<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"] - SamsonDentalCenterManagementSystem</title>
  <script type="importmap"></script>

  <script>
    if (localStorage.getItem("sidebarCollapsed") === "true") {
      document.documentElement.classList.add("sb-collapsed");
    }
  </script>

  <link rel="stylesheet" href="~/css/admin.css" />
  <link rel="stylesheet" href="~/css/tailwind.css" />
  <link rel="stylesheet" href="~/SamsonDentalCenterManagementSystem.styles.css" asp-append-version="true" />
  <script src="https://cdn.tailwindcss.com"></script>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

  <link href="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.css" rel="stylesheet" />

  <link
    href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap"
    rel="stylesheet" />

  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script src="~/js/config.js" asp-append-version="true"></script>
  <script type="module" src="~/js/AdminSide/site.js" asp-append-version="true" defer></script>
</head>

<body>
  <!-- Overlay for mobile sidebar -->
  <div id="overlay" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[150] hidden"></div>

  <div class="flex min-h-screen">
    <!-- ══════════════════════════════════════ -->
    <!-- SIDEBAR                                -->
    <!-- ══════════════════════════════════════ -->
    <aside id="sidebar"
      class="w-[256px] bg-brand fixed left-0 top-0 h-dvh z-[200] transition-all duration-300 -translate-x-full lg:translate-x-0">
      <div class="flex flex-col relative h-full w-full">
        <div class="flex items-center gap-3 px-4 py-5 border-b border-white/[0.07] flex-shrink-0 overflow-hidden">
          <div class="w-9 h-9 rounded-[10px] bg-primary flex items-center justify-center flex-shrink-0">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2" />
            </svg>
          </div>
          <div class="sidebar-text flex flex-col transition-opacity duration-300">
            <span class="sidebar-text font-display text-white font-bold text-[15px] leading-tight">MediCore</span>
            <span class="sidebar-text text-[10px] text-white whitespace-nowrap">Health Management</span>
          </div>

          <button id="toggle-btn"
            class="absolute -right-3 top-5 p-1 rounded-full bg-[#1f2c4b] text-white transition-colors hidden lg:flex items-center justify-center flex-shrink-0">
            <svg id="toggle-icon" class="transition-transform duration-300" width="18" height="18" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <!-- Chevron Left -->
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>
        </div>

        <nav class="flex-1 overflow-y-auto py-2 overflow-x-hidden">
          <div class="nav-label px-7 py-2.5">
            <span
              class="sidebar-text text-[9.5px] font-bold uppercase tracking-[0.12em] text-white font-display">Main</span>
          </div>

          <a class="nav-item flex items-center gap-4 px-4 py-2.5 mx-2 rounded-xl cursor-pointer text-white text-[13px] font-medium transition-all"
            href="../admin/dashboard" id="admin-dashboard">
            <svg class="flex-shrink-0" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="7" />
              <rect x="14" y="3" width="7" height="7" />
              <rect x="3" y="14" width="7" height="7" />
              <rect x="14" y="14" width="7" height="7" />
            </svg>
            <span class="sidebar-text transition-opacity duration-300">Dashboard</span>
          </a>
          <!-- <div
              id="tooltip-dashboard"
              role="tooltip"
              class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white bg-brand rounded-lg shadow-xs opacity-0 tooltip"
            >
              Dashboard
              <div class="tooltip-arrow" data-popper-arrow></div>
            </div> -->
          <div class="nav-label px-7 py-2.5 mt-1">
            <span
              class="sidebar-text text-[9.5px] font-bold uppercase tracking-[0.12em] text-white font-display">People</span>
          </div>
          <a class="nav-item flex items-center gap-4 px-4 py-2.5 mx-2 rounded-xl cursor-pointer text-white text-[13px] font-medium transition-all"
            href="../admin/patients" id="admin-patients">
            <svg class="pl-0.5 flex" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
              <circle cx="9" cy="7" r="4" />
            </svg>
            <span class="sidebar-text transition-opacity duration-300">Patients</span>
            <span
              class="nav-badge sidebar-text ml-auto bg-accent text-white text-[9px] font-bold px-1.5 py-0.5 rounded-full">248</span>
          </a>
          <a class="nav-item flex items-center gap-4 px-4 py-2.5 mx-2 rounded-xl cursor-pointer text-white text-[13px] font-medium transition-all"
            href="../admin/doctors" id="admin-doctors">
            <svg class="flex-shrink-0" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 7h-9" />

              <path d="M14 17H5" />

              <circle cx="17" cy="17" r="3" />

              <circle cx="7" cy="7" r="3" />
            </svg>

            <span class="sidebar-text transition-opacity duration-300">Doctors</span>
          </a>
          <a class="nav-item flex items-center gap-4 px-4 py-2.5 mx-2 rounded-xl cursor-pointer text-white text-[13px] font-medium transition-all"
            href="../admin/users" id="admin-users">
            <svg class="pl-0.5 flex" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
              <circle cx="9" cy="7" r="4" />
            </svg>
            <span class="sidebar-text transition-opacity duration-300">Users</span>
            <span
              class="nav-badge sidebar-text ml-auto bg-accent text-white text-[9px] font-bold px-1.5 py-0.5 rounded-full">248</span>
          </a>

          <div class="px-7 py-2.5 mt-1">
            <span
              class="sidebar-text text-[9.5px] font-bold uppercase tracking-[0.12em] text-white font-display">Operations</span>
          </div>

          <a class="nav-item flex items-center gap-4 px-4 py-2.5 mx-2 rounded-xl cursor-pointer text-white text-[13px] font-medium transition-all"
            href="../admin/appointments" id="admin-appointments">
            <svg class="flex-shrink-0" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />

              <line x1="16" y1="2" x2="16" y2="6" />

              <line x1="8" y1="2" x2="8" y2="6" />

              <line x1="3" y1="10" x2="21" y2="10" />
            </svg>

            <span class="sidebar-text transition-opacity duration-300">Appointments</span>

            <span
              class="sidebar-text ml-auto bg-accent text-white text-[9px] font-bold px-1.5 py-0.5 rounded-full font-display">12</span>
          </a>

          <a class="nav-item flex items-center gap-4 px-4 py-2.5 mx-2 rounded-xl cursor-pointer text-white text-[13px] font-medium transition-all"
            href="../admin/services" id="admin-services">
            <svg class="flex-shrink-0" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2a5 5 0 0 1 5 5v3H7V7a5 5 0 0 1 5-5z" />

              <rect x="2" y="10" width="20" height="12" rx="2" />

              <path d="M12 14v4" />

              <path d="M10 16h4" />
            </svg>

            <span class="sidebar-text transition-opacity duration-300">Services</span>
          </a>
          <a class="nav-item flex items-center gap-4 px-4 py-2.5 mx-2 rounded-xl cursor-pointer text-white text-[13px] font-medium transition-all"
            href="../admin/transactions" id="admin-services">
            <svg class="flex-shrink-0" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2a5 5 0 0 1 5 5v3H7V7a5 5 0 0 1 5-5z" />

              <rect x="2" y="10" width="20" height="12" rx="2" />

              <path d="M12 14v4" />

              <path d="M10 16h4" />
            </svg>

            <span class="sidebar-text transition-opacity duration-300">Transactions</span>
          </a>

          <div class="px-7 py-2.5 mt-1">
            <span
              class="sidebar-text text-[9.5px] font-bold uppercase tracking-[0.12em] text-white font-display">Analytics</span>
          </div>

          <a class="nav-item flex items-center gap-4 px-4 py-2.5 mx-2 rounded-xl cursor-pointer text-white text-[13px] font-medium transition-all"
            href="../admin/reports" id="admin-reports">
            <svg class="flex-shrink-0" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="20" x2="18" y2="10" />

              <line x1="12" y1="20" x2="12" y2="4" />

              <line x1="6" y1="20" x2="6" y2="14" />
            </svg>

            <span class="sidebar-text transition-opacity duration-300">Reports</span>
          </a>

          <a class="nav-item flex items-center gap-4 px-4 py-2.5 mx-2 rounded-xl cursor-pointer text-white text-[13px] font-medium transition-all"
            href="../admin/inquiries" id="admin-inquiries">
            <svg class="flex-shrink-0" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
            </svg>

            <span class="sidebar-text transition-opacity duration-300">Inquiries</span>

            <span
              class="sidebar-text ml-auto bg-accent text-white text-[9px] font-bold px-1.5 py-0.5 rounded-full font-display">5</span>
          </a>

          <a class="nav-item flex items-center gap-4 px-4 py-2.5 mx-2 rounded-xl cursor-pointer text-white text-[13px] font-medium transition-all"
            href="../admin/activitylogs" id="admin-activitylogs">
            <svg class="flex-shrink-0" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
            </svg>

            <span class="sidebar-text transition-opacity duration-300">Activity Logs</span>
          </a>
        </nav>

        <div class="p-2 border-t border-white/[0.07] flex-shrink-0 overflow-hidden">
          <div class="flex justify-between items-center p-2.5 rounded-xl bg-white/[0.05]">
            <div class="flex items-center gap-2.5">
              <div
                class="w-8 h-8 rounded-full bg-primary primary/80 flex items-center justify-center text-white text-[11px] font-bold flex-shrink-0">
                AJ
              </div>
              <div class="sidebar-text flex flex-col min-w-0">
                <span class="text-[12px] font-semibold text-white truncate">Dr. Ana J.</span>
                <span class="text-[10px] text-white">Admin</span>
              </div>
            </div>
            <button id="signoutBtn"
              class="sidebar-text border-none bg-transparent text-white flex items-center gap-2.5 px-4 py-2.5 rounded-xl hover:text-red-600 hover:bg-white/[0.05] transition-colors font-medium">
              <svg class="menu-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                <polyline points="16 17 21 12 16 7" />
                <line x1="21" y1="12" x2="9" y2="12" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </aside>

    <!-- MAIN -->
    <main id="main"
      class="flex-1 flex flex-col min-h-screen transition-all duration-[250ms] lg:ml-[256px] overflow-hidden">
      <!-- TOPBAR -->
      <header
        class="bg-white border-b border-slate-200 sticky top-0 z-[50] flex items-center justify-between px-4 lg:px-6 h-[60px] flex-shrink-0 ">
        <div class="flex items-center gap-3">
          <!-- Hamburger (mobile only) -->
          <button class="lg:hidden p-2 rounded-lg hover:bg-slate-100 text-slate-600 transition-colors"
            id="openSidebarBtn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round">
              <line x1="3" y1="6" x2="21" y2="6" />
              <line x1="3" y1="12" x2="21" y2="12" />
              <line x1="3" y1="18" x2="21" y2="18" />
            </svg>
          </button>
          <div>
            <h1 id="page-title" class="font-display text-[15px] font-bold text-brand-900 leading-tight">
              Dashboard
            </h1>
            <p id="page-breadcrumb" class="text-[10.5px] text-brand-500">
              Overview · Today
            </p>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <div class="relative hidden sm:block">
            <svg class="absolute left-2.5 top-1/2 translate-half text-slate-400" width="13" height="13"
              viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
              stroke-linejoin="round">
              <circle cx="11" cy="11" r="8" />
              <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
            <input placeholder="Search…"
              class="pl-8 pr-3 py-1.5 text-[12px] bg-slate-50 border border-slate-200 rounded-lg outline-none focus:border-primary/50 focus:ring-2 focus:ring-primary/10 w-44" />
          </div>
          <button class="relative p-2 rounded-lg border border-slate-200 bg-white hover:bg-slate-50 transition-colors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#374151" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
              <path d="M13.73 21a2 2 0 0 1-3.46 0" />
            </svg>
            <span class="absolute top-1.5 right-1.5 w-1.5 h-1.5 rounded-full bg-accent pulse"></span>
          </button>
          <div id="date-pill"
            class="hidden md:flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-[11px] font-medium text-brand-500 bg-slate-50 border border-slate-200">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" />
              <line x1="16" y1="2" x2="16" y2="6" />
              <line x1="8" y1="2" x2="8" y2="6" />
              <line x1="3" y1="10" x2="21" y2="10" />
            </svg>
            <span id="cur-date"></span>
          </div>
        </div>
      </header>

      <!-- PAGE CONTENT -->
      <div class="flex-1 max-w-full overflow-hidden">@RenderBody()</div>
    </main>
  </div>

  <!-- Toast Container -->
  <div id="toast-container" class="fixed top-5 right-5 space-y-1 z-50"></div>

  <!-- Modal Root -->
  <div id="modal-root"></div>

  <script src="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.js"></script>

  @await RenderSectionAsync("Scripts", required: false)
</body>

</html>