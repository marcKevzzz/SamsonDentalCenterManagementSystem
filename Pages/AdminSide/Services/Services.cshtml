@page "/Admin/Services"
@model AdminServicesModel
@{
Layout = "AdminSide/_AdminLayout";
var services = Model.Services ?? new List<SamsonDentalCenterManagementSystem.Models.DentalService>();
  }

  <script id="services-data" type="application/json">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        services.Select(s => new {
            id       = s.Id,
            slug     = s.Slug,
            category = s.Category,
            name     = s.Name,
            tagline  = s.Tagline,
            summary  = s.Summary ?? "",
            duration = s.Duration ?? "",
            recovery = s.Recovery ?? "",
            price    = s.Price,
            benefits = s.Benefits,
            isActive = s.IsActive
        })
    ))
</script>

  <div id="page-services" class="page p-4 md:p-6">

    <div class="flex flex-wrap items-center justify-between gap-3 mb-5">
      <div>
        <h2 class="font-display text-xl font-extrabold text-brand">Services</h2>
        <p class="text-[12px] text-muted mt-0.5">Dental services and pricing catalog</p>
      </div>
      <button id="addServiceBtn"
        class="flex items-center gap-1.5 px-4 py-2 rounded-xl text-[12.5px] font-semibold text-white bg-primary shadow-md shadow-primary/25 hover:shadow-primary/40 transition-shadow">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19" />
          <line x1="5" y1="12" x2="19" y2="12" />
        </svg>
        Add Service
      </button>
    </div>

    <div class="flex flex-wrap items-center gap-2 mb-4">
      <div class="relative flex-1 min-w-[140px] max-w-[240px]">
        <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 text-slate-400" width="12" height="12"
          viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
        <input id="searchInput" placeholder="Search services…"
          class="w-full pl-7 pr-3 py-1.5 text-[12px] bg-white border border-slate-200 rounded-lg outline-none focus:border-primary/40" />
      </div>
      <select id="categoryFilter"
        class="px-3 py-1.5 text-[12px] bg-white border border-slate-200 rounded-lg text-muted outline-none">
        <option value="">All Categories</option>
        <option value="General Dentistry">General Dentistry</option>
        <option value="Cosmetic">Cosmetic</option>
        <option value="Specialized">Specialized</option>
      </select>
      <select id="statusFilter"
        class="px-3 py-1.5 text-[12px] bg-white border border-slate-200 rounded-lg text-muted outline-none">
        <option value="">All Status</option>
        <option value="true">Active</option>
        <option value="false">Inactive</option>
      </select>
      <span class="ml-auto text-[11px] text-slate-400" id="svcCount">@services.Count services</span>
    </div>

    <div id="servicesGrid" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4"></div>

    <div id="emptyState" class="hidden py-16 text-center">
      <div class="text-slate-300 text-4xl mb-3">🦷</div>
      <p class="text-[13px] text-slate-400 font-medium">No services found</p>
    </div>
  </div>

  <div id="svcModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl max-h-[92vh] overflow-y-auto">
      <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
        <h3 id="modalTitle" class="font-display font-bold text-[15px] text-brand">Add Service</h3>
        <button id="closeModalBtn" class="text-slate-400 hover:text-slate-700 transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>

      <div class="px-6 py-5 space-y-4">
        <input type="hidden" id="modalSvcId" />

        <div class="grid grid-cols-2 gap-4">
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] font-semibold text-slate-600 tracking-wide">Service Name <span
                class="text-red-400">*</span></label>
            <input id="mName" type="text" placeholder="e.g. Teeth Cleaning"
              class="modal-input px-3 py-2 border border-slate-200 rounded-lg text-[13px] outline-none focus:border-primary/50 focus:ring-2 focus:ring-primary/10" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] font-semibold text-slate-600 tracking-wide">Category <span
                class="text-red-400">*</span></label>
            <select id="mCategory"
              class="modal-input px-3 py-2 border border-slate-200 rounded-lg text-[13px] outline-none focus:border-primary/50 focus:ring-2 focus:ring-primary/10">
              <option value="General Dentistry">General Dentistry</option>
              <option value="Cosmetic">Cosmetic</option>
              <option value="Specialized">Specialized</option>
            </select>
          </div>
        </div>

        <div class="flex flex-col gap-1.5">
          <label class="text-[11px] font-semibold text-slate-600 tracking-wide">Tagline <span
              class="text-red-400">*</span></label>
          <input id="mTagline" type="text" placeholder="Short description shown on cards"
            class="modal-input px-3 py-2 border border-slate-200 rounded-lg text-[13px] outline-none focus:border-primary/50 focus:ring-2 focus:ring-primary/10" />
        </div>

        <div class="flex flex-col gap-1.5">
          <label class="text-[11px] font-semibold text-slate-600 tracking-wide">Summary</label>
          <textarea id="mSummary" rows="3" placeholder="Detailed description for the service page…" style="resize:none"
            class="modal-input px-3 py-2 border border-slate-200 rounded-lg text-[13px] outline-none focus:border-primary/50 focus:ring-2 focus:ring-primary/10"></textarea>
        </div>

        <div class="flex flex-col gap-1.5">
          <label class="text-[11px] font-semibold text-slate-600 tracking-wide">Hero Image</label>
          <div class="flex items-center gap-3">
            <div id="heroPreview"
              class="w-16 h-16 rounded-xl bg-slate-100 border border-slate-200 overflow-hidden flex items-center justify-center shrink-0">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2" />
                <circle cx="8.5" cy="8.5" r="1.5" />
                <polyline points="21 15 16 10 5 21" />
              </svg>
            </div>
            <div class="flex-1">
              <input type="hidden" id="mHero" />
              <input type="file" id="heroFileInput" accept="image/*" class="hidden" />
              <button type="button" id="heroUploadBtn" class="text-[11.5px] font-semibold text-primary border border-primary/20 px-3 py-1.5 rounded-lg
                       hover:bg-primary hover:text-white transition-all">
                Upload Hero Image
              </button>
              <p class="text-[10px] text-muted mt-1">JPG, PNG — max 10MB. Displayed at top of service page.</p>
              <p id="heroUploadStatus" class="text-[10px] text-emerald-600 mt-1 hidden">✓ Image uploaded</p>
            </div>
          </div>
        </div>
        <div class="grid grid-cols-3 gap-3">
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] font-semibold text-slate-600 tracking-wide">Price <span
                class="text-red-400">*</span></label>
            <input id="mPrice" type="text" placeholder="e.g. ₱800"
              class="modal-input px-3 py-2 border border-slate-200 rounded-lg text-[13px] outline-none focus:border-primary/50 focus:ring-2 focus:ring-primary/10" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] font-semibold text-slate-600 tracking-wide">Duration</label>
            <input id="mDuration" type="text" placeholder="e.g. 45–60 min"
              class="modal-input px-3 py-2 border border-slate-200 rounded-lg text-[13px] outline-none focus:border-primary/50 focus:ring-2 focus:ring-primary/10" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] font-semibold text-slate-600 tracking-wide">Recovery</label>
            <input id="mRecovery" type="text" placeholder="e.g. None"
              class="modal-input px-3 py-2 border border-slate-200 rounded-lg text-[13px] outline-none focus:border-primary/50 focus:ring-2 focus:ring-primary/10" />
          </div>
        </div>

        <div class="flex flex-col gap-1.5">
          <label class="text-[11px] font-semibold text-slate-600 tracking-wide">Benefits</label>
          <div id="benefitsList" class="space-y-2"></div>
          <button id="addBenefitBtn" type="button"
            class="text-[11px] font-semibold text-primary hover:underline text-left mt-1">
            + Add benefit
          </button>
        </div>

        <div class="flex items-center gap-3">
          <label class="text-[11px] font-semibold text-slate-600 tracking-wide">Status</label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" id="mIsActive" class="w-4 h-4 accent-primary" checked />
            <span class="text-[12px] text-slate-600">Active (visible to patients)</span>
          </label>
        </div>

        <p id="modalError" class="hidden text-[12px] text-red-500 font-medium"></p>
      </div>

      <div class="flex justify-end gap-2 px-6 py-4 border-t border-slate-100">
        <button id="cancelModalBtn"
          class="px-4 py-2 text-[12.5px] font-semibold text-slate-500 border border-slate-200 rounded-xl hover:bg-slate-50 transition-colors">
          Cancel
        </button>
        <button id="modalSaveBtn"
          class="px-5 py-2 text-[12.5px] font-semibold text-white bg-primary rounded-xl hover:bg-primary/90 transition-colors">
          Save Service
        </button>
      </div>
    </div>
  </div>

  <div id="deleteModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6">
      <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center mb-4">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <polyline points="3 6 5 6 21 6" />
          <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
        </svg>
      </div>
      <h3 class="font-display font-bold text-[15px] text-brand mb-1">Delete Service</h3>
      <p class="text-[13px] text-slate-500 mb-5">
        Delete <strong id="deleteSvcName"></strong>? This cannot be undone.
      </p>
      <div class="flex gap-2 justify-end">
        <button id="cancelDeleteBtn"
          class="px-4 py-2 text-[12.5px] font-semibold text-slate-500 border border-slate-200 rounded-xl hover:bg-slate-50 transition-colors">
          Cancel
        </button>
        <button id="confirmDeleteBtn"
          class="px-5 py-2 text-[12.5px] font-semibold text-white bg-red-500 rounded-xl hover:bg-red-600 transition-colors">
          Delete
        </button>
      </div>
    </div>
  </div>

  <script type="module" src="~/js/AdminSide/adminServices.js"></script>