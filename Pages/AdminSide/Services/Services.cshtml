@page "/Admin/Services"
@model AdminServicesModel
@{
Layout = "AdminSide/_AdminLayout";
}


<div id="page-services" class="page p-4 md:p-6">
  <div class="flex flex-wrap items-center justify-between gap-3 mb-5">
    <div>
      <h2 class="font-display text-xl font-extrabold text-brand-900">
        Services
      </h2>
      <p class="text-[12px] text-brand-500 mt-0.5">
        Medical services and pricing catalog
      </p>
    </div>
    <button
      class="flex items-center gap-1.5 px-4 py-2 rounded-xl text-[12.5px] font-semibold text-white bg-primary shadow-md shadow-primary/25"
    >
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="12" y1="5" x2="12" y2="19" />
        <line x1="5" y1="12" x2="19" y2="12" /></svg
      >Add Service
    </button>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
    <div
      class="bg-white rounded-2xl p-5 border border-slate-200 hover:shadow-md transition-shadow"
    >
      <div
        class="w-9 h-9 rounded-xl bg-blue-50 flex items-center justify-center mb-3"
      >
        <svg
          width="17"
          height="17"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#1E40AF"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M12 2a5 5 0 0 1 5 5v3H7V7a5 5 0 0 1 5-5z" />
          <rect x="2" y="10" width="20" height="12" rx="2" />
        </svg>
      </div>
      <h4 class="font-display font-bold text-brand-900">
        General Consultation
      </h4>
      <p class="text-[11px] text-brand-400 mt-1 mb-3">
        Basic checkup and diagnosis
      </p>
      <div class="flex items-center justify-between">
        <span class="font-display font-extrabold text-lg text-primary"
          >₱500</span
        ><span
          class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700 font-display"
          >Active</span
        >
      </div>
    </div>
    <div
      class="bg-white rounded-2xl p-5 border border-slate-200 hover:shadow-md transition-shadow"
    >
      <div
        class="w-9 h-9 rounded-xl bg-red-50 flex items-center justify-center mb-3"
      >
        <svg
          width="17"
          height="17"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#c0392b"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
        </svg>
      </div>
      <h4 class="font-display font-bold text-brand-900">ECG / Cardiology</h4>
      <p class="text-[11px] text-brand-400 mt-1 mb-3">
        Electrocardiogram and heart eval
      </p>
      <div class="flex items-center justify-between">
        <span class="font-display font-extrabold text-lg text-accent"
          >₱1,200</span
        ><span
          class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700 font-display"
          >Active</span
        >
      </div>
    </div>
    <div
      class="bg-white rounded-2xl p-5 border border-slate-200 hover:shadow-md transition-shadow"
    >
      <div
        class="w-9 h-9 rounded-xl bg-emerald-50 flex items-center justify-center mb-3"
      >
        <svg
          width="17"
          height="17"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#059669"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
          <circle cx="9" cy="7" r="4" />
        </svg>
      </div>
      <h4 class="font-display font-bold text-brand-900">Pediatric Visit</h4>
      <p class="text-[11px] text-brand-400 mt-1 mb-3">
        Child health assessment
      </p>
      <div class="flex items-center justify-between">
        <span class="font-display font-extrabold text-lg text-emerald-600"
          >₱650</span
        ><span
          class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700 font-display"
          >Active</span
        >
      </div>
    </div>
    <div
      class="bg-white rounded-2xl p-5 border border-slate-200 hover:shadow-md transition-shadow"
    >
      <div
        class="w-9 h-9 rounded-xl bg-violet-50 flex items-center justify-center mb-3"
      >
        <svg
          width="17"
          height="17"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#7c3aed"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="10" />
          <line x1="12" y1="8" x2="12" y2="16" />
          <line x1="8" y1="12" x2="16" y2="12" />
        </svg>
      </div>
      <h4 class="font-display font-bold text-brand-900">Laboratory Tests</h4>
      <p class="text-[11px] text-brand-400 mt-1 mb-3">
        CBC, urinalysis, blood chemistry
      </p>
      <div class="flex items-center justify-between">
        <span class="font-display font-extrabold text-lg text-violet-600"
          >₱800</span
        ><span
          class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700 font-display"
          >Active</span
        >
      </div>
    </div>
    <div
      class="bg-white rounded-2xl p-5 border border-slate-200 hover:shadow-md transition-shadow"
    >
      <div
        class="w-9 h-9 rounded-xl bg-amber-50 flex items-center justify-center mb-3"
      >
        <svg
          width="17"
          height="17"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#f59e0b"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="3" y="3" width="18" height="18" rx="2" />
          <line x1="3" y1="9" x2="21" y2="9" />
          <line x1="9" y1="21" x2="9" y2="9" />
        </svg>
      </div>
      <h4 class="font-display font-bold text-brand-900">X-Ray / Imaging</h4>
      <p class="text-[11px] text-brand-400 mt-1 mb-3">
        Digital X-ray and ultrasound
      </p>
      <div class="flex items-center justify-between">
        <span class="font-display font-extrabold text-lg text-amber-500"
          >₱1,500</span
        ><span
          class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700 font-display"
          >Active</span
        >
      </div>
    </div>
    <div
      class="bg-white rounded-2xl p-5 border border-slate-200 hover:shadow-md transition-shadow"
    >
      <div
        class="w-9 h-9 rounded-xl bg-red-50 flex items-center justify-center mb-3"
      >
        <svg
          width="17"
          height="17"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#c0392b"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
        </svg>
      </div>
      <h4 class="font-display font-bold text-brand-900">Emergency Care</h4>
      <p class="text-[11px] text-brand-400 mt-1 mb-3">
        24/7 emergency medical services
      </p>
      <div class="flex items-center justify-between">
        <span class="font-display font-extrabold text-lg text-accent"
          >₱3,000+</span
        ><span
          class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700 font-display"
          >Active</span
        >
      </div>
    </div>
  </div>
</div>
