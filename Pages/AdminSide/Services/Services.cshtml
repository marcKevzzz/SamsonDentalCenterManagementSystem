@page "/Admin/Services"
@model AdminServicesModel
@{
Layout = "AdminSide/_StaffLayout";
var services = Model.Services ?? new List<SamsonDentalCenterManagementSystem.Models.DentalService>();
  }

  <script id="services-data" type="application/json">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        services.Select(s => new {
            id       = s.Id,
            slug     = s.Slug,
            category = s.Category,
            name     = s.Name,
            tagline  = s.Tagline,
            summary  = s.Summary ?? "",
            duration = s.Duration ?? "",
            recovery = s.Recovery ?? "",
            price    = s.Price,
            benefits = s.Benefits,
            isActive = s.IsActive
        })
    ))
</script>

  <div id="page-services" class="page p-4 md:p-6">

    <div class="flex flex-wrap items-center justify-between gap-3 mb-5">
      <div>
        <h2 class=" text-xl font-extrabold text-brand">Services</h2>
        <p class="text-[12px] text-muted mt-0.5">Dental services and pricing catalog</p>
      </div>
      <button id="addServiceBtn"
        class="flex items-center gap-1.5 px-4 py-2 rounded-xl text-[12.5px] font-semibold text-white bg-primary shadow-md shadow-primary/25 hover:shadow-primary/40 transition-shadow">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19" />
          <line x1="5" y1="12" x2="19" y2="12" />
        </svg>
        Add Service
      </button>
    </div>

    <!-- Filter bar -->
    <div class="flex flex-wrap items-center gap-3 mb-6 bg-slate-50/50 p-3 rounded-2xl border border-slate-100">
      <div class="relative flex-1 min-w-[240px]">
        <i class="fa-solid fa-magnifying-glass absolute left-3.5 top-1/2 -translate-y-1/2 text-brand-300 text-[11px]"></i>
        <input id="searchInput" type="text" placeholder="Search services by name or description…"
          class="w-full text-[12px] pl-9 pr-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-primary/20 transition-all bg-white" />
      </div>
      
      <div class="flex items-center gap-2">
        <span class="text-[10px] font-bold uppercase tracking-wider text-brand-400 ml-2">Category:</span>
        <select id="categoryFilter"
          class="text-[12px] px-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-primary/20 bg-white min-w-[140px]">
          <option value="">All Categories</option>
          <option value="General Dentistry">General Dentistry</option>
          <option value="Cosmetic">Cosmetic</option>
          <option value="Specialized">Specialized</option>
        </select>
      </div>

      <div class="flex items-center gap-2">
        <span class="text-[10px] font-bold uppercase tracking-wider text-brand-400 ml-2">Status:</span>
        <select id="statusFilter"
          class="text-[12px] px-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-primary/20 bg-white min-w-[120px]">
          <option value="">All Status</option>
          <option value="true">Active</option>
          <option value="false">Inactive</option>
        </select>
      </div>
      
      <span class="ml-auto text-[11px] font-medium text-brand-400 bg-white px-3 py-1.5 rounded-lg border border-slate-100" id="svcCount">
        @services.Count services
      </span>
    </div>

    <div id="servicesGrid" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4"></div>

    <div id="emptyState" class="hidden py-16 text-center">
      <div class="text-slate-300 text-4xl mb-3">🦷</div>
      <p class="text-[13px] text-slate-400 font-medium">No services found</p>
    </div>
  </div>

  <div id="svcModal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-brand-900/40 backdrop-blur-md" ></div>
    <div class="absolute inset-0 flex items-center justify-center p-4 pointer-events-none">
      <div id="svcModal-box" class="bg-white w-full max-w-2xl rounded-[32px] shadow-2xl overflow-hidden pointer-events-auto flex flex-col max-h-[92vh]">
        
        <!-- Modal Header with Banner -->
        <div class="relative bg-brand px-8 py-4 overflow-hidden shrink-0">
          <div class="absolute top-0 right-0 w-64 h-64 bg-blue-500 rounded-full blur-3xl -mr-32 -mt-32"></div>
          <div class="relative z-10 flex items-center justify-between">
            <div>
              <h3 id="modalTitle" class=" font-bold text-2xl text-white tracking-tight">Add Service</h3>
              <p class="text-white/60 text-[12px] mt-1 font-medium">Configure service details and patient information</p>
            </div>
            <button  class="w-10 h-10 rounded-full bg-white/10 text-white hover:bg-white/20 transition-all flex items-center justify-center" id="closeModalBtn">
              <i class="fa-solid fa-xmark"></i>
            </button>
          </div>
        </div>

        <div class="p-4 space-y-4 overflow-y-auto">
          <input type="hidden" id="modalSvcId" />

          <!-- Section: Basic Info -->
          <div class="space-y-4">
            <div class="flex items-center gap-2 mb-2">
              <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
              <h4 class="text-[11px] font-bold uppercase tracking-wider text-brand-400">Basic Information</h4>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div class="col-span-2">
                <label class="block text-[11px] font-bold text-brand-500 mb-1.5 ml-1">Service Name *</label>
                <div class="relative">
                  <i class="fa-solid fa-tooth absolute left-4 top-1/2 -translate-y-1/2 text-brand-200 text-xs"></i>
                  <input id="mName" type="text" placeholder="e.g. Teeth Cleaning"
                    class="w-full text-[13px] pl-10 pr-4 py-3 rounded-2xl border border-slate-100 bg-slate-50/50 focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/5 transition-all outline-none" />
                </div>
              </div>
              <div>
                <label class="block text-[11px] font-bold text-brand-500 mb-1.5 ml-1">Category *</label>
                <div class="relative">
                  <i class="fa-solid fa-tags absolute left-4 top-1/2 -translate-y-1/2 text-brand-200 text-xs"></i>
                  <select id="mCategory"
                    class="w-full text-[13px] pl-10 pr-4 py-3 rounded-2xl border border-slate-100 bg-slate-50/50 focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/5 transition-all outline-none appearance-none">
                    <option value="General Dentistry">General Dentistry</option>
                    <option value="Cosmetic">Cosmetic</option>
                    <option value="Specialized">Specialized</option>
                  </select>
                </div>
              </div>
              <div>
                <label class="block text-[11px] font-bold text-brand-500 mb-1.5 ml-1">Status</label>
                <div class="flex items-center gap-4 py-3 px-4 rounded-2xl bg-slate-50/50 border border-slate-100">
                  <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" id="mIsActive" class="sr-only peer" checked>
                    <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-primary/20 rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                    <span class="ms-3 text-[12px] font-medium text-brand-600">Active</span>
                  </label>
                </div>
              </div>
            </div>

            <div class="col-span-2">
              <label class="block text-[11px] font-bold text-brand-500 mb-1.5 ml-1">Tagline *</label>
              <div class="relative">
                <i class="fa-solid fa-quote-left absolute left-4 top-1/2 -translate-y-1/2 text-brand-200 text-xs"></i>
                <input id="mTagline" type="text" placeholder="Short description shown on cards"
                  class="w-full text-[13px] pl-10 pr-4 py-3 rounded-2xl border border-slate-100 bg-slate-50/50 focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/5 transition-all outline-none" />
              </div>
            </div>

            <div class="col-span-2">
              <label class="block text-[11px] font-bold text-brand-500 mb-1.5 ml-1">Summary</label>
              <textarea id="mSummary" rows="3" placeholder="Detailed description for the service page…" 
                class="w-full text-[13px] px-4 py-3 rounded-2xl border border-slate-100 bg-slate-50/50 focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/5 transition-all outline-none resize-none"></textarea>
            </div>
          </div>

          <!-- Section: Images & Media -->
          <div class="space-y-4 pt-4 border-t border-slate-100">
            <div class="flex items-center gap-2 mb-2">
              <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
              <h4 class="text-[11px] font-bold uppercase tracking-wider text-brand-400">Media & Visuals</h4>
            </div>

            <div class="flex items-center gap-6 p-4 rounded-2xl bg-slate-50/50 border border-slate-100">
              <div id="heroPreview" class="w-24 h-24 rounded-2xl bg-white border border-slate-100 shadow-sm overflow-hidden flex items-center justify-center shrink-0">
                <i class="fa-solid fa-image text-brand-100 text-3xl"></i>
              </div>
              <div class="flex-1 space-y-2">
                <input type="hidden" id="mHero" />
                <input type="file" id="heroFileInput" accept="image/*" class="hidden" />
                <button type="button" id="heroUploadBtn" 
                  class="px-4 py-2 text-[12px] font-bold text-primary bg-white border border-primary/20 rounded-xl hover:bg-primary hover:text-white transition-all">
                  Choose Hero Image
                </button>
                <p class="text-[10px] text-brand-400">Recommended size: 1920x1080px. Max 10MB.</p>
                <p id="heroUploadStatus" class="text-[10px] text-emerald-600 font-bold hidden"><i class="fa-solid fa-check mr-1"></i> Image ready to upload</p>
              </div>
            </div>
          </div>

          <!-- Section: Pricing & Logistics -->
          <div class="space-y-4 pt-4 border-t border-slate-100">
            <div class="flex items-center gap-2 mb-2">
              <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
              <h4 class="text-[11px] font-bold uppercase tracking-wider text-brand-400">Pricing & Logistics</h4>
            </div>

            <div class="grid grid-cols-3 gap-4">
              <div>
                <label class="block text-[11px] font-bold text-brand-500 mb-1.5 ml-1">Price *</label>
                <div class="relative">
                  <i class="fa-solid fa-peso-sign absolute left-4 top-1/2 -translate-y-1/2 text-brand-200 text-xs"></i>
                  <input id="mPrice" type="text" placeholder="e.g. 800"
                    class="w-full text-[13px] pl-10 pr-4 py-3 rounded-2xl border border-slate-100 bg-slate-50/50 focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/5 transition-all outline-none" />
                </div>
              </div>
              <div>
                <label class="block text-[11px] font-bold text-brand-500 mb-1.5 ml-1">Duration</label>
                <div class="relative">
                  <i class="fa-solid fa-clock absolute left-4 top-1/2 -translate-y-1/2 text-brand-200 text-xs"></i>
                  <input id="mDuration" type="text" placeholder="e.g. 45 min"
                    class="w-full text-[13px] pl-10 pr-4 py-3 rounded-2xl border border-slate-100 bg-slate-50/50 focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/5 transition-all outline-none" />
                </div>
              </div>
              <div>
                <label class="block text-[11px] font-bold text-brand-500 mb-1.5 ml-1">Recovery</label>
                <div class="relative">
                  <i class="fa-solid fa-bed absolute left-4 top-1/2 -translate-y-1/2 text-brand-200 text-xs"></i>
                  <input id="mRecovery" type="text" placeholder="e.g. None"
                    class="w-full text-[13px] pl-10 pr-4 py-3 rounded-2xl border border-slate-100 bg-slate-50/50 focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/5 transition-all outline-none" />
                </div>
              </div>
            </div>
          </div>

          <!-- Section: Benefits -->
          <div class="space-y-4 pt-4 border-t border-slate-100 pb-4">
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
                <h4 class="text-[11px] font-bold uppercase tracking-wider text-brand-400">Service Benefits</h4>
              </div>
              <button id="addBenefitBtn" type="button" class="text-[11px] font-bold text-primary hover:text-primary-dark flex items-center gap-1">
                <i class="fa-solid fa-plus"></i> Add Benefit
              </button>
            </div>
            <div id="benefitsList" class="grid grid-cols-1 gap-2"></div>
          </div>

          <p id="modalError" class="hidden text-[12px] text-red-500 font-medium bg-red-50 p-3 rounded-xl border border-red-100 text-center"></p>
        </div>

        <!-- Modal Footer -->
        <div class="p-6 border-t border-slate-100 flex items-center justify-end gap-3 bg-slate-50/50 shrink-0">
          <button  
            class="px-6 py-3 text-[13px] font-bold text-brand-500 hover:text-brand-700 transition-colors">
            Discard Changes
          </button>
          <button id="modalSaveBtn" 
            class="px-8 py-3 bg-primary text-white text-[13px] font-bold rounded-2xl shadow-lg shadow-primary/25 hover:shadow-primary/40 hover:-translate-y-0.5 active:translate-y-0 transition-all">
            Save Service Profile
          </button>
        </div>
      </div>
    </div>
  </div>

  <div id="deleteModal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-brand-900/40 backdrop-blur-md" ></div>
    <div class="absolute inset-0 flex items-center justify-center p-4 pointer-events-none">
      <div id="deleteModal-box" class="bg-white w-full max-w-sm rounded-[32px] shadow-2xl overflow-hidden pointer-events-auto">
        <div class="p-8 text-center">
          <div class="w-16 h-16 rounded-2xl bg-red-50 text-red-500 flex items-center justify-center mx-auto mb-6 border border-red-100">
            <i class="fa-solid fa-trash-can text-2xl"></i>
          </div>
          <h3 class="font-bold text-xl text-brand-900 mb-2">Delete Service?</h3>
          <p class="text-[13px] text-brand-400 leading-relaxed mb-8">
            You are about to delete <strong id="deleteSvcName" class="text-brand-900"></strong>. This action is permanent and cannot be undone.
          </p>
          <div class="flex flex-col gap-2">
            <button id="confirmDeleteBtn"
              class="w-full py-3.5 bg-red-500 text-white text-[13px] font-bold rounded-2xl shadow-lg shadow-red-500/20 hover:shadow-red-500/40 hover:-translate-y-0.5 active:translate-y-0 transition-all">
              Yes, Delete Service
            </button>
            <button 
              class="w-full py-3.5 text-[13px] font-bold text-brand-500 hover:text-brand-700 transition-colors" id="deleteCloseBtn">
              Cancel, Keep it
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script type="module" src="~/js/AdminSide/adminServices.js"></script>