@page "/staff/login"
@model StaffLoginModel
@{
  Layout = null;
  ViewData["Title"] = "Staff Portal Login";
}

<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Staff Login — Samson Dental Center</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet" />
  <style>
    :root {
      --brand: #0F172A;
      --primary: #1E40AF;
      --accent: #c0392b;
    }
    body { font-family: 'DM Sans', sans-serif; }
    .brand-font { font-family: 'Syne', sans-serif; }
    .auth-input {
      width: 100%;
      padding: 0.75rem 0.875rem 0.75rem 2.75rem;
      font-size: 0.875rem;
      border: 1.5px solid #e5e7eb;
      border-radius: 0.75rem;
      outline: none;
      background: #fafafa;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .auth-input:focus {
      border-color: rgba(30,64,175,0.5);
      box-shadow: 0 0 0 3px rgba(30,64,175,0.08);
    }
    .auth-input.has-error { border-color: #c0392b; }
    .field-error {
      font-size: 0.72rem;
      color: #c0392b;
      margin-top: 0.35rem;
      display: none;
    }
    .field-error.show { display: block; }
    .bg-grid {
      background-image: radial-gradient(circle, rgba(255,255,255,.04) 1px, transparent 1px);
      background-size: 24px 24px;
    }
    .fade-up {
      opacity: 0;
      transform: translateY(18px);
      animation: fadeUpIn 0.5s ease forwards;
    }
    @@keyframes fadeUpIn {
      to { opacity: 1; transform: translateY(0); }
    }
    .pulse-dot {
      animation: pulse-glow 2s ease-in-out infinite;
    }
    @@keyframes pulse-glow {
      0%, 100% { box-shadow: 0 0 0 0 rgba(30,64,175,0.4); }
      50% { box-shadow: 0 0 0 8px rgba(30,64,175,0); }
    }
  </style>
</head>

<body class="min-h-screen bg-slate-50 flex">
  <!-- ── Left panel (branding) ── -->
  <div class="hidden lg:flex lg:w-[44%] bg-[#0F172A] flex-col justify-between p-12 relative overflow-hidden shrink-0">
    <div class="absolute inset-0 bg-grid"></div>
    <div class="absolute -bottom-40 -left-40 w-96 h-96 rounded-full bg-[#1E40AF]/15 blur-3xl pointer-events-none"></div>
    <div class="absolute top-20 -right-24 w-64 h-64 rounded-full bg-[#1E40AF]/08 blur-2xl pointer-events-none"></div>

    <!-- Logo -->
    <a href="/"
      class="brand-font flex items-center gap-2.5 font-extrabold text-[1rem] tracking-[0.07em] uppercase text-white no-underline relative z-10">
      <div class="w-9 h-9 rounded-full border-2 border-[#1E40AF] flex items-center justify-center shrink-0">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#1E40AF" stroke-width="2.5">
          <path d="M22 12h-4l-3 9L9 3l-3 9H2" />
        </svg>
      </div>
      Samson Dental <span class="text-[#1E40AF] ml-1">Center</span>
    </a>

    <!-- Center content -->
    <div class="relative z-10">
      <div class="flex items-center gap-2 text-[0.65rem] font-semibold tracking-[0.15em] uppercase text-white/35 mb-5">
        <span class="w-2 h-2 rounded-full bg-[#1E40AF] inline-block pulse-dot"></span>Staff Portal
      </div>
      <h2 class="brand-font font-extrabold text-white leading-[1.08] mb-5" style="font-size: clamp(2rem, 3.2vw, 2.8rem)">
        Clinic<br />Management.
      </h2>
      <p class="text-[0.9rem] text-white/50 leading-relaxed max-w-xs mb-10">
        Secure access for authorized clinic staff, doctors, and administrators.
      </p>
      <div class="space-y-3.5">
        <div class="flex items-center gap-3 text-[0.84rem] text-white/65">
          <span class="w-7 h-7 rounded-full bg-[#1E40AF]/20 flex items-center justify-center shrink-0">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#1E40AF" stroke-width="3">
              <polyline points="20 6 9 17 4 12" />
            </svg>
          </span>
          Manage appointments & schedules
        </div>
        <div class="flex items-center gap-3 text-[0.84rem] text-white/65">
          <span class="w-7 h-7 rounded-full bg-[#1E40AF]/20 flex items-center justify-center shrink-0">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#1E40AF" stroke-width="3">
              <polyline points="20 6 9 17 4 12" />
            </svg>
          </span>
          Access patient records & reports
        </div>
        <div class="flex items-center gap-3 text-[0.84rem] text-white/65">
          <span class="w-7 h-7 rounded-full bg-[#1E40AF]/20 flex items-center justify-center shrink-0">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#1E40AF" stroke-width="3">
              <polyline points="20 6 9 17 4 12" />
            </svg>
          </span>
          Process billing & transactions
        </div>
        <div class="flex items-center gap-3 text-[0.84rem] text-white/65">
          <span class="w-7 h-7 rounded-full bg-[#1E40AF]/20 flex items-center justify-center shrink-0">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#1E40AF" stroke-width="3">
              <polyline points="20 6 9 17 4 12" />
            </svg>
          </span>
          Role-based access control
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="relative z-10 flex items-center gap-3">
      <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10">
        <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
        <span class="text-[0.7rem] text-white/50">System Online</span>
      </div>
      <span class="text-[0.65rem] text-white/30">v2.0 · Secured</span>
    </div>
  </div>

  <!-- ── Right panel (form) ── -->
  <div class="flex-1 flex items-center justify-center px-6 py-12 lg:py-0 overflow-y-auto">
    <div class="w-full max-w-[420px] fade-up">
      <!-- Mobile logo -->
      <div class="flex lg:hidden justify-center mb-8">
        <a href="/"
          class="brand-font flex items-center gap-2 font-extrabold text-[1rem] tracking-[0.07em] uppercase text-[#0F172A] no-underline">
          <div class="w-9 h-9 rounded-full border-2 border-[#1E40AF] flex items-center justify-center shrink-0">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#1E40AF" stroke-width="2.5">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2" />
            </svg>
          </div>
          Staff Portal
        </a>
      </div>

      <div class="mb-8">
        <h2 class="brand-font font-extrabold text-[#0F172A] text-[1.9rem] leading-tight mb-1.5">
          Staff Sign In
        </h2>
        <p class="text-[0.9rem] text-slate-500">
          Access restricted to authorized staff only.
        </p>
      </div>

      <form id="staffLoginForm" method="post" class="space-y-4">
        @Html.AntiForgeryToken()
        <!-- Email -->
        <div>
          <label class="block text-[0.71rem] font-semibold tracking-[0.08em] uppercase text-slate-500 mb-2">Email Address</label>
          <div class="relative">
            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                <polyline points="22,6 12,13 2,6" />
              </svg>
            </span>
            <input asp-for="Input.Email" id="staff_email" type="email" class="auth-input" placeholder="staff@samsondental.com" />
          </div>
          <div id="err_staff_email" class="field-error">Please enter a valid email address.</div>
        </div>

        <!-- Password -->
        <div>
          <label class="block text-[0.71rem] font-semibold tracking-[0.08em] uppercase text-slate-500 mb-2">Password</label>
          <div class="relative">
            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
              </svg>
            </span>
            <input asp-for="Input.Password" id="staff_pw" type="password" class="auth-input pr-11" placeholder="Enter your password" />
            <button type="button" id="togglePwBtn"
              class="absolute right-3.5 top-1/2 -translate-y-1/2 text-slate-400 hover:text-[#1E40AF] transition-colors">
              <svg id="eyeShow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
              <svg id="eyeHide" class="hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94" />
                <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19" />
                <line x1="1" y1="1" x2="23" y2="23" />
              </svg>
            </button>
          </div>
          <div id="err_staff_pw" class="field-error">Password is required.</div>
        </div>

        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2.5">
            <input type="checkbox" id="rememberMe" name="rememberMe"
              class="accent-[#1E40AF] w-4 h-4 cursor-pointer rounded" />
            <label for="rememberMe" class="text-[0.83rem] text-slate-500 cursor-pointer select-none">Keep me signed in</label>
          </div>
        </div>

        <!-- Sign in btn -->
        <button type="button" id="staff-signin-btn"
          class="brand-font font-bold text-[0.85rem] tracking-wider uppercase w-full bg-[#0F172A] text-white py-3.5 rounded-xl hover:bg-[#1E40AF] transition-colors duration-200 cursor-pointer">
          Sign In →
        </button>
      </form>

      <div class="mt-6 pt-5 border-t border-slate-200">
        <p class="text-[0.78rem] text-slate-400 text-center">
          Patient? <a href="/sign-in" class="text-[#1E40AF] font-medium hover:underline">Sign in here →</a>
        </p>
      </div>
    </div>
  </div>

  <!-- Toast Container -->
  <div id="toast-container" class="fixed top-5 right-5 space-y-1 z-[11000]"></div>

  <script>
    // ── Toast utility (inline for standalone page) ──
    const Toast = {
      show(msg, type = "info", duration = 4000) {
        const container = document.getElementById("toast-container");
        const colors = {
          success: "bg-emerald-500", danger: "bg-red-500",
          warning: "bg-amber-500", info: "bg-blue-500"
        };
        const toast = document.createElement("div");
        toast.className = `${colors[type] || colors.info} text-white text-[13px] font-medium px-5 py-3 rounded-xl shadow-lg transition-all duration-300 translate-x-0 opacity-100`;
        toast.textContent = msg;
        container.appendChild(toast);
        setTimeout(() => {
          toast.style.opacity = "0";
          toast.style.transform = "translateX(20px)";
          setTimeout(() => toast.remove(), 300);
        }, duration);
      }
    };

    // ── Password toggle ──
    document.getElementById("togglePwBtn")?.addEventListener("click", () => {
      const inp = document.getElementById("staff_pw");
      const isPassword = inp.type === "password";
      inp.type = isPassword ? "text" : "password";
      document.getElementById("eyeShow").classList.toggle("hidden", isPassword);
      document.getElementById("eyeHide").classList.toggle("hidden", !isPassword);
    });

    // ── Error helpers ──
    function showErr(id, msg) {
      const errEl = document.getElementById(`err_${id}`);
      const inputEl = document.getElementById(id);
      if (errEl) { if (msg) errEl.textContent = msg; errEl.classList.add("show"); }
      if (inputEl) inputEl.classList.add("has-error");
    }
    function clearErr(id) {
      document.getElementById(`err_${id}`)?.classList.remove("show");
      document.getElementById(id)?.classList.remove("has-error");
    }

    // Auto-clear errors on input
    document.querySelectorAll(".auth-input").forEach(el =>
      el.addEventListener("input", () => clearErr(el.id))
    );

    // ── Enter key support ──
    document.getElementById("staffLoginForm")?.addEventListener("keypress", (e) => {
      if (e.key === "Enter") {
        e.preventDefault();
        document.getElementById("staff-signin-btn")?.click();
      }
    });

    // ── Sign in handler ──
    document.getElementById("staff-signin-btn")?.addEventListener("click", async () => {
      clearErr("staff_email");
      clearErr("staff_pw");

      const email = document.getElementById("staff_email")?.value.trim() || "";
      const password = document.getElementById("staff_pw")?.value.trim() || "";

      if (!email || !password) {
        if (!email) showErr("staff_email", "Email is required.");
        if (!password) showErr("staff_pw", "Password is required.");
        return;
      }

      const btn = document.getElementById("staff-signin-btn");
      const originalText = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<span class="animate-pulse">Signing in...</span>';

      const form = document.getElementById("staffLoginForm");
      const formData = new FormData(form);

      const rememberMeEl = document.getElementById("rememberMe");
      formData.set("rememberMe", rememberMeEl?.checked ? "true" : "false");

      try {
        const response = await fetch("/staff/login", {
          method: "POST",
          body: formData,
          credentials: "include",
          headers: {
            RequestVerificationToken: document.querySelector('input[name="__RequestVerificationToken"]').value
          }
        });

        const result = await response.json();

        if (result.ok) {
          // Store user data for admin sidebar
          localStorage.setItem("sb_user", JSON.stringify(result.user));
          Toast.show("Welcome back!", "success");
          setTimeout(() => {
            window.location.href = "/Admin/Dashboard";
          }, 1500);
        } else {
          const errorMsg = result.errors?.[0] || "Login failed.";
          if (errorMsg.includes("email")) showErr("staff_email", "");
          else if (errorMsg.includes("password") || errorMsg.includes("Incorrect")) showErr("staff_pw", "");
          Toast.show(errorMsg, "danger");
          btn.disabled = false;
          btn.innerHTML = originalText;
        }
      } catch (err) {
        Toast.show(err.message || "An error occurred.", "danger");
        btn.disabled = false;
        btn.innerHTML = originalText;
      }
    });
  </script>
</body>
</html>