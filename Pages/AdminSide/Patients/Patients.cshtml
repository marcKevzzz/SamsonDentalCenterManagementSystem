@page "/Admin/Patients"
@model AdminPatientsModel
@{
Layout = "AdminSide/_StaffLayout";
}


<!-- ── PATIENTS ── -->
<div id="page-patients" class="page p-4 md:p-6">
  <div class="flex flex-wrap items-center justify-between gap-3 mb-5">
    <div>
      <h2 class="font-display text-xl font-extrabold text-brand-900">
        Patients
      </h2>
      <p class="text-[12px] text-brand-500 mt-0.5">
        Manage all registered patients
      </p>
    </div>
    <button
      class="flex items-center gap-1.5 px-4 py-2 rounded-xl text-[12.5px] font-semibold text-white bg-primary shadow-md shadow-primary/25 hover:shadow-primary/40 transition-shadow">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
        stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19" />
        <line x1="5" y1="12" x2="19" y2="12" />
      </svg>Add Patient
    </button>
  </div>
  <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
    <div class="flex flex-wrap items-center gap-2 px-4 py-3 border-b border-slate-100">
      <div class="relative flex-1 min-w-[140px] max-w-[260px]">
        <svg class="absolute left-2.5 top-1/2 translate-half text-slate-400" width="12" height="12" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg><input placeholder="Search patients…"
          class="w-full pl-7 pr-3 py-1.5 text-[12px] bg-slate-50 border border-slate-200 rounded-lg outline-none focus:border-primary/40" />
      </div>
      <select
        class="px-9 py-1.5 text-[12px] bg-slate-50 border border-slate-200 rounded-lg text-brand-500 outline-none w-fit">
        <option>All Status</option>
        <option>Active</option>
        <option>Inactive</option>
      </select>
    </div>
    <div class="overflow-x-auto">
      <table class="dtable w-full min-w-[500px]">
        <thead class="bg-slate-50">
          <tr>
            <th
              class="text-left text-[10px] font-bold uppercase tracking-wider text-brand-400 px-4 py-2.5 font-display">
              Patient
            </th>
            <th
              class="text-left text-[10px] font-bold uppercase tracking-wider text-brand-400 px-4 py-2.5 font-display">
              Age / Gender
            </th>
            <th
              class="text-left text-[10px] font-bold uppercase tracking-wider text-brand-400 px-4 py-2.5 font-display">
              Last Visit
            </th>
            <th
              class="text-left text-[10px] font-bold uppercase tracking-wider text-brand-400 px-4 py-2.5 font-display">
              Doctor
            </th>
            <th
              class="text-left text-[10px] font-bold uppercase tracking-wider text-brand-400 px-4 py-2.5 font-display">
              Status
            </th>
            <th
              class="text-left text-[10px] font-bold uppercase tracking-wider text-brand-400 px-4 py-2.5 font-display">
              Action
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-50">
          <tr>
            <td class="px-4 py-3">
              <div class="flex items-center gap-2">
                <div
