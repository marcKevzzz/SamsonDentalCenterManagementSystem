<div id="userModal" class="fixed inset-0 z-[999] hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg max-h-[90vh] overflow-hidden ">
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
            <h3 id="modalTitle" class="font-display font-bold text-[15px] text-brand-900">Add User</h3>
            <button onclick="closeModal()" class="text-slate-400 hover:text-slate-700 transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18" />
                    <line x1="6" y1="6" x2="18" y2="18" />
                </svg>
            </button>
        </div>
        <div class="px-6 py-5 space-y-4 !max-h-[70vh] overflow-y-auto">
            <input type="hidden" id="modalUserId" />
            <div class="grid grid-cols-2 gap-4">
                <div class="flex flex-col gap-1.5">
                    <label class="text-[11px] font-semibold text-slate-600 tracking-wide">First Name</label>
                    <input id="mFirstName" type="text" placeholder="Juan"
                        class="modal-input px-3 py-2 border border-slate-200 rounded-lg text-[13px] outline-none focus:border-primary/50 focus:ring-2 focus:ring-primary/10" />
                </div>
                <div class="flex flex-col gap-1.5">
                    <label class="text-[11px] font-semibold text-slate-600 tracking-wide">Last Name</label>
                    <input id="mLastName" type="text" placeholder="Dela Cruz"
                        class="modal-input px-3 py-2 border border-slate-200 rounded-lg text-[13px] outline-none focus:border-primary/50 focus:ring-2 focus:ring-primary/10" />
                </div>
            </div>
            <div class="flex flex-col gap-1.5">
                <label class="text-[11px] font-semibold text-slate-600 tracking-wide">Email</label>
                <input id="mEmail" type="email" placeholder="user@email.com"
                    class="modal-input px-3 py-2 border border-slate-200 rounded-lg text-[13px] outline-none focus:border-primary/50 focus:ring-2 focus:ring-primary/10" />
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div class="flex flex-col gap-1.5">
                    <label class="text-[11px] font-semibold text-slate-600 tracking-wide">Date of Birth</label>
                    <input id="mDob" type="date"
                        class="modal-input px-3 py-2 border border-slate-200 rounded-lg text-[13px] outline-none focus:border-primary/50 focus:ring-2 focus:ring-primary/10" />
                </div>
                <div class="flex flex-col gap-1.5">
                    <label class="text-[11px] font-semibold text-slate-600 tracking-wide">Sex</label>
                    <select id="mSex"
                        class="modal-input px-3 py-2 border border-slate-200 rounded-lg text-[13px] outline-none focus:border-primary/50 focus:ring-2 focus:ring-primary/10">
                        <option value="">Select</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="prefer_not">Prefer not to say</option>
                    </select>
                </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div class="flex flex-col gap-1.5">
                    <label class="text-[11px] font-semibold text-slate-600 tracking-wide">Phone Number</label>
                    <input id="mPhone" type="tel" placeholder="09XX XXX XXXX"
                        class="modal-input px-3 py-2 border border-slate-200 rounded-lg text-[13px] outline-none focus:border-primary/50 focus:ring-2 focus:ring-primary/10" />
                </div>
                <div class="flex flex-col gap-1.5">
                    <label class="text-[11px] font-semibold text-slate-600 tracking-wide">Role</label>
                    <select id="mRole"
                        class="modal-input px-3 py-2 border border-slate-200 rounded-lg text-[13px] outline-none focus:border-primary/50 focus:ring-2 focus:ring-primary/10">
                        <option value="patient">Patient</option>
                        <option value="admin">Admin</option>
                        <option value="doctor">Doctor</option>
                        <option value="receptionist">Receptionist</option>
                    </select>
                </div>
            </div>
            <div class="flex flex-col gap-1.5">
                <label class="text-[11px] font-semibold text-slate-600 tracking-wide">Address</label>
                <input id="mAddress" type="text" placeholder="Complete address"
                    class="modal-input px-3 py-2 border border-slate-200 rounded-lg text-[13px] outline-none focus:border-primary/50 focus:ring-2 focus:ring-primary/10" />
            </div>
            <p id="modalError" class="hidden text-[12px] text-red-500 font-medium"></p>
        </div>
        <div class="flex justify-end gap-2 px-6 py-4 border-t border-slate-100">
            <button onclick="closeModal()"
                class="px-4 py-2 text-[12.5px] font-semibold text-slate-500 border border-slate-200 rounded-xl hover:bg-slate-50 transition-colors">
                Cancel
            </button>
            <button id="modalSaveBtn" onclick="saveUser()"
                class="px-5 py-2 text-[12.5px] font-semibold text-white bg-primary rounded-xl hover:bg-primary/90 transition-colors">
                Save
            </button>
        </div>
    </div>
</div>