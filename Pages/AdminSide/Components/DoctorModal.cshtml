<div id="doctorModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg overflow-y-auto max-h-[90vh]">
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
            <div>
                <h3 id="doctorModalTitle" class="font-display font-bold text-[15px] text-brand-900">Add Doctor</h3>
                <p class="text-[11px] text-brand-500 mt-0.5">Select a user profile to add as a doctor.</p>
            </div>
            <button onclick="closeDoctorModal()" class="text-slate-400 hover:text-slate-700 transition-colors">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        </div>

        <div class="px-6 py-5 space-y-4">
            <input type="hidden" id="doctorId" />
            
            <div class="flex flex-col gap-1.5" id="userSelectGroup">
                <label class="text-[11px] font-semibold text-slate-600 tracking-wide">Select User (Must be a Doctor role) <span class="text-red-400">*</span></label>
                <select id="doctorProfileId" class="modal-input px-3 py-2 border border-slate-200 rounded-lg text-[13px] outline-none focus:border-primary/50 focus:ring-2 focus:ring-primary/10">
                    <option value="">Select an available user...</option>
                </select>
                <p class="text-[10px] text-brand-400 mt-0.5">Note: Once a profile is selected, it cannot be changed.</p>
            </div>

            <div class="flex flex-col gap-1.5">
                <label class="text-[11px] font-semibold text-slate-600 tracking-wide">Title <span class="text-red-400">*</span></label>
                <input id="doctorTitle" type="text" placeholder="e.g. Dr." value="Dr."
                       class="modal-input px-3 py-2 border border-slate-200 rounded-lg text-[13px] outline-none focus:border-primary/50 focus:ring-2 focus:ring-primary/10" />
            </div>

            <div class="flex flex-col gap-1.5">
                <label class="text-[11px] font-semibold text-slate-600 tracking-wide">Specialties (comma-separated)</label>
                <input id="doctorSpecialties" type="text" placeholder="e.g. General Dentistry, Orthodontics"
                       class="modal-input px-3 py-2 border border-slate-200 rounded-lg text-[13px] outline-none focus:border-primary/50 focus:ring-2 focus:ring-primary/10" />
            </div>

            <div class="flex flex-col gap-1.5">
                <label class="text-[11px] font-semibold text-slate-600 tracking-wide">Bio</label>
                <textarea id="doctorBio" rows="3" placeholder="Short biography about the doctor..."
                       class="modal-input px-3 py-2 border border-slate-200 rounded-lg text-[13px] outline-none focus:border-primary/50 focus:ring-2 focus:ring-primary/10 resize-none"></textarea>
            </div>
            
            <div class="flex items-center gap-2 mt-2">
                <input type="checkbox" id="doctorIsActive" class="w-4 h-4 rounded text-primary border-slate-300 focus:ring-primary" checked />
                <label for="doctorIsActive" class="text-[12px] font-medium text-slate-700">Active Status (Check if available)</label>
            </div>

            <p id="doctorModalError" class="hidden text-[12px] text-red-500 font-medium mt-2"></p>
        </div>

        <div class="flex justify-end gap-2 px-6 py-4 border-t border-slate-100">
            <button onclick="closeDoctorModal()" class="px-4 py-2 text-[12.5px] font-semibold text-slate-500 border border-slate-200 rounded-xl hover:bg-slate-50 transition-colors">
                Cancel
            </button>
            <button onclick="saveDoctor()" class="px-5 py-2 text-[12.5px] font-semibold text-white bg-primary rounded-xl hover:bg-primary/90 transition-colors flex items-center gap-2">
                Save Doctor
            </button>
        </div>
    </div>
</div>
