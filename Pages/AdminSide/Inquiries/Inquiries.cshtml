@page "/Admin/Inquiries"
@model AdminInquiriesModel
@{
Layout = "AdminSide/_AdminLayout";
}

<div id="page-inquiries" class="page p-4 md:p-6">
  <div class="mb-5">
    <h2 class="font-display text-xl font-extrabold text-brand">Inquiries</h2>
    <p class="text-[12px] text-brand-500 mt-0.5">
      Patient messages and support requests
    </p>
  </div>
  <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="dtable w-full min-w-[440px]">
        <thead class="bg-slate-50">
          <tr>
            <th
              class="text-left text-[10px] font-bold uppercase tracking-wider text-brand px-4 py-2.5 font-display"
            >
              From
            </th>
            <th
              class="text-left text-[10px] font-bold uppercase tracking-wider text-brand px-4 py-2.5 font-display"
            >
              Subject
            </th>
            <th
              class="text-left text-[10px] font-bold uppercase tracking-wider text-brand px-4 py-2.5 font-display"
            >
              Date
            </th>
            <th
              class="text-left text-[10px] font-bold uppercase tracking-wider text-brand px-4 py-2.5 font-display"
            >
              Status
            </th>
            <th
              class="text-left text-[10px] font-bold uppercase tracking-wider text-brand px-4 py-2.5 font-display"
            >
              Action
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-50">
          <tr>
            <td class="px-4 py-3">
              <div class="text-[13px] font-medium">Maria Lim</div>
              <div class="text-[10px] text-brand">maria.lim@email.com</div>
            </td>
            <td class="px-4 py-3 text-[12.5px]">Schedule change request</td>
            <td class="px-4 py-3 text-[11px] text-brand whitespace-nowrap">
              Mar 23, 9:02 AM
            </td>
            <td class="px-4 py-3">
              <span
                class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-amber-100 text-amber-700 font-display"
                >Open</span
              >
            </td>
            <td class="px-4 py-3">
              <button
                class="text-[11px] font-semibold text-primary hover:underline"
              >
                Reply
              </button>
            </td>
          </tr>
          <tr>
            <td class="px-4 py-3">
              <div class="text-[13px] font-medium">Juan Reyes</div>
              <div class="text-[10px] text-brand">juan.r@email.com</div>
            </td>
            <td class="px-4 py-3 text-[12.5px]">Lab results inquiry</td>
            <td class="px-4 py-3 text-[11px] text-brand whitespace-nowrap">
              Mar 22, 3:45 PM
            </td>
            <td class="px-4 py-3">
              <span
                class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700 font-display"
                >Resolved</span
              >
            </td>
            <td class="px-4 py-3">
              <button
                class="text-[11px] font-semibold text-primary hover:underline"
              >
                View
              </button>
            </td>
          </tr>
          <tr>
            <td class="px-4 py-3">
              <div class="text-[13px] font-medium">Ana Cruz</div>
              <div class="text-[10px] text-brand">ana.c@email.com</div>
            </td>
            <td class="px-4 py-3 text-[12.5px]">Billing concern</td>
            <td class="px-4 py-3 text-[11px] text-brand whitespace-nowrap">
              Mar 22, 11:20 AM
            </td>
            <td class="px-4 py-3">
              <span
                class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-amber-100 text-amber-700 font-display"
                >Open</span
              >
            </td>
            <td class="px-4 py-3">
              <button
                class="text-[11px] font-semibold text-primary hover:underline"
              >
                Reply
              </button>
            </td>
          </tr>
          <tr>
            <td class="px-4 py-3">
              <div class="text-[13px] font-medium">Ben Marcos</div>
              <div class="text-[10px] text-brand">bmarcos@email.com</div>
            </td>
            <td class="px-4 py-3 text-[12.5px]">Prescription refill</td>
            <td class="px-4 py-3 text-[11px] text-brand whitespace-nowrap">
              Mar 21, 8:00 AM
            </td>
            <td class="px-4 py-3">
              <span
                class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-amber-100 text-amber-700 font-display"
                >Open</span
              >
            </td>
            <td class="px-4 py-3">
              <button
                class="text-[11px] font-semibold text-primary hover:underline"
              >
                Reply
              </button>
            </td>
          </tr>
          <tr>
            <td class="px-4 py-3">
              <div class="text-[13px] font-medium">Lina Castillo</div>
              <div class="text-[10px] text-brand">lcastillo@email.com</div>
            </td>
            <td class="px-4 py-3 text-[12.5px]">Feedback on service</td>
            <td class="px-4 py-3 text-[11px] text-brand whitespace-nowrap">
              Mar 20, 4:15 PM
            </td>
            <td class="px-4 py-3">
              <span
                class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700 font-display"
                >Resolved</span
              >
            </td>
            <td class="px-4 py-3">
              <button
                class="text-[11px] font-semibold text-primary hover:underline"
              >
                View
              </button>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
