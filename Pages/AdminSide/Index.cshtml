                    →</button>
            </div>
            <div class="overflow-x-auto">
                <table class="dtable w-full min-w-[440px]">
                    <thead class="bg-slate-50">
                        <tr>
                            <th
                                class="text-left text-[10px] font-bold uppercase tracking-wider text-brand px-4 py-2.5 font-display">
                                Patient</th>
                            <th
                                class="text-left text-[10px] font-bold uppercase tracking-wider text-brand px-4 py-2.5 font-display">
                                Doctor</th>
                            <th
                                class="text-left text-[10px] font-bold uppercase tracking-wider text-brand px-4 py-2.5 font-display">
                                Service</th>
                            <th
                                class="text-left text-[10px] font-bold uppercase tracking-wider text-brand px-4 py-2.5 font-display">
                                Time</th>
                            <th
                                class="text-left text-[10px] font-bold uppercase tracking-wider text-brand px-4 py-2.5 font-display">
                                Status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        <tr>
                            <td class="px-4 py-3 text-[13px]">
                                <div class="flex items-center gap-2">
                                    <div
                                        class="w-7 h-7 rounded-full bg-blue-50 flex items-center justify-center text-primary text-[9.5px] font-bold font-display flex-shrink-0">
                                        ML</div>Maria L.
                                </div>
                            </td>
                            <td class="px-4 py-3 text-[12.5px] text-brand-500">Dr. Santos</td>
                            <td class="px-4 py-3 text-[12.5px]">General Checkup</td>
                            <td class="px-4 py-3 text-[12px] text-brand-500 whitespace-nowrap">9:00 AM</td>
                            <td class="px-4 py-3"><span
                                    class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700 font-display">Confirmed</span>
                            </td>
                        </tr>
                        <tr>
                            <td class="px-4 py-3 text-[13px]">
                                <div class="flex items-center gap-2">
                                    <div
                                        class="w-7 h-7 rounded-full bg-emerald-50 flex items-center justify-center text-emerald-700 text-[9.5px] font-bold font-display flex-shrink-0">
                                        JR</div>Juan R.
                                </div>
                            </td>
                            <td class="px-4 py-3 text-[12.5px] text-brand-500">Dr. Cruz</td>
                            <td class="px-4 py-3 text-[12.5px]">Cardiology</td>
                            <td class="px-4 py-3 text-[12px] text-brand-500 whitespace-nowrap">10:30 AM</td>
                            <td class="px-4 py-3"><span
                                    class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-amber-100 text-amber-700 font-display">Pending</span>
                            </td>
                        </tr>
                        <tr>
                            <td class="px-4 py-3 text-[13px]">
                                <div class="flex items-center gap-2">
                                    <div
                                        class="w-7 h-7 rounded-full bg-violet-50 flex items-center justify-center text-violet-700 text-[9.5px] font-bold font-display flex-shrink-0">
                                        AC</div>Ana C.
                                </div>
                            </td>
                            <td class="px-4 py-3 text-[12.5px] text-brand-500">Dr. Reyes</td>
                            <td class="px-4 py-3 text-[12.5px]">Pediatrics</td>
                            <td class="px-4 py-3 text-[12px] text-brand-500 whitespace-nowrap">11:00 AM</td>
                            <td class="px-4 py-3"><span
                                    class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700 font-display">Confirmed</span>
                            </td>
                        </tr>
                        <tr>
                            <td class="px-4 py-3 text-[13px]">
                                <div class="flex items-center gap-2">
                                    <div
                                        class="w-7 h-7 rounded-full bg-red-50 flex items-center justify-center text-red-600 text-[9.5px] font-bold font-display flex-shrink-0">
                                        BM</div>Ben M.
                                </div>
                            </td>
                            <td class="px-4 py-3 text-[12.5px] text-brand-500">Dr. Garcia</td>
                            <td class="px-4 py-3 text-[12.5px]">Orthopedics</td>
                            <td class="px-4 py-3 text-[12px] text-brand-500 whitespace-nowrap">2:00 PM</td>
                            <td class="px-4 py-3"><span
                                    class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-red-100 text-red-700 font-display">Cancelled</span>
                            </td>
                        </tr>
                        <tr>
                            <td class="px-4 py-3 text-[13px]">
                                <div class="flex items-center gap-2">
                                    <div
                                        class="w-7 h-7 rounded-full bg-amber-50 flex items-center justify-center text-amber-700 text-[9.5px] font-bold font-display flex-shrink-0">
                                        LC</div>Lina C.
                                </div>
                            </td>
                            <td class="px-4 py-3 text-[12.5px] text-brand-500">Dr. Santos</td>
                            <td class="px-4 py-3 text-[12.5px]">Dermatology</td>
                            <td class="px-4 py-3 text-[12px] text-brand-500 whitespace-nowrap">3:30 PM</td>
                            <td class="px-4 py-3"><span
                                    class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-amber-100 text-amber-700 font-display">Pending</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Activity -->
        <div class="bg-white rounded-2xl p-5 border border-slate-200">
            <h3 class="font-display text-[13.5px] font-bold text-brand mb-4">Recent Activity</h3>
            <div class="space-y-3">
                <div class="flex gap-2.5">
                    <div class="w-2 h-2 rounded-full bg-primary flex-shrink-0 mt-1.5"></div>
                    <div>
                        <p class="text-[12.5px] font-medium text-brand">New patient registered</p>
                        <p class="text-[10.5px] text-brand">Maria L. · 8 mins ago</p>
                    </div>
                </div>
                <div class="flex gap-2.5">
                    <div class="w-2 h-2 rounded-full bg-emerald-500 flex-shrink-0 mt-1.5"></div>
                    <div>
                        <p class="text-[12.5px] font-medium text-brand">Appointment confirmed</p>
                        <p class="text-[10.5px] text-brand">Dr. Cruz — 10:30AM · 15 mins ago</p>
                    </div>
                </div>
                <div class="flex gap-2.5">
                    <div class="w-2 h-2 rounded-full bg-orange-600 flex-shrink-0 mt-1.5"></div>
                    <div>
                        <p class="text-[12.5px] font-medium text-brand">Emergency admission</p>
                        <p class="text-[10.5px] text-brand">Room 204 · 32 mins ago</p>
                    </div>
                </div>
                <div class="flex gap-2.5">
                    <div class="w-2 h-2 rounded-full bg-violet-600 flex-shrink-0 mt-1.5"></div>
                    <div>
                        <p class="text-[12.5px] font-medium text-brand">Lab results uploaded</p>
                        <p class="text-[10.5px] text-brand">Patient #1031 · 1 hr ago</p>
                    </div>
                </div>
                <div class="flex gap-2.5">
                    <div class="w-2 h-2 rounded-full bg-amber-500 flex-shrink-0 mt-1.5"></div>
                    <div>
