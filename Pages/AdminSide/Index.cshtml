<!-- ── APPOINTMENTS ── -->
<div id="page-appointments" class="page p-4 md:p-6">
  <div class="flex flex-wrap items-center justify-between gap-3 mb-5">
    <div>
      <h2 class="font-display text-xl font-extrabold text-brand">
        Appointments
      </h2>
      <p class="text-[12px] text-brand-500 mt-0.5">
        Schedule and manage appointments
      </p>
    </div>
    <button
      class="flex items-center gap-1.5 px-4 py-2 rounded-xl text-[12.5px] font-semibold text-white bg-primary shadow-md shadow-primary/25"
    >
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="12" y1="5" x2="12" y2="19" />
        <line x1="5" y1="12" x2="19" y2="12" /></svg
      >Book Appointment
    </button>
  </div>
  <div class="grid grid-cols-3 gap-3 mb-5">
    <div class="bg-white rounded-xl p-3 text-center border border-slate-200">
      <div class="font-display text-2xl font-extrabold text-primary">47</div>
      <div class="text-[10.5px] text-brand mt-0.5">Confirmed</div>
    </div>
    <div class="bg-white rounded-xl p-3 text-center border border-slate-200">
      <div class="font-display text-2xl font-extrabold text-amber-500">15</div>
      <div class="text-[10.5px] text-brand mt-0.5">Pending</div>
    </div>
    <div class="bg-white rounded-xl p-3 text-center border border-slate-200">
      <div class="font-display text-2xl font-extrabold text-orange-600">12</div>
      <div class="text-[10.5px] text-brand mt-0.5">Cancelled</div>
    </div>
  </div>
  <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="dtable w-full min-w-[580px]">
        <thead class="bg-slate-50">
          <tr>
            <th
              class="text-left text-[10px] font-bold uppercase tracking-wider text-brand px-4 py-2.5 font-display"
            >
              ID
            </th>
            <th
              class="text-left text-[10px] font-bold uppercase tracking-wider text-brand px-4 py-2.5 font-display"
            >
              Patient
            </th>
            <th
              class="text-left text-[10px] font-bold uppercase tracking-wider text-brand px-4 py-2.5 font-display"
            >
              Doctor
            </th>
            <th
              class="text-left text-[10px] font-bold uppercase tracking-wider text-brand px-4 py-2.5 font-display"
            >
              Service
            </th>
            <th
              class="text-left text-[10px] font-bold uppercase tracking-wider text-brand px-4 py-2.5 font-display"
            >
              Date &amp; Time
            </th>
            <th
              class="text-left text-[10px] font-bold uppercase tracking-wider text-brand px-4 py-2.5 font-display"
            >
              Status
            </th>
            <th
              class="text-left text-[10px] font-bold uppercase tracking-wider text-brand px-4 py-2.5 font-display"
            >
              Actions
            </th>
