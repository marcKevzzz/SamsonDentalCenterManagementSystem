@page "/Admin/Dashboard"
@model AdminDashboardModel
@{
Layout = "AdminSide/_AdminLayout";
}


<!-- ── DASHBOARD ── -->
<div id="page-dashboard" class="page active p-4 md:p-6">
    <div class="flex flex-wrap items-start justify-between gap-3 mb-5">
        <div>
            <h2 class="font-display text-[clamp(17px,3vw,22px)] font-extrabold text-brand">Good morning, Dr. Ana 👋
            </h2>
            <p class="text-[12px] text-brand-500 mt-0.5">Here's what's happening at your clinic today.</p>
        </div>
        <!-- <button
            class="flex items-center gap-1.5 px-4 py-2 rounded-xl text-[12.5px] font-semibold text-white bg-primary shadow-lg shadow-primary/30 hover:shadow-primary/50 transition-shadow whitespace-nowrap">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            New Appointment
        </button> -->
    </div>

    <!-- Stat cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-3 mb-5">
        <div
            class="stat-card stat-blue relative bg-white rounded-2xl p-4 border border-slate-200 hover:shadow-lg hover:-translate-y-0.5 transition-all">
            <div class="flex items-start justify-between mb-3">
                <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center"><svg width="18"
                        height="18" viewBox="0 0 24 24" fill="none" stroke="#1E40AF" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg></div>
                <span class="text-[10px] font-semibold px-2 py-0.5 rounded-lg bg-blue-50 text-primary">+12%</span>
            </div>
            <div class="font-display text-3xl font-extrabold text-brand">1,248</div>
            <div class="text-[12px] text-brand-500 mt-0.5">Total Patients</div>
            <div class="text-[11px] text-emerald-600 mt-1.5">↑ 24 new this week</div>
        </div>
        <div
            class="stat-card stat-teal relative bg-white rounded-2xl p-4 border border-slate-200 hover:shadow-lg hover:-translate-y-0.5 transition-all">
            <div class="flex items-start justify-between mb-3">
                <div class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center"><svg width="18"
                        height="18" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 7h-9" />
                        <path d="M14 17H5" />
                        <circle cx="17" cy="17" r="3" />
                        <circle cx="7" cy="7" r="3" />
                    </svg></div>
                <span
                    class="text-[10px] font-semibold px-2 py-0.5 rounded-lg bg-emerald-50 text-emerald-700">Active</span>
            </div>
            <div class="font-display text-3xl font-extrabold text-brand">38</div>
            <div class="text-[12px] text-brand-500 mt-0.5">Doctors on Staff</div>
            <div class="text-[11px] text-emerald-600 mt-1.5">↑ 5 specialists</div>
        </div>
        <div
            class="stat-card stat-red relative bg-white rounded-2xl p-4 border border-slate-200 hover:shadow-lg hover:-translate-y-0.5 transition-all">
            <div class="flex items-start justify-between mb-3">
                <div class="w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center"><svg width="18" height="18"
                        viewBox="0 0 24 24" fill="none" stroke="#c0392b" stroke-width="2" stroke-linecap="round"
                        stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                        <line x1="16" y1="2" x2="16" y2="6" />
                        <line x1="8" y1="2" x2="8" y2="6" />
                        <line x1="3" y1="10" x2="21" y2="10" />
                    </svg></div>
                <span class="text-[10px] font-semibold px-2 py-0.5 rounded-lg bg-red-50 text-red-700">Today</span>
            </div>
            <div class="font-display text-3xl font-extrabold text-brand">74</div>
            <div class="text-[12px] text-brand-500 mt-0.5">Appointments</div>
            <div class="text-[11px] text-red-500 mt-1.5">↓ 12 pending confirm</div>
        </div>
        <div
            class="stat-card stat-purple relative bg-white rounded-2xl p-4 border border-slate-200 hover:shadow-lg hover:-translate-y-0.5 transition-all">
            <div class="flex items-start justify-between mb-3">
                <div class="w-10 h-10 rounded-xl bg-violet-50 flex items-center justify-center"><svg width="18"
                        height="18" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="1" x2="12" y2="23" />
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                    </svg></div>
                <span class="text-[10px] font-semibold px-2 py-0.5 rounded-lg bg-violet-50 text-violet-700">+8%</span>
            </div>
            <div class="font-display text-3xl font-extrabold text-brand">₱2.4M</div>
            <div class="text-[12px] text-brand-500 mt-0.5">Monthly Revenue</div>
            <div class="text-[11px] text-emerald-600 mt-1.5">↑ ₱180K vs last month</div>
        </div>
    </div>

    <!-- Charts row -->
    <div class="grid grid-cols-1 xl:grid-cols-3 gap-4 mb-4">
        <!-- Bar chart (2/3) -->
        <div class="xl:col-span-2 bg-white rounded-2xl p-5 border border-slate-200">
            <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
                <div>
                    <h3 class="font-display text-[13.5px] font-bold text-brand">Patient Visits</h3>
                    <p class="text-[10.5px] text-brand-500 mt-0.5">Weekly overview — March 2026</p>
                </div>
                <div class="flex gap-1.5">
                    <button class="px-3 py-1 text-[10.5px] font-semibold rounded-lg bg-primary text-white">Week</button>
                    <button
                        class="px-3 py-1 text-[10.5px] font-semibold rounded-lg bg-slate-100 text-brand-500 hover:bg-slate-200 transition-colors">Month</button>
                </div>
            </div>
            <div class="h-36 flex items-end gap-2 px-1">
                <div class="cbar">
                    <div class="cbar-inner" style="height:60%;background:linear-gradient(180deg,#1E40AF,#3b82f6)"></div>
                    <span class="text-[9.5px] text-brand">Mon</span>
                </div>
                <div class="cbar">
                    <div class="cbar-inner" style="height:80%;background:linear-gradient(180deg,#1E40AF,#3b82f6)"></div>
                    <span class="text-[9.5px] text-brand">Tue</span>
                </div>
                <div class="cbar">
                    <div class="cbar-inner" style="height:55%;background:linear-gradient(180deg,#1E40AF,#3b82f6)"></div>
                    <span class="text-[9.5px] text-brand">Wed</span>
                </div>
                <div class="cbar">
                    <div class="cbar-inner"
                        style="height:95%;background:linear-gradient(180deg,#c0392b,#ef4444);box-shadow:0 0 10px rgba(192,57,43,.35)">
                    </div><span class="text-[9.5px] font-semibold text-orange-600">Thu</span>
                </div>
                <div class="cbar">
                    <div class="cbar-inner" style="height:70%;background:linear-gradient(180deg,#1E40AF,#3b82f6)"></div>
                    <span class="text-[9.5px] text-brand">Fri</span>
                </div>
                <div class="cbar">
                    <div class="cbar-inner" style="height:40%;background:linear-gradient(180deg,#94a3b8,#cbd5e1)"></div>
                    <span class="text-[9.5px] text-brand">Sat</span>
                </div>
                <div class="cbar">
                    <div class="cbar-inner" style="height:25%;background:linear-gradient(180deg,#94a3b8,#cbd5e1)"></div>
                    <span class="text-[9.5px] text-brand">Sun</span>
                </div>
            </div>
            <div class="flex flex-wrap gap-3 mt-3 pt-3 border-t border-slate-100">
                <div class="flex items-center gap-1.5 text-[10.5px] text-brand"><span
                        class="w-2 h-2 rounded-sm inline-block bg-primary"></span>Outpatient</div>
                <div class="flex items-center gap-1.5 text-[10.5px] text-brand"><span
                        class="w-2 h-2 rounded-sm inline-block bg-orange-600"></span>Emergency</div>
                <div class="flex items-center gap-1.5 text-[10.5px] text-brand"><span
                        class="w-2 h-2 rounded-sm inline-block bg-slate-300"></span>Weekend</div>
            </div>
        </div>

        <!-- Donut (1/3) -->
        <div class="bg-white rounded-2xl p-5 border border-slate-200">
            <h3 class="font-display text-[13.5px] font-bold text-brand">Department Load</h3>
            <p class="text-[10.5px] text-brand-500 mt-0.5 mb-3">Active cases by unit</p>
            <div class="flex justify-center mb-3">
                <svg width="120" height="120" viewBox="0 0 140 140">
                    <circle cx="70" cy="70" r="54" fill="none" stroke="#f1f5f9" stroke-width="18" />
                    <circle cx="70" cy="70" r="54" fill="none" stroke="#1E40AF" stroke-width="18"
                        stroke-dasharray="122 217" stroke-dashoffset="0" class="dr" />
                    <circle cx="70" cy="70" r="54" fill="none" stroke="#c0392b" stroke-width="18"
                        stroke-dasharray="81 258" stroke-dashoffset="-122" class="dr" />
                    <circle cx="70" cy="70" r="54" fill="none" stroke="#059669" stroke-width="18"
                        stroke-dasharray="68 271" stroke-dashoffset="-203" class="dr" />
                    <circle cx="70" cy="70" r="54" fill="none" stroke="#7c3aed" stroke-width="18"
                        stroke-dasharray="68 271" stroke-dashoffset="-271" class="dr" />
                    <text x="70" y="65" text-anchor="middle" fill="#0F172A" font-size="22" font-weight="800"
                        font-family="Syne,sans-serif">248</text>
                    <text x="70" y="81" text-anchor="middle" fill="#6b7280" font-size="10"
                        font-family="DM Sans,sans-serif">Total</text>
                </svg>
            </div>
            <div class="space-y-1.5">
                <div class="flex items-center justify-between text-[12px]">
                    <div class="flex items-center gap-2"><span
                            class="w-2 h-2 rounded-full bg-primary inline-block"></span><span
                            class="text-brand-500">General</span></div><span
                        class="font-semibold text-brand">36%</span>
                </div>
                <div class="flex items-center justify-between text-[12px]">
                    <div class="flex items-center gap-2"><span
                            class="w-2 h-2 rounded-full bg-orange-600 inline-block"></span><span
                            class="text-brand-500">Emergency</span></div><span
                        class="font-semibold text-brand">24%</span>
                </div>
                <div class="flex items-center justify-between text-[12px]">
                    <div class="flex items-center gap-2"><span
                            class="w-2 h-2 rounded-full bg-emerald-500 inline-block"></span><span
                            class="text-brand-500">Pediatrics</span></div><span
                        class="font-semibold text-brand">20%</span>
                </div>
                <div class="flex items-center justify-between text-[12px]">
                    <div class="flex items-center gap-2"><span
                            class="w-2 h-2 rounded-full bg-violet-600 inline-block"></span><span
                            class="text-brand-500">Cardiology</span></div><span
                        class="font-semibold text-brand">20%</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom row -->
    <div class="grid grid-cols-1 xl:grid-cols-3 gap-4">
        <!-- Appointments table -->
        <div class="xl:col-span-2 bg-white rounded-2xl border border-slate-200 overflow-hidden">
            <div class="flex items-center justify-between px-5 py-3.5 border-b border-slate-100">
