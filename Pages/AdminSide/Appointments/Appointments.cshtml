@page "/Admin/Appointments"
@namespace SamsonDentalCenterManagementSystem.Pages.Admin
@model AdminAppointmentsModel
@{
Layout = "AdminSide/_AdminLayout";
}
<!-- ── APPOINTMENTS ── -->
<div id="page-appointments" class="page p-4 md:p-6">

  <!-- Header -->
  <div class="flex flex-wrap items-center justify-between gap-3 mb-5">
    <div>
      <h2 class="font-display text-xl font-extrabold text-brand-900">Appointments</h2>
      <p class="text-[12px] text-brand-500 mt-0.5">Schedule and manage appointments</p>
    </div>
    <button onclick="openBookModal()"
      class="flex items-center gap-1.5 px-4 py-2 rounded-xl text-[12.5px] font-semibold text-white bg-primary shadow-md shadow-primary/25">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
        stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19" />
        <line x1="5" y1="12" x2="19" y2="12" />
      </svg>
      Book Appointment
    </button>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-5">
    <div class="bg-white rounded-xl p-3 text-center border border-slate-200">
      <div class="font-display text-2xl font-extrabold text-primary">@Model.CountConfirmed</div>
      <div class="text-[10.5px] text-brand-400 mt-0.5">Confirmed</div>
    </div>
    <div class="bg-white rounded-xl p-3 text-center border border-slate-200">
      <div class="font-display text-2xl font-extrabold text-amber-500">@Model.CountPending</div>
      <div class="text-[10.5px] text-brand-400 mt-0.5">Pending</div>
    </div>
    <div class="bg-white rounded-xl p-3 text-center border border-slate-200">
      <div class="font-display text-2xl font-extrabold text-accent">@Model.CountCancelled</div>
      <div class="text-[10.5px] text-brand-400 mt-0.5">Cancelled</div>
    </div>
    <div class="bg-white rounded-xl p-3 text-center border border-slate-200">
      <div class="font-display text-2xl font-extrabold text-slate-400">@Model.CountWaitlist</div>
      <div class="text-[10.5px] text-brand-400 mt-0.5">Waitlist</div>
    </div>
  </div>

  <!-- Filter bar -->
  <div class="flex flex-wrap gap-2 mb-4">
    <input id="search-input" type="text" placeholder="Search patient, doctor, service…"
      oninput="filterTable()"
      class="flex-1 min-w-[180px] text-[12px] px-3 py-2 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-primary/30" />
    <select id="status-filter" onchange="filterTable()"
      class="text-[12px] px-3 py-2 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-primary/30">
      <option value="">All Statuses</option>
      <option value="confirmed">Confirmed</option>
      <option value="pending">Pending</option>
      <option value="cancelled">Cancelled</option>
      <option value="waitlist">Waitlist</option>
    </select>
  </div>

  <!-- Table -->
  <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full min-w-[640px]" id="appointments-table">
        <thead class="bg-slate-50">
          <tr>
            <th class="text-left text-[10px] font-bold uppercase tracking-wider text-brand-400 px-4 py-2.5 font-display">ID</th>
            <th class="text-left text-[10px] font-bold uppercase tracking-wider text-brand-400 px-4 py-2.5 font-display">Patient</th>
            <th class="text-left text-[10px] font-bold uppercase tracking-wider text-brand-400 px-4 py-2.5 font-display">Doctor</th>
            <th class="text-left text-[10px] font-bold uppercase tracking-wider text-brand-400 px-4 py-2.5 font-display">Service</th>
            <th class="text-left text-[10px] font-bold uppercase tracking-wider text-brand-400 px-4 py-2.5 font-display">Date &amp; Time</th>
            <th class="text-left text-[10px] font-bold uppercase tracking-wider text-brand-400 px-4 py-2.5 font-display">Status</th>
            <th class="text-left text-[10px] font-bold uppercase tracking-wider text-brand-400 px-4 py-2.5 font-display">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-50" id="appointments-body">
          @if (!Model.Appointments.Any())
          {
            <tr>
              <td colspan="7" class="px-4 py-10 text-center text-[12px] text-brand-400">
                No appointments found.
              </td>
            </tr>
          }
          @foreach (var appt in Model.Appointments)
          {
            var shortId = "#APT-" + appt.Id[..4].ToUpper();
            var dateStr = appt.AppointmentDate.ToString("MMM dd") + " · " + appt.AppointmentTime;
            var (badgeClasses, statusLabel) = appt.EmailStatus.ToLower() switch
            {
              "confirmed" => ("bg-emerald-100 text-emerald-700", "Confirmed"),
              "pending"   => ("bg-orange-100 text-orange-700",  "Pending"),
              "arrived"   => ("bg-yellow-100 text-yellow-700",  "Arrived"),
              "completed" => ("bg-blue-100 text-blue-700",      "Completed"),
              "no-show"   => ("bg-slate-100 text-slate-600",    "No-Show"),
              "cancelled" => ("bg-red-100 text-red-700",        "Cancelled"),
              "waitlist"  => ("bg-slate-100 text-slate-600",    "Waitlist"),
              _           => ("bg-slate-100 text-slate-600",    appt.EmailStatus)
            };

            // Serialize appointment to JSON for JS
            var apptJson = System.Text.Json.JsonSerializer.Serialize(new {
              id              = appt.Id,
              patientName     = appt.PatientName,
              patientEmail    = appt.PatientEmail,
              patientPhone    = appt.PatientPhone,
              doctorId        = appt.DoctorId,
              doctorName      = appt.DoctorName,
              serviceName     = appt.ServiceName,
              serviceId       = appt.ServiceId,
              serviceCategory = Model.Services.FirstOrDefault(s => s.Id == appt.ServiceId)?.Category ?? "",
              appointmentDate = appt.AppointmentDate.ToString("yyyy-MM-dd"),
              appointmentTime = appt.AppointmentTime,
              status          = appt.Status,
              emailStatus          = appt.EmailStatus,
              notes           = appt.Notes
            });

            <tr data-status="@appt.EmailStatus" data-search="@(appt.PatientName + appt.DoctorName + appt.ServiceName)">
              <td class="px-4 py-3 text-[10.5px] text-brand-400">@shortId</td>
              <td class="px-4 py-3">
                <div class="text-[13px] font-medium">@appt.PatientName</div>
                <div class="text-[10.5px] text-brand-400">@appt.PatientEmail</div>
              </td>
              <td class="px-4 py-3 text-[12.5px] text-brand-500">@(appt.DoctorName ?? "—")</td>
              <td class="px-4 py-3 text-[12.5px]">@appt.ServiceName</td>
              <td class="px-4 py-3 text-[12px] text-brand-500 whitespace-nowrap">@dateStr</td>
              <td class="px-4 py-3">
                <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full @badgeClasses font-display">
                  @statusLabel
                </span>
              </td>
              <td class="px-4 py-3 text-right">
  <div class=" inline-block text-left action-dropdown ">
    <button onclick="toggleDropdown(event, this)" 
            class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-slate-100 text-brand-400 transition-colors">
      <i class="fa-solid fa-ellipsis-vertical"></i>
    </button>

    <div class="dropdown-menu hidden absolute right-0 mt-2 w-40 bg-white border border-slate-200 rounded-xl shadow-lg shadow-brand-900/5 z-50 overflow-hidden">
      <div class="py-1">
        @if (appt.EmailStatus == "pending")
        {
          <button onclick='confirmAppt(@Html.Raw(apptJson))' 
                  class="w-full text-left px-4 py-2 text-[12px] text-emerald-600 hover:bg-emerald-50 flex items-center gap-2">
            <i class="fa-solid fa-check w-4"></i> Confirm
          </button>
        }

        @if (appt.EmailStatus == "confirmed")
        {
          <button onclick='updateStatus(@Html.Raw(apptJson), "arrived")' 
                  class="w-full text-left px-4 py-2 text-[12px] text-yellow-600 hover:bg-yellow-50 flex items-center gap-2">
            <i class="fa-solid fa-person-walking-arrow-right w-4"></i> Arrived
          </button>
        }

        @if (appt.EmailStatus is "confirmed" or "arrived")
        {
          <button onclick='updateStatus(@Html.Raw(apptJson), "completed")' 
                  class="w-full text-left px-4 py-2 text-[12px] text-blue-600 hover:bg-blue-50 flex items-center gap-2">
            <i class="fa-solid fa-circle-check w-4"></i> Complete
          </button>
          
          <button onclick='updateStatus(@Html.Raw(apptJson), "no-show")' 
                  class="w-full text-left px-4 py-2 text-[12px] text-slate-500 hover:bg-slate-50 flex items-center gap-2">
            <i class="fa-solid fa-user-slash w-4"></i> No-Show
          </button>
        }
        
        @if (appt.EmailStatus is "confirmed" or "pending" or "arrived")
        {
          <button onclick='openEditModal(@Html.Raw(apptJson))' 
                  class="w-full text-left px-4 py-2 text-[12px] text-brand-600 hover:bg-slate-50 flex items-center gap-2">
            <i class="fa-solid fa-pen-to-square w-4"></i> Edit
          </button>
          
          <button onclick='cancelAppt(@Html.Raw(apptJson))' 
                  class="w-full text-left px-4 py-2 text-[12px] text-accent hover:bg-red-50 flex items-center gap-2">
            <i class="fa-solid fa-xmark w-4"></i> Cancel
          </button>
        }

        @if (appt.EmailStatus is "cancelled" or "no-show")
        {
          <button onclick='openRescheduleModal(@Html.Raw(apptJson))' 
                  class="w-full text-left px-4 py-2 text-[12px] text-primary hover:bg-blue-50 flex items-center gap-2">
            <i class="fa-solid fa-calendar-days w-4"></i> Reschedule
          </button>
        }

        @if (appt.EmailStatus is "waitlist" or "no-show" or "cancelled" or "completed")
        {
          <button onclick='deleteAppt(@Html.Raw(apptJson))' 
                  class="w-full text-left px-4 py-2 text-[12px] text-red-600 hover:bg-red-50 flex items-center gap-2">
            <i class="fa-solid fa-trash-can w-4"></i> Remove
          </button>
        }
      </div>
    </div>
  </div>
</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════════════ -->
<!-- BOOK APPOINTMENT MODAL                                                    -->
<!-- ══════════════════════════════════════════════════════════════════════════ -->
<div id="book-modal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="closeBookModal()"></div>
  <div class="absolute inset-0 flex items-center justify-center p-4 pointer-events-none">
    <div id="book-modal-box"
      class="bg-white rounded-2xl shadow-2xl w-full max-w-lg max-h-[90vh] overflow-y-auto pointer-events-auto
             transform scale-95 opacity-0 transition-all duration-300">

      <div class="flex items-center justify-between p-5 border-b border-slate-100">
        <h3 class="font-display font-extrabold text-[15px] text-brand-900">Book Appointment</h3>
        <button onclick="closeBookModal()" class="text-brand-400 hover:text-brand-600">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
            stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <div class="p-5 space-y-4">
        <!-- Patient info -->
        <div class="grid grid-cols-2 gap-3">
          <div class="col-span-2">
            <label class="block text-[11px] font-semibold text-brand-500 mb-1">Patient Name *</label>
            <input id="book-patient-name" type="text" placeholder="Full name"
              class="w-full text-[12.5px] px-3 py-2 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-primary/30" />
          </div>
          <div>
            <label class="block text-[11px] font-semibold text-brand-500 mb-1">Email *</label>
            <input id="book-patient-email" type="email" placeholder="email@example.com"
              class="w-full text-[12.5px] px-3 py-2 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-primary/30" />
          </div>
          <div>
            <label class="block text-[11px] font-semibold text-brand-500 mb-1">Phone</label>
            <input id="book-patient-phone" type="tel" placeholder="+63 9XX XXX XXXX"
              class="w-full text-[12.5px] px-3 py-2 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-primary/30" />
          </div>
        </div>

        <!-- Service -->
        <div>
          <label class="block text-[11px] font-semibold text-brand-500 mb-1">Service *</label>
          <select id="book-service"
            class="w-full text-[12.5px] px-3 py-2 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-primary/30">
            <option value="">Select a service</option>
            @foreach (var svc in Model.Services)
            {
              <option value="@svc.Id" data-name="@svc.Name" data-category="@svc.Category">@svc.Name</option>
            }
          </select>
        </div>

        <!-- Doctor -->
        <div>
          <label class="block text-[11px] font-semibold text-brand-500 mb-1">Doctor</label>
          <select id="book-doctor"
            class="w-full text-[12.5px] px-3 py-2 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-primary/30">
            <option value="">Any available doctor</option>
            @foreach (var doc in Model.Doctors)
            {
              <option value="@doc.Id" data-name="@doc.DoctorName" data-specialties="@(doc.Specialties != null ? string.Join(",", doc.Specialties) : "")">@doc.DoctorName</option>
            }
          </select>
        </div>

        <!-- Date & Time -->
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-[11px] font-semibold text-brand-500 mb-1">Date *</label>
            <input id="book-date" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")"
              class="w-full text-[12.5px] px-3 py-2 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-primary/30" />
          </div>
          <div>
            <label class="block text-[11px] font-semibold text-brand-500 mb-1">Time *</label>
            <select id="book-time"
              class="w-full text-[12.5px] px-3 py-2 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-primary/30">
              <option value="">Select time</option>
              @foreach (var slot in SamsonDentalCenterManagementSystem.Services.AppointmentService.ALL_SLOTS)
              {
                <option value="@slot">@slot</option>
              }
            </select>
          </div>
        </div>

        <!-- Notes -->
        <div>
          <label class="block text-[11px] font-semibold text-brand-500 mb-1">Notes</label>
          <textarea id="book-notes" rows="2" placeholder="Additional notes…"
            class="w-full text-[12.5px] px-3 py-2 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-primary/30 resize-none"></textarea>
        </div>
      </div>

      <div class="flex justify-end gap-2 p-5 border-t border-slate-100">
        <button onclick="closeBookModal()"
          class="px-4 py-2 text-[12.5px] rounded-xl border border-slate-200 text-brand-500 hover:bg-slate-50">
          Cancel
        </button>
        <button onclick="submitBook()"
          class="px-4 py-2 text-[12.5px] rounded-xl bg-primary text-white font-semibold shadow-md shadow-primary/25 hover:opacity-90">
          Book Appointment
        </button>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════════════ -->
<!-- EDIT / RESCHEDULE MODAL                                                   -->
<!-- ══════════════════════════════════════════════════════════════════════════ -->
<div id="edit-modal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="closeEditModal()"></div>
  <div class="absolute inset-0 flex items-center justify-center p-4 pointer-events-none">
    <div id="edit-modal-box"
      class="bg-white rounded-2xl shadow-2xl w-full max-w-md pointer-events-auto
             transform scale-95 opacity-0 transition-all duration-300">

      <div class="flex items-center justify-between p-5 border-b border-slate-100">
        <h3 id="edit-modal-title" class="font-display font-extrabold text-[15px] text-brand-900">Edit Appointment</h3>
        <button onclick="closeEditModal()" class="text-brand-400 hover:text-brand-600">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
            stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <input type="hidden" id="edit-appt-id" />

      <div class="p-5 space-y-4">
        <div>
          <label class="block text-[11px] font-semibold text-brand-500 mb-1">Doctor</label>
          <select id="edit-doctor"
            class="w-full text-[12.5px] px-3 py-2 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-primary/30">
            <option value="">Any available</option>
            @foreach (var doc in Model.Doctors)
            {
              <option value="@doc.Id" data-name="@doc.DoctorName" data-specialties="@(doc.Specialties != null ? string.Join(",", doc.Specialties) : "")">@doc.DoctorName</option>
            }
          </select>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-[11px] font-semibold text-brand-500 mb-1">New Date *</label>
            <input id="edit-date" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")"
              class="w-full text-[12.5px] px-3 py-2 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-primary/30" />
          </div>
          <div>
            <label class="block text-[11px] font-semibold text-brand-500 mb-1">New Time *</label>
            <select id="edit-time"
              class="w-full text-[12.5px] px-3 py-2 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-primary/30">
              <option value="">Select time</option>
              @foreach (var slot in SamsonDentalCenterManagementSystem.Services.AppointmentService.ALL_SLOTS)
              {
                <option value="@slot">@slot</option>
              }
            </select>
          </div>
        </div>
      </div>

      <div class="flex justify-end gap-2 p-5 border-t border-slate-100">
        <button onclick="closeEditModal()"
          class="px-4 py-2 text-[12.5px] rounded-xl border border-slate-200 text-brand-500 hover:bg-slate-50">
          Cancel
        </button>
        <button onclick="submitReschedule()"
          class="px-4 py-2 text-[12.5px] rounded-xl bg-primary text-white font-semibold shadow-md shadow-primary/25 hover:opacity-90">
          Save Changes
        </button>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════════════ -->
<!-- CONFIRM APPOINTMENT MODAL                                                 -->
<!-- ══════════════════════════════════════════════════════════════════════════ -->
<div id="confirm-modal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="closeConfirmModal()"></div>
  <div class="absolute inset-0 flex items-center justify-center p-4 pointer-events-none">
    <div id="confirm-modal-box"
      class="bg-white rounded-2xl shadow-2xl w-full max-w-md pointer-events-auto
             transform scale-95 opacity-0 transition-all duration-300">

      <div class="flex items-center justify-between p-5 border-b border-slate-100">
        <h3 class="font-display font-extrabold text-[15px] text-emerald-600">Confirm Appointment</h3>
        <button onclick="closeConfirmModal()" class="text-brand-400 hover:text-brand-600">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
            stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <div class="p-5 space-y-4">
        <p id="confirm-modal-message" class="text-[12.5px] text-brand-600"></p>
        
        <div>
          <label class="block text-[11px] font-semibold text-brand-500 mb-1">Assign Doctor *</label>
          <select id="confirm-doctor"
            class="w-full text-[12.5px] px-3 py-2 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-primary/30">
            <option value="">Select a doctor</option>
            @foreach (var doc in Model.Doctors)
            {
              <option value="@doc.Id" data-name="@doc.DoctorName" data-specialties="@(doc.Specialties != null ? string.Join(",", doc.Specialties) : "")">@doc.DoctorName</option>
            }
          </select>
          <p id="doctor-hint" class="text-[10px] text-brand-400 mt-1 hidden italic">Note: Only doctors specializing in this service category are shown.</p>
        </div>
      </div>

      <input type="hidden" id="confirm-appt-id" />

      <div class="flex justify-end gap-2 p-5 border-t border-slate-100">
        <button onclick="closeConfirmModal()"
          class="px-4 py-2 text-[12.5px] rounded-xl border border-slate-200 text-brand-500 hover:bg-slate-50">
          Cancel
        </button>
        <button onclick="submitConfirm()"
          class="px-4 py-2 text-[12.5px] rounded-xl bg-emerald-600 text-white font-semibold shadow-md shadow-emerald-600/25 hover:opacity-90">
          Confirm Appointment
        </button>
      </div>
    </div>
  </div>
</div>



    <script type="module" src="~/js/AdminSide/adminAppointment.js"></script>