@page "/Appointments"
@model AppointmentModel
@{
    ViewData["Title"] = "Book an Appointment";
}

@* ── Server-side user data bridge ── *@
@* Injected once at page load — JS reads this instead of localStorage *@
<script id="appointment-user" type="application/json">
    @if (Model.IsLoggedIn)
    {
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
            id          = Model.CurrentUser!.Id,
            firstName   = Model.CurrentUser.FirstName,
            lastName    = Model.CurrentUser.LastName,
            email       = Model.CurrentUser.Email ?? "",
            phone       = Model.CurrentUser.PhoneNumber ?? "",
            sex         = Model.CurrentUser.Sex ?? "",
            dob         = Model.CurrentUser.DateOfBirth?.ToString("yyyy-MM-dd") ?? "",
            role        = Model.CurrentUser.Role ?? "patient",
            avatarUrl   = Model.CurrentUser.AvatarUrl ?? "",
            initials    = ((Model.CurrentUser.FirstName?.Length > 0 ? Model.CurrentUser.FirstName[0].ToString() : "") +
                          (Model.CurrentUser.LastName?.Length  > 0 ? Model.CurrentUser.LastName[0].ToString()  : "")).ToUpper(),
            isLoggedIn  = true
        }))
    }
    else
    {
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new { isLoggedIn = false }))
    }
</script>

<div class="min-h-screen flex flex-col">
    <div class="flex-1 py-10 px-4 sm:px-6 lg:px-12">
        <div class="max-w sm:px-6 mx-auto">
            <partial name="PatientSide/Appointments/Services" />
            <partial name="PatientSide/Appointments/Schedule" />
            <partial name="PatientSide/Appointments/Details" />
            <partial name="PatientSide/Appointments/Confirmation" />
            <partial name="PatientSide/Appointments/Success" />
        </div>
    </div>
</div>
