@page "/About"
@model AboutModel
@{
    ViewData["Title"] = "About page";
}

<section class="pt-[68px] relative overflow-hidden h-[400px]">
  
 <div class="absolute inset-0 bg-gradient-to-b from-[#eaeaee] via-[#f5f5f7] to-[#b8b8c4]"></div>
  <div class="about-hero-bg-img absolute inset-0 opacity-80"></div>
  <div class="absolute inset-0 bg-gradient-to-br from-[#eaeaee]/75 via-[#f5f5f7]/50 to-transparent"></div>


  <div class="max-w-7xl mx-auto px-8 lg:px-12 py-16 relative z-10">
    <h1 class="brand-font font-extrabold text-[2.8rem] text-brand mb-3">
      About Us
    </h1>
    <p class="font-body text-[0.92rem] text-brand max-w-sm leading-relaxed">
      Discover the story, mission, and people behind Samson Dental Center's commitment to excellence.
    </p>
  </div>

</section>


<!-- ══════════════════════════════════
     OUR STORY
═══════════════════════════════════ -->
<section class="bg-white">
  <div class="max-w-7xl mx-auto px-8 lg:px-12 py-24 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

    <!-- Text -->
    <div class="fade-up">
      <div class="flex items-center gap-2 font-body text-[0.67rem] font-semibold tracking-[0.15em] uppercase text-muted mb-5">
        <span class="w-2 h-2 rounded-full bg-primary"></span>
        Our Story
      </div>
      <h2 class="brand-font font-extrabold leading-[1.1] text-brand mb-6" style="font-size:clamp(2rem,4vw,2.8rem);">
        Redefining the<br>Dental Experience.
      </h2>
      <p class="font-body text-[0.93rem] text-muted leading-relaxed mb-4">
        Founded in 2008, Samson Dental Center started with a singular vision: to bridge the gap between world-class medical precision and the comfort of a hospitality-driven experience.
      </p>
      <p class="font-body text-[0.93rem] text-muted leading-relaxed">
        We believe that a visit to the dentist shouldn't be a chore, but a step towards a healthier, more confident you. Our clinic combines architectural elegance with cutting-edge technology, ensuring that every patient feels valued, understood, and cared for.
      </p>

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-4 mt-10">
        <div class="stat-card bg-offwhite rounded-2xl p-5 text-center">
          <div class="brand-font font-extrabold text-[1.9rem] text-brand leading-none">16+</div>
          <div class="font-body text-[0.7rem] text-muted mt-1.5 leading-snug">Years of<br>Excellence</div>
        </div>
        <div class="stat-card bg-offwhite rounded-2xl p-5 text-center">
          <div class="brand-font font-extrabold text-[1.9rem] text-brand leading-none">2K+</div>
          <div class="font-body text-[0.7rem] text-muted mt-1.5 leading-snug">Happy<br>Patients</div>
        </div>
        <div class="stat-card bg-offwhite rounded-2xl p-5 text-center">
          <div class="brand-font font-extrabold text-[1.9rem] text-brand leading-none">12</div>
          <div class="font-body text-[0.7rem] text-muted mt-1.5 leading-snug">Expert<br>Specialists</div>
        </div>
      </div>
    </div>

    <!-- Image -->
    <div class="fade-up relative">
      <div class="rounded-2xl overflow-hidden shadow-xl relative">
        <img src="https://images.unsplash.com/photo-1629909613654-28e377c37b09?w=800&q=80"
             alt="Clinic interior"
             class="w-full h-[440px] object-cover"/>
        <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-brand/90 to-transparent p-6">
          <div class="brand-font font-bold text-white text-[1.1rem]">Est. 2008</div>
          <div class="font-body text-white/55 text-[0.78rem] mt-0.5">Quezon City, Philippines</div>
        </div>
      </div>
      <!-- Floating badge -->
      <div class="absolute -top-4 -right-4 w-20 h-20 rounded-full bg-primary flex flex-col items-center justify-center shadow-lg">
        <div class="brand-font font-extrabold text-white text-[0.9rem] leading-none">#1</div>
        <div class="font-body text-white/80 text-[0.52rem] text-center leading-tight mt-0.5">Rated<br>Clinic</div>
      </div>
    </div>

  </div>
</section>


<!-- ══════════════════════════════════
     MISSION & VALUES
═══════════════════════════════════ -->
<section class="bg-offwhite">
  <div class="max-w-7xl mx-auto px-8 lg:px-12 py-20">

    <div class="text-center mb-14 fade-up">
      <div class="flex items-center justify-center gap-2 font-body text-[0.67rem] font-semibold tracking-[0.15em] uppercase text-muted mb-4">
        <span class="w-2 h-2 rounded-full bg-primary"></span>
        What Drives Us
      </div>
      <h2 class="brand-font font-extrabold text-brand" style="font-size:clamp(1.8rem,3.5vw,2.6rem);">
        Our Mission & Values
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <div class="fade-up bg-white rounded-2xl p-8 shadow-sm hover:-translate-y-1 transition-transform duration-200">
        <div class="w-12 h-12 rounded-xl bg-red-50 flex items-center justify-center mb-5">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c0392b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </div>
        <h3 class="brand-font font-bold text-[1.1rem] text-brand mb-3">Patient-First Care</h3>
        <p class="font-body text-[0.86rem] text-muted leading-relaxed">
          Every decision we make centers on patient comfort, safety, and outcomes. We treat each visit as a partnership.
        </p>
      </div>

      <div class="fade-up bg-white rounded-2xl p-8 shadow-sm hover:-translate-y-1 transition-transform duration-200">
        <div class="w-12 h-12 rounded-xl bg-red-50 flex items-center justify-center mb-5">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c0392b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>
          </svg>
        </div>
        <h3 class="brand-font font-bold text-[1.1rem] text-brand mb-3">Clinical Excellence</h3>
        <p class="font-body text-[0.86rem] text-muted leading-relaxed">
          We invest continuously in the latest dental technology and evidence-based techniques to deliver superior results.
        </p>
      </div>

      <div class="fade-up bg-white rounded-2xl p-8 shadow-sm hover:-translate-y-1 transition-transform duration-200">
        <div class="w-12 h-12 rounded-xl bg-red-50 flex items-center justify-center mb-5">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c0392b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <h3 class="brand-font font-bold text-[1.1rem] text-brand mb-3">Community Commitment</h3>
        <p class="font-body text-[0.86rem] text-muted leading-relaxed">
          We believe healthy smiles transform communities. Our outreach programs bring quality dental care to those in need.
        </p>
      </div>

    </div>
  </div>
</section>


<!-- ══════════════════════════════════
     OUR DEDICATED TEAM
═══════════════════════════════════ -->
<section class="bg-brand">
  <div class="max-w-7xl mx-auto px-8 lg:px-12 py-24">

    <div class="text-center mb-14 fade-up">
      <h2 class="brand-font font-extrabold text-white mb-3" style="font-size:clamp(1.8rem,3.5vw,2.6rem);">
        Our Dedicated Team
      </h2>
      <p class="font-body text-[0.9rem] text-white/45 max-w-sm mx-auto leading-relaxed">
        Behind every smile is a team of passionate professionals dedicated to your comfort and care.
      </p>
    </div>

    <!-- Featured doctor card -->
    <div id="teamCard" class="fade-up bg-white rounded-2xl p-8 lg:p-10 flex flex-col lg:flex-row gap-10 items-center max-w-3xl mx-auto mb-10 shadow-2xl">

      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 font-body text-[0.62rem] font-semibold tracking-[0.13em] uppercase text-muted mb-5">
          <span class="w-2 h-2 rounded-full bg-primary"></span>
          <span id="teamRole">Chief Oral Surgeon</span>
        </div>
        <h3 id="teamName" class="brand-font font-extrabold text-brand mb-4" style="font-size:clamp(1.5rem,3vw,2rem);">
          Dr. Marcus Rivera
        </h3>
        <blockquote id="teamQuote" class="border-l-2 border-primary pl-4 font-body text-[0.87rem] text-muted italic leading-relaxed mb-6">
          "Surgery is an art where precision meets compassion. My goal is to ensure safety and comfort in every procedure."
        </blockquote>
        <div class="grid grid-cols-2 gap-6">
          <div>
            <div class="flex items-center gap-1.5 font-body text-[0.6rem] font-semibold tracking-[0.1em] uppercase text-muted mb-2">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
              Education
            </div>
            <div id="teamEdu" class="font-body text-[0.82rem] text-brand font-medium leading-snug">DMD, UP Manila | Residency at Mount Sinai</div>
          </div>
          <div>
            <div class="flex items-center gap-1.5 font-body text-[0.6rem] font-semibold tracking-[0.1em] uppercase text-muted mb-2">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
              Experience
            </div>
            <div id="teamExp" class="font-body text-[0.82rem] text-brand font-medium">16 Years Experience</div>
          </div>
        </div>
      </div>

      <div class="shrink-0">
        <img id="teamImg" src="https://randomuser.me/api/portraits/men/46.jpg" alt="Dr. Marcus Rivera"
             class="w-48 h-56 object-cover rounded-xl shadow-lg"/>
      </div>
    </div>

    <!-- Thumbnail selector -->
    <div class="flex justify-center gap-4">
      <img src="https://randomuser.me/api/portraits/men/46.jpg"   data-index="0" onclick="selectDoctor(0)"
           class="team-thumb active w-14 h-14 rounded-full object-cover border-2 border-transparent"/>
      <img src="https://randomuser.me/api/portraits/women/44.jpg" data-index="1" onclick="selectDoctor(1)"
           class="team-thumb opacity-50 w-14 h-14 rounded-full object-cover border-2 border-transparent"/>
      <img src="https://randomuser.me/api/portraits/men/32.jpg"   data-index="2" onclick="selectDoctor(2)"
           class="team-thumb opacity-50 w-14 h-14 rounded-full object-cover border-2 border-transparent"/>
    </div>

  </div>
</section>


<!-- ══════════════════════════════════
     FAQ
═══════════════════════════════════ -->
<section class="bg-white">
  <div class="max-w-2xl mx-auto px-8 lg:px-12 py-24">

    <div class="text-center mb-12 fade-up">
      <h2 class="brand-font font-extrabold text-brand mb-3" style="font-size:clamp(1.8rem,3.5vw,2.5rem);">
        Frequently Asked Questions
      </h2>
      <p class="font-body text-[0.9rem] text-muted">Common questions from our patients.</p>
    </div>

    <div class="space-y-3 fade-up" id="faqList"></div>

  </div>
</section>

<script src="~/js/about.js"></script>