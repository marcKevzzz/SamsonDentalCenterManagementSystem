          <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/10 to-transparent"></div>
         <div class="absolute bottom-0 left-0 right-0 p-6 transition-all duration-300 group-hover:opacity-0 group-hover:translate-y-4">
            <h3 class="brand-font font-extrabold text-white text-[1.4rem] leading-tight">Executive Lounge</h3>
