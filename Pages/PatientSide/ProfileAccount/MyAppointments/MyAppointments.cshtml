@page "/Profile/MyAppointments"
@model MyAppointmentsModel
@{
ViewData["Title"] = "My Appointments page";
}


<div class="flex-1 min-w-0">
  <!-- Header Section -->
  <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-6 mb-8 fade-up">
    <div>
      <div class="flex items-center gap-2 font-body text-[0.67rem] font-semibold tracking-[0.15em] uppercase text-muted mb-2">
        <span class="w-2 h-2 rounded-full bg-primary inline-block"></span>Appointments
      </div>
      <h1 class="brand-font font-extrabold text-brand text-[1.8rem] leading-tight">My Appointments</h1>
    </div>
    
    <div class="flex flex-col sm:flex-row gap-3">
        <div class="relative min-w-[280px]">
            <input type="text" id="apptSearch" oninput="searchAppts(this.value)" placeholder="Search by service or doctor..." 
                   class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-[#e5e7eb] bg-white text-[0.85rem] focus:border-primary outline-none transition-all" />
            <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-muted text-xs"></i>
        </div>
        <a href="/Appointments" class="brand-font font-bold text-[0.8rem] tracking-wider uppercase bg-brand text-white px-6 py-2.5 rounded-xl hover:bg-primary transition-all text-center no-underline">
            Book New
        </a>
    </div>
  </div>

  <!-- Stats Grid -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-10 fade-up">
    <div class="bg-white rounded-2xl p-5 border border-[#e5e7eb] shadow-sm group hover:border-primary/30 transition-all">
      <div class="flex items-center justify-between mb-3">
          <div class="w-10 h-10 rounded-xl bg-gray-50 flex items-center justify-center text-brand group-hover:bg-primary group-hover:text-white transition-all">
              <i class="fa-solid fa-calendar-check"></i>
          </div>
          <div class="brand-font font-extrabold text-brand text-[1.5rem]">@Model.TotalCount</div>
      </div>
      <div class="font-body text-[0.7rem] font-bold uppercase tracking-wider text-muted">Total</div>
    </div>
    
    <div class="bg-white rounded-2xl p-5 border border-[#e5e7eb] shadow-sm group hover:border-primary/30 transition-all">
      <div class="flex items-center justify-between mb-3">
          <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center text-primary">
              <i class="fa-solid fa-clock-rotate-left"></i>
          </div>
          <div class="brand-font font-extrabold text-brand text-[1.5rem]">@Model.UpcomingCount</div>
      </div>
      <div class="font-body text-[0.7rem] font-bold uppercase tracking-wider text-muted">Upcoming</div>
    </div>

    <div class="bg-white rounded-2xl p-5 border border-[#e5e7eb] shadow-sm group hover:border-primary/30 transition-all">
      <div class="flex items-center justify-between mb-3">
          <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center text-green-600">
              <i class="fa-solid fa-check"></i>
          </div>
          <div class="brand-font font-extrabold text-brand text-[1.5rem]">@Model.CompletedCount</div>
      </div>
      <div class="font-body text-[0.7rem] font-bold uppercase tracking-wider text-muted">Completed</div>
    </div>

    <div class="bg-white rounded-2xl p-5 border border-[#e5e7eb] shadow-sm group hover:border-primary/30 transition-all">
      <div class="flex items-center justify-between mb-3">
          <div class="w-10 h-10 rounded-xl bg-yellow-50 flex items-center justify-center text-yellow-600">
              <i class="fa-solid fa-star"></i>
          </div>
          <div class="brand-font font-extrabold text-brand text-[1.5rem]">4.8</div>
      </div>
      <div class="font-body text-[0.7rem] font-bold uppercase tracking-wider text-muted">Rating</div>
    </div>
  </div>

  <!-- Filter Tabs -->
  <div class="flex items-center gap-2 mb-6  pb-px fade-up overflow-x-auto no-scrollbar">
    <button onclick="filterAppts('all')" class="filter-tab active px-4 py-3 font-body text-[0.8rem] font-semibold text-muted border-b-2 border-transparent transition-all whitespace-nowrap" data-filter="all">All</button>
    <button onclick="filterAppts('confirmed')" class="filter-tab px-4 py-3 font-body text-[0.8rem] font-semibold text-muted border-b-2 border-transparent transition-all whitespace-nowrap" data-filter="confirmed">Confirmed</button>
    <button onclick="filterAppts('pending')" class="filter-tab px-4 py-3 font-body text-[0.8rem] font-semibold text-muted border-b-2 border-transparent transition-all whitespace-nowrap" data-filter="pending">Pending</button>
    <button onclick="filterAppts('completed')" class="filter-tab px-4 py-3 font-body text-[0.8rem] font-semibold text-muted border-b-2 border-transparent transition-all whitespace-nowrap" data-filter="completed">Completed</button>
    <button onclick="filterAppts('cancelled')" class="filter-tab px-4 py-3 font-body text-[0.8rem] font-semibold text-muted border-b-2 border-transparent transition-all whitespace-nowrap" data-filter="cancelled">Cancelled</button>
  </div>

  <div id="apptList" class="grid grid-cols-1 md:grid-cols-2 gap-4">
    @if (!Model.Appointments.Any())
    {
    <div class="col-span-full py-20 text-center bg-white rounded-3xl border border-dashed border-[#e5e7eb]">
        <div class="w-16 h-16 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-4">
            <i class="fa-solid fa-calendar-plus text-muted text-xl"></i>
        </div>
        <h3 class="brand-font font-bold text-brand text-[1.1rem] mb-2">No Appointments Yet</h3>
        <p class="font-body text-[0.85rem] text-muted mb-6 max-w-xs mx-auto">Your smile is important to us. Book your first consultation today!</p>
        <a href="/Appointments" class="brand-font font-bold text-[0.8rem] tracking-wider uppercase bg-primary text-white px-8 py-3 rounded-xl hover:opacity-90 transition-all no-underline">
            Book Appointment
        </a>
    </div>
    }
    else
    {
    @foreach (var appt in Model.Appointments)
    {
        var docName = appt.Doctor?.Profile != null ? $"{appt.Doctor.Title} {appt.Doctor.Profile.FirstName} {appt.Doctor.Profile.LastName}" : null;
        var apptJson = System.Text.Json.JsonSerializer.Serialize(new {
            id = appt.Id,
            serviceName = appt.ServiceName,
            doctorName = docName,
            date = appt.AppointmentDate.ToString("MMM dd, yyyy"),
            time = appt.AppointmentTime,
            status = appt.Status,
            notes = appt.Notes
        });

        var s = appt.Status.ToLower();
        var statusClass = s switch
        {
            "confirmed" => "bg-emerald-50 text-emerald-600 border-emerald-100",
            "completed" => "bg-blue-50 text-blue-600 border-blue-100",
            "cancelled" => "bg-red-50 text-red-600 border-red-100",
            "pending"   => "bg-orange-50 text-orange-600 border-orange-100",
            "arrived"   => "bg-yellow-50 text-yellow-600 border-yellow-100",
            "no-show"   => "bg-slate-50 text-slate-600 border-slate-100",
            _           => "bg-gray-50 text-gray-600 border-gray-100"
        };

        var accentColor = s switch {
            "confirmed" => "bg-emerald-500",
            "completed" => "bg-blue-500",
            "cancelled" => "bg-red-500",
            "pending"   => "bg-orange-500",
            "arrived"   => "bg-yellow-500",
            "no-show"   => "bg-slate-500",
            _           => "bg-gray-500"
        };

        <div class="appt-card fade-up group bg-white rounded-2xl border border-[#e5e7eb] hover:border-primary/20 hover:shadow-md transition-all overflow-hidden"
             data-status="@s" data-name="@appt.ServiceName @docName">

          <div class="p-5">
            <div class="flex items-start justify-between gap-4 mb-4">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-gray-50 flex items-center justify-center shrink-0">
                        <i class="fa-solid fa-tooth text-brand"></i>
                    </div>
                    <div>
                        <h3 class="brand-font font-bold text-brand text-[1rem] leading-none mb-1">@appt.ServiceName</h3>
                        <div class="flex items-center gap-1.5 font-body text-[0.72rem] text-muted">
                        @if(docName != null && s != "pending"){
                            <i class="fa-solid fa-user-doctor text-[9px]"></i>
                            @docName
                        } else if(docName != null && s == "cancelled"){
                            <i class="fa-solid fa-user-doctor text-[9px]"></i>
                            <span class="text-muted">As Assigned</span>
                        } else {
                            <i class="fa-solid fa-user-doctor text-[9px]"></i>
                            <span class="text-muted">As Assigned</span>
                        }
                        </div>
                    </div>
                </div>
                <span class="font-body text-[0.62rem] font-bold uppercase tracking-widest @statusClass px-2.5 py-1 rounded-full border">
                  @appt.Status
                </span>
            </div>

            <div class="grid grid-cols-2 gap-3 mb-5">
                <div class="bg-gray-50 rounded-xl p-2.5">
                    <div class="font-body text-[0.6rem] uppercase tracking-wider text-muted mb-0.5">Date</div>
                    <div class="brand-font font-bold text-brand text-[0.8rem]">@appt.AppointmentDate.ToString("MMM dd, yyyy")</div>
                </div>
                <div class="bg-gray-50 rounded-xl p-2.5">
                    <div class="font-body text-[0.6rem] uppercase tracking-wider text-muted mb-0.5">Time</div>
                    <div class="brand-font font-bold text-brand text-[0.8rem]">@appt.AppointmentTime</div>
                </div>
            </div>

            <div class="flex items-center justify-between pt-4 border-t border-[#f0f0f0]">
                <div class="font-body text-[0.68rem] text-muted">
                    Ref: <span class="font-bold text-brand">SDC-@appt.Id.Substring(0,6).ToUpper()</span>
                </div>
                
                <div class="flex gap-2">
                    <button onclick='viewApptDetails(@Html.Raw(apptJson))'
                            class="w-8 h-8 rounded-lg flex items-center justify-center text-muted hover:bg-slate-100 transition-all"
                            title="View Details">
                        <i class="fa-solid fa-file-circle-exclamation text-xs"></i>
                    </button>

                    @if (s == "confirmed" || s == "pending") {
                        <button onclick="cancelAppointment('@appt.Id')" 
                                class="w-8 h-8 rounded-lg flex items-center justify-center text-red-500 hover:bg-red-50 transition-all"
                                title="Cancel Appointment">
                            <i class="fa-solid fa-trash-can text-xs"></i>
                        </button>
                    }
                    
                    @if (s == "completed") {
                         <button class="w-8 h-8 rounded-lg flex items-center justify-center text-primary hover:bg-blue-50 transition-all"
                                title="Add Review">
                            <i class="fa-solid fa-comment-dots text-xs"></i>
                        </button>
                    }
                </div>
            </div>
          </div>
        </div>
    }
    }
  </div>

  <!-- Empty state for search/filters -->
  <div id="noResults" class="hidden py-20 text-center">
      <p class="text-muted font-body text-[0.9rem]">No appointments match your search or filter.</p>
      <button onclick="clearFilters()" class="text-primary font-bold text-[0.8rem] mt-2 underline">Clear all filters</button>
  </div>
</div>

<!-- Appointment Details Modal -->
<div id="details-modal" class="fixed inset-0 z-[10001] hidden">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="closeDetailsModal()"></div>
    <div class="absolute inset-0 flex items-center justify-center sm:p-4 pointer-events-none">
        <div id="details-modal-box" 
             class="bg-white s rounded-xl shadow-2xl w-full max-w-lg flex flex-col max-h-[90vh] overflow-hidden pointer-events-auto transform scale-95 opacity-0 transition-all duration-300">
            
            <!-- Modal Header -->
            <div class="relative h-32 bg-brand flex items-center px-8 shrink-0">
                <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 20px 20px;"></div>
                <div class="relative z-10">
                    <h3 id="det-service" class="brand-font font-bold text-white text-xl">Service Name</h3>
                    <p id="det-id" class="font-body text-white/50 text-xs mt-1 uppercase tracking-widest">#APT-ID</p>
                </div>
                <button onclick="closeDetailsModal()" class="absolute top-6 right-6 text-white/50 hover:text-white transition-colors">
                    <i class="fa-solid fa-xmark text-lg"></i>
                </button>
            </div>

            <!-- Modal Content -->
            <div class="p-8 space-y-6 overflow-y-auto">
                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label class="block text-[0.65rem] font-bold text-muted uppercase tracking-wider mb-2">Date & Time</label>
                        <div class="flex items-center gap-2 text-brand font-semibold text-sm">
                            <i class="fa-regular fa-calendar text-primary"></i>
                            <span id="det-date">Date</span>
                        </div>
                        <div class="flex items-center gap-2 text-brand font-semibold text-sm mt-1">
                            <i class="fa-regular fa-clock text-primary"></i>
                            <span id="det-time">Time</span>
                        </div>
                    </div>
                    <div>
                        <label class="block text-[0.65rem] font-bold text-muted uppercase tracking-wider mb-2">Status</label>
                        <div id="det-status-badge" class="inline-flex px-3 py-1 rounded-full text-[0.7rem] font-bold uppercase">STATUS</div>
                    </div>
                </div>

                <hr class="border-slate-100" />

                <div>
                    <label class="block text-[0.65rem] font-bold text-muted uppercase tracking-wider mb-2">Doctor</label>
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-primary">
                            <i class="fa-solid fa-user-doctor"></i>
                        </div>
                        <div>
                            <p id="det-doctor" class="brand-font font-bold text-brand text-sm">Dr. Name</p>
                            <p class="font-body text-muted text-xs">Assigned Specialist</p>
                        </div>
                    </div>
                </div>

                <div>
                    <label class="block text-[0.65rem] font-bold text-muted uppercase tracking-wider mb-2">Location</label>
                    <div class="flex items-start gap-3">
                        <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-primary shrink-0">
                            <i class="fa-solid fa-location-dot"></i>
                        </div>
                        <div>
                            <p class="brand-font font-bold text-brand text-sm">Samson Dental Center</p>
                            <p class="font-body text-muted text-xs leading-relaxed">Unit 201, Medical Tower, Quezon City, Metro Manila</p>
                        </div>
                    </div>
                </div>

                <div id="det-notes-wrap">
                    <label class="block text-[0.65rem] font-bold text-muted uppercase tracking-wider mb-2">Notes</label>
                    <div class="bg-slate-50 rounded-2xl p-4 border border-slate-100">
                        <p id="det-notes" class="font-body text-brand/70 text-xs leading-relaxed italic">No additional notes.</p>
                    </div>
                </div>
            </div>

            <!-- Modal Footer -->
            <div class="p-6 bg-slate-50 border-t border-slate-100 flex justify-end shrink-0">
                <button onclick="closeDetailsModal()" class="brand-font font-bold text-[0.75rem] tracking-wider uppercase text-muted hover:text-brand px-6 py-2 transition-colors">
                    Close
                </button>
            </div>
        </div>
    </div>
</div>


<script type="module" src="~/js/site.js"></script>
<script type="module" src="~/js/PatientSide/myAppointments.js"></script>