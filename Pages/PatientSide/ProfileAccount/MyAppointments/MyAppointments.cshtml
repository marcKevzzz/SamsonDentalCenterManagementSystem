@page "/Profile/MyAppointments"
@model MyAppointmentsModel
@{
    ViewData["Title"] = "My Appointments page";
}

 <div class="flex-1 min-w-0 ">
 
    <!-- Page header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8 fade-up">
      <div>
        
        <h1 class="brand-font font-extrabold text-brand text-[1.8rem] leading-tight">My Appointments</h1>
        <p class="font-body text-[0.88rem] text-muted mt-1">View your appointment history and dentist feedback.</p>
      </div>
     
    </div>
 
    <!-- Stats row -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8 fade-up">
      <div class="bg-white rounded-2xl p-4 border border-[#e5e7eb] text-center">
        <div class="brand-font font-extrabold text-brand text-[1.7rem] leading-none">6</div>
        <div class="font-body text-[0.7rem] text-muted mt-1.5 leading-snug">Total<br>Appointments</div>
      </div>
      <div class="bg-white rounded-2xl p-4 border border-[#e5e7eb] text-center">
        <div class="brand-font font-extrabold text-brand text-[1.7rem] leading-none">1</div>
        <div class="font-body text-[0.7rem] text-muted mt-1.5 leading-snug">Upcoming<br>This Month</div>
      </div>
      <div class="bg-white rounded-2xl p-4 border border-[#e5e7eb] text-center">
        <div class="brand-font font-extrabold text-brand text-[1.7rem] leading-none">4</div>
        <div class="font-body text-[0.7rem] text-muted mt-1.5 leading-snug">Completed<br>Visits</div>
      </div>
      <div class="bg-white rounded-2xl p-4 border border-[#e5e7eb] text-center">
        <div class="brand-font font-extrabold text-primary text-[1.7rem] leading-none">4.8</div>
        <div class="font-body text-[0.7rem] text-muted mt-1.5 leading-snug">Avg. Dentist<br>Rating</div>
      </div>
    </div>
 
    <!-- Filter tabs + search -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6 fade-up">
      <div class="flex gap-2 flex-wrap" id="filterTabs">
        <button class="filter-tab active" data-filter="all"       onclick="filterAppts('all')">All</button>
        <button class="filter-tab"        data-filter="upcoming"  onclick="filterAppts('upcoming')">Upcoming</button>
        <button class="filter-tab"        data-filter="completed" onclick="filterAppts('completed')">Completed</button>
        <button class="filter-tab"        data-filter="cancelled" onclick="filterAppts('cancelled')">Cancelled</button>
      </div>
      <!-- Search -->
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-muted pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" placeholder="Search appointments…" oninput="searchAppts(this.value)"
          class="font-body text-[0.82rem] pl-9 pr-4 py-2 rounded-full border border-[#e5e7eb] bg-white focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all w-52"/>
      </div>
    </div>
 
    <!-- Appointment list -->
    <div id="apptList" class="space-y-4">
 
      <!-- ════ UPCOMING ════ -->
 
      <!-- Card: Upcoming -->
      <div class="appt-card fade-up bg-white rounded-2xl border border-[#e5e7eb] overflow-hidden" data-status="upcoming" data-name="teeth cleaning">
        <!-- Top accent -->
        <div class="h-1 bg-gradient-to-r from-blue-500 to-blue-400"></div>
        <div class="p-5">
          <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-3">
            <!-- Left info -->
            <div class="flex items-start gap-4">
              <!-- Icon -->
              <div class="w-11 h-11 rounded-xl bg-blue-50 flex items-center justify-center shrink-0 mt-0.5">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              </div>
              <div>
                <div class="brand-font font-bold text-brand text-[1rem] mb-0.5">Teeth Cleaning</div>
                <div class="font-body text-[0.8rem] text-muted">General Dentistry</div>
                <div class="flex flex-wrap items-center gap-3 mt-2">
                  <div class="flex items-center gap-1.5 font-body text-[0.78rem] text-muted">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    April 15, 2026
                  </div>
                  <div class="flex items-center gap-1.5 font-body text-[0.78rem] text-muted">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    10:00 AM
                  </div>
                  <div class="flex items-center gap-1.5 font-body text-[0.78rem] text-muted">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    Dr. Marcus Rivera
                  </div>
                </div>
              </div>
            </div>
            <!-- Right: badge + actions -->
            <div class="flex sm:flex-col items-center sm:items-end gap-2 shrink-0">
              <span class="font-body text-[0.65rem] font-semibold uppercase tracking-wider bg-blue-50 text-blue-600 px-2.5 py-1 rounded-full">Upcoming</span>
              <div class="flex gap-2 mt-0 sm:mt-2">
                <button class="font-body text-[0.72rem] font-medium text-muted bg-offwhite border border-[#e5e7eb] px-3 py-1.5 rounded-lg hover:border-brand hover:text-brand transition-all cursor-pointer">Reschedule</button>
                <button class="font-body text-[0.72rem] font-medium text-primary bg-red-50 border border-primary/20 px-3 py-1.5 rounded-lg hover:bg-primary hover:text-white transition-all cursor-pointer">Cancel</button>
              </div>
            </div>
          </div>
          <!-- Reference -->
          <div class="mt-3 pt-3 border-t border-[#f0f0f0] flex items-center justify-between">
            <span class="font-body text-[0.68rem] text-muted">Ref: <span class="font-medium text-brand">SDC-A2024-041</span></span>
            <span class="font-body text-[0.68rem] text-muted">Booked: April 2, 2026</span>
