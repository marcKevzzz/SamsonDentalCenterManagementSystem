@page "/Profile/Records"
@model RecordsModel
@{
ViewData["Title"] = "Dental Records";
}

<section class="flex-1 min-w-0 space-y-2 sm:space-y-5">
  <div class="fade-up">

    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
      <div>
        <div
          class="flex items-center gap-2 font-body text-[0.67rem] font-semibold tracking-[0.15em] uppercase text-muted mb-2">
          <span class="w-2 h-2 rounded-full bg-primary inline-block"></span>Patient Records
        </div>
        <h1 class="brand-font font-extrabold text-brand text-[1.75rem] leading-tight">Dental Records</h1>
        <p class="font-body text-[.87rem] text-muted mt-1">Your complete oral health history at Samson Dental Center.
        </p>
      </div>

    </div>
  </div>

  <!-- ═══ PATIENT INFO CARD ═══ -->
  <div class="fade-up bg-brand rounded-2xl overflow-hidden">
    <div class="relative px-5 pt-5 pb-0">
      <div class="absolute inset-0 opacity-[.04]"
        style="background-image:linear-gradient(rgba(255,255,255,1) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,1) 1px,transparent 1px);background-size:30px 30px;">
      </div>
      <div class="relative z-10 flex flex-col sm:flex-row sm:items-start gap-4 mb-5">
        <!-- Avatar -->
        <div
          class="w-14 h-14 rounded-full bg-primary flex items-center justify-center shrink-0 border-2 border-primary/30">
          <span class="brand-font font-bold text-white text-[1.1rem]">JD</span>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <h2 class="brand-font font-extrabold text-white text-[1.2rem] leading-tight">Juan Dela Cruz</h2>
              <div class="flex flex-wrap items-center gap-3 mt-1.5">
                <span class="font-body text-[.75rem] text-white/55 flex items-center gap-1.5">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2" />
                    <line x1="16" y1="2" x2="16" y2="6" />
                    <line x1="8" y1="2" x2="8" y2="6" />
                    <line x1="3" y1="10" x2="21" y2="10" />
                  </svg>
                  DOB: June 15, 1995 (30 y/o)
                </span>
                <span class="font-body text-[.75rem] text-white/55 flex items-center gap-1.5">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                  </svg>
                  Male
                </span>
                <span class="font-body text-[.75rem] text-white/55">Patient ID: SDC-2024-0042</span>
              </div>
            </div>
            <span
              class="font-body text-[.65rem] font-semibold uppercase tracking-wider bg-green-500/20 text-green-300 px-2.5 py-1 rounded-full">Active
              Patient</span>
          </div>
        </div>
      </div>
      <!-- Info grid -->
      <div class="relative z-10 grid grid-cols-2 sm:grid-cols-4 border-t border-white/10">
        <div class="px-4 py-3 border-r border-white/10">
          <div class="font-body text-[.65rem] font-semibold tracking-[.1em] uppercase text-white/35 mb-1">Patient Since
          </div>
          <div class="brand-font font-bold text-white text-[.9rem]">January 2024</div>
        </div>
        <div class="px-4 py-3 sm:border-r border-white/10">
          <div class="font-body text-[.65rem] font-semibold tracking-[.1em] uppercase text-white/35 mb-1">Blood Type
          </div>
          <div class="brand-font font-bold text-white text-[.9rem]">O+</div>
        </div>
        <div class="px-4 py-3 border-t sm:border-t-0 border-r border-white/10">
          <div class="font-body text-[.65rem] font-semibold tracking-[.1em] uppercase text-white/35 mb-1">Last Visit
          </div>
          <div class="brand-font font-bold text-white text-[.9rem]">Jan 10, 2026</div>
        </div>
        <div class="px-4 py-3 border-t sm:border-t-0 border-white/10">
          <div class="font-body text-[.65rem] font-semibold tracking-[.1em] uppercase text-white/35 mb-1">Assigned
            Doctor</div>
          <div class="brand-font font-bold text-white text-[.9rem]">Dr. M. Rivera</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ TAB FILTER ═══ -->
  <div class="fade-up flex gap-2 flex-wrap">
    <button class="rec-tab active" data-tab="all" onclick="switchTab('all')">All Records</button>
    <button class="rec-tab" data-tab="medical" onclick="switchTab('medical')">Medical Info</button>
    <button class="rec-tab" data-tab="treatments" onclick="switchTab('treatments')">Treatments</button>
    <button class="rec-tab" data-tab="xrays" onclick="switchTab('xrays')">X-Rays &amp; Scans</button>
    <button class="rec-tab" data-tab="chart" onclick="switchTab('chart')">Tooth Chart</button>
  </div>

  <!-- ═══ MEDICAL INFORMATION ═══ -->
  <div class="rec-section fade-up" data-section="medical">
    <div class="bg-white rounded-2xl border border-[#e5e7eb] overflow-hidden rec-card">
      <button onclick="toggleSection(this)"
        class="w-full flex items-center justify-between px-5 py-4 cursor-pointer bg-transparent border-none text-left">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-xl bg-red-50 flex items-center justify-center shrink-0">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#c0392b" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <path
                d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
            </svg>
          </div>
          <span class="brand-font font-bold text-brand text-[.95rem]">Medical Information</span>
        </div>
        <svg class="rec-chevron open w-4 h-4 text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </button>
      <div class="rec-body open">
        <div class="px-5 pb-5 border-t border-[#f0f0f0]">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-4">

            <div class="bg-offwhite rounded-xl p-4">
              <div class="font-body text-[.65rem] font-semibold tracking-[.1em] uppercase text-muted mb-3">General
                Health</div>
              <div class="space-y-2.5">
                <div class="flex justify-between"><span class="font-body text-[.8rem] text-muted">Blood Type</span><span
                    class="font-body text-[.82rem] font-medium text-brand">O+</span></div>
                <div class="flex justify-between"><span class="font-body text-[.8rem] text-muted">Height</span><span
                    class="font-body text-[.82rem] font-medium text-brand">172 cm</span></div>
                <div class="flex justify-between"><span class="font-body text-[.8rem] text-muted">Weight</span><span
                    class="font-body text-[.82rem] font-medium text-brand">68 kg</span></div>
                <div class="flex justify-between"><span class="font-body text-[.8rem] text-muted">Smoker</span><span
                    class="font-body text-[.82rem] font-medium text-green-600">No</span></div>
              </div>
            </div>

            <div class="bg-offwhite rounded-xl p-4">
              <div class="font-body text-[.65rem] font-semibold tracking-[.1em] uppercase text-muted mb-3">Allergies
              </div>
              <div class="space-y-2">
                <div class="flex items-center gap-2">
                  <span class="w-4 h-4 rounded-full bg-green-100 flex items-center justify-center shrink-0">
                    <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="3">
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                  </span>
                  <span class="font-body text-[.82rem] text-muted">No known drug allergies</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="w-4 h-4 rounded-full bg-green-100 flex items-center justify-center shrink-0">
                    <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="3">
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                  </span>
                  <span class="font-body text-[.82rem] text-muted">No latex allergy</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="w-4 h-4 rounded-full bg-amber-100 flex items-center justify-center shrink-0">
                    <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="3">
                      <line x1="12" y1="8" x2="12" y2="12" />
                      <line x1="12" y1="16" x2="12.01" y2="16" />
                    </svg>
                  </span>
                  <span class="font-body text-[.82rem] text-muted">Mild sensitivity to cold</span>
                </div>
              </div>
            </div>

            <div class="bg-offwhite rounded-xl p-4">
              <div class="font-body text-[.65rem] font-semibold tracking-[.1em] uppercase text-muted mb-3">Current
                Medications</div>
              <div class="space-y-2">
                <div class="font-body text-[.8rem] text-brand font-medium">None on file</div>
                <div class="font-body text-[.75rem] text-muted leading-relaxed">Last updated: January 10, 2026</div>
              </div>
            </div>

            <div class="bg-offwhite rounded-xl p-4 sm:col-span-2 lg:col-span-3">
              <div class="font-body text-[.65rem] font-semibold tracking-[.1em] uppercase text-muted mb-3">Medical
                History</div>
              <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                <div class="flex items-center gap-2"><span
                    class="w-3 h-3 rounded-full bg-green-400 shrink-0"></span><span
                    class="font-body text-[.8rem] text-muted">Diabetes: None</span></div>
                <div class="flex items-center gap-2"><span
                    class="w-3 h-3 rounded-full bg-green-400 shrink-0"></span><span
                    class="font-body text-[.8rem] text-muted">Heart disease: None</span></div>
                <div class="flex items-center gap-2"><span
                    class="w-3 h-3 rounded-full bg-green-400 shrink-0"></span><span
                    class="font-body text-[.8rem] text-muted">Hypertension: None</span></div>
                <div class="flex items-center gap-2"><span
                    class="w-3 h-3 rounded-full bg-green-400 shrink-0"></span><span
                    class="font-body text-[.8rem] text-muted">Osteoporosis: None</span></div>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ TREATMENT HISTORY ═══ -->
  <div class="rec-section fade-up" data-section="treatments">
    <div class="bg-white rounded-2xl border border-[#e5e7eb] overflow-hidden rec-card">
      <button onclick="toggleSection(this)"
        class="w-full flex items-center justify-between px-5 py-4 cursor-pointer bg-transparent border-none text-left">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-xl bg-green-50 flex items-center justify-center shrink-0">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
            </svg>
          </div>
          <span class="brand-font font-bold text-brand text-[.95rem]">Treatment History</span>
          <span class="font-body text-[.7rem] font-semibold text-muted bg-offwhite px-2 py-0.5 rounded-full">5
            records</span>
        </div>
        <svg class="rec-chevron open w-4 h-4 text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </button>
      <div class="rec-body open">
        <div class="border-t border-[#f0f0f0]">

          <!-- Treatment row -->
          <div
            class="px-5 py-4 flex flex-col sm:flex-row sm:items-start gap-4 border-b border-[#f5f5f7] hover:bg-offwhite/60 transition-colors">
            <div class="flex items-start gap-3 flex-1 min-w-0">
              <div class="w-2 h-2 rounded-full bg-blue-500 mt-2 shrink-0"></div>
              <div class="min-w-0">
                <div class="brand-font font-semibold text-brand text-[.9rem]">Dental Checkup &amp; Cleaning</div>
                <div class="font-body text-[.78rem] text-muted mt-0.5">General Dentistry · Dr. Marcus Rivera</div>
                <div class="font-body text-[.77rem] text-brand/80 mt-1.5 leading-relaxed">No cavities detected. Minor
                  tartar on lower molars — cleaned. Gums healthy. Digital X-ray clear. Recommended fluoride treatment at
                  next visit.</div>
              </div>
            </div>
            <div class="flex sm:flex-col items-center sm:items-end gap-3 sm:gap-1.5 shrink-0 ml-5 sm:ml-0">
              <span
                class="font-body text-[.72rem] font-semibold text-green-600 bg-green-50 px-2.5 py-1 rounded-full whitespace-nowrap">Completed</span>
              <span class="font-body text-[.72rem] text-muted whitespace-nowrap">Jan 10, 2026</span>
            </div>
          </div>

          <div
            class="px-5 py-4 flex flex-col sm:flex-row sm:items-start gap-4 border-b border-[#f5f5f7] hover:bg-offwhite/60 transition-colors">
            <div class="flex items-start gap-3 flex-1 min-w-0">
              <div class="w-2 h-2 rounded-full bg-purple-400 mt-2 shrink-0"></div>
              <div class="min-w-0">
                <div class="brand-font font-semibold text-brand text-[.9rem]">Professional Teeth Whitening</div>
                <div class="font-body text-[.78rem] text-muted mt-0.5">Cosmetic Dentistry · Dr. Leila Santos</div>
                <div class="font-body text-[.77rem] text-brand/80 mt-1.5 leading-relaxed">In-office LED whitening
                  completed. Lightened ~6 shades from baseline. Mild sensitivity during procedure — managed with
                  desensitizing gel. Take-home maintenance kit provided.</div>
              </div>
            </div>
            <div class="flex sm:flex-col items-center sm:items-end gap-3 sm:gap-1.5 shrink-0 ml-5 sm:ml-0">
              <span
                class="font-body text-[.72rem] font-semibold text-green-600 bg-green-50 px-2.5 py-1 rounded-full whitespace-nowrap">Completed</span>
              <span class="font-body text-[.72rem] text-muted whitespace-nowrap">Oct 22, 2025</span>
            </div>
          </div>

          <div
            class="px-5 py-4 flex flex-col sm:flex-row sm:items-start gap-4 border-b border-[#f5f5f7] hover:bg-offwhite/60 transition-colors">
            <div class="flex items-start gap-3 flex-1 min-w-0">
              <div class="w-2 h-2 rounded-full bg-[#f59e0b] mt-2 shrink-0"></div>
              <div class="min-w-0">
                <div class="brand-font font-semibold text-brand text-[.9rem]">Permanent Crown Placement — Tooth #46
                </div>
                <div class="font-body text-[.78rem] text-muted mt-0.5">Restorative · Dr. Marcus Rivera</div>
                <div class="font-body text-[.77rem] text-brand/80 mt-1.5 leading-relaxed">Porcelain-fused-to-metal crown
                  cemented on lower right first molar following root canal. Occlusion checked and adjusted. Patient
                  reported good fit and comfort.</div>
              </div>
            </div>
            <div class="flex sm:flex-col items-center sm:items-end gap-3 sm:gap-1.5 shrink-0 ml-5 sm:ml-0">
              <span
                class="font-body text-[.72rem] font-semibold text-green-600 bg-green-50 px-2.5 py-1 rounded-full whitespace-nowrap">Completed</span>
              <span class="font-body text-[.72rem] text-muted whitespace-nowrap">Aug 5, 2025</span>
            </div>
          </div>

          <div
            class="px-5 py-4 flex flex-col sm:flex-row sm:items-start gap-4 border-b border-[#f5f5f7] hover:bg-offwhite/60 transition-colors">
            <div class="flex items-start gap-3 flex-1 min-w-0">
              <div class="w-2 h-2 rounded-full bg-[#7c3aed] mt-2 shrink-0"></div>
              <div class="min-w-0">
                <div class="brand-font font-semibold text-brand text-[.9rem]">Root Canal Treatment — Tooth #46</div>
                <div class="font-body text-[.78rem] text-muted mt-0.5">Specialized · Dr. Marcus Rivera</div>
                <div class="font-body text-[.77rem] text-brand/80 mt-1.5 leading-relaxed">Infected pulp removed from
                  lower right first molar. Three canals cleaned, shaped, and obturated with gutta-percha. Temporary
                  crown placed. No complications under local anesthesia.</div>
              </div>
            </div>
            <div class="flex sm:flex-col items-center sm:items-end gap-3 sm:gap-1.5 shrink-0 ml-5 sm:ml-0">
              <span
                class="font-body text-[.72rem] font-semibold text-green-600 bg-green-50 px-2.5 py-1 rounded-full whitespace-nowrap">Completed</span>
              <span class="font-body text-[.72rem] text-muted whitespace-nowrap">Jul 8, 2025</span>
            </div>
          </div>

          <div class="px-5 py-4 flex flex-col sm:flex-row sm:items-start gap-4 hover:bg-offwhite/60 transition-colors">
            <div class="flex items-start gap-3 flex-1 min-w-0">
              <div class="w-2 h-2 rounded-full bg-muted mt-2 shrink-0"></div>
              <div class="min-w-0">
                <div class="brand-font font-semibold text-brand text-[.9rem]">New Patient Consultation &amp; Full Exam
                </div>
                <div class="font-body text-[.78rem] text-muted mt-0.5">General Dentistry · Dr. Marcus Rivera</div>
                <div class="font-body text-[.77rem] text-brand/80 mt-1.5 leading-relaxed">Initial new patient intake.
                  Full oral examination, baseline X-rays, periodontal charting. Identified: minor tartar buildup, one
                  tooth (lower right #46) with deep decay requiring root canal. Treatment plan created and discussed.
                </div>
              </div>
            </div>
            <div class="flex sm:flex-col items-center sm:items-end gap-3 sm:gap-1.5 shrink-0 ml-5 sm:ml-0">
              <span
                class="font-body text-[.72rem] font-semibold text-green-600 bg-green-50 px-2.5 py-1 rounded-full whitespace-nowrap">Completed</span>
              <span class="font-body text-[.72rem] text-muted whitespace-nowrap">Jan 15, 2024</span>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>

  <!-- ═══ X-RAYS & SCANS ═══ -->
  <div class="rec-section fade-up" data-section="xrays">
    <div class="bg-white rounded-2xl border border-[#e5e7eb] overflow-hidden rec-card">
      <button onclick="toggleSection(this)"
        class="w-full flex items-center justify-between px-5 py-4 cursor-pointer bg-transparent border-none text-left">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-xl bg-brand flex items-center justify-center shrink-0">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
              <circle cx="8.5" cy="8.5" r="1.5" />
              <polyline points="21 15 16 10 5 21" />
            </svg>
          </div>
          <span class="brand-font font-bold text-brand text-[.95rem]">X-Rays &amp; Scans</span>
          <span class="font-body text-[.7rem] font-semibold text-muted bg-offwhite px-2 py-0.5 rounded-full">3
            files</span>
        </div>
        <svg class="rec-chevron open w-4 h-4 text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </button>
      <div class="rec-body open">
        <div class="px-5 pb-5 border-t border-[#f0f0f0]">
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-4">

            <!-- X-ray card 1 -->
            <div
              class="rounded-xl overflow-hidden border border-[#e5e7eb] hover:border-brand transition-colors group cursor-pointer">
              <div class="xray-shimmer h-36 relative flex items-center justify-center">
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)"
                    stroke-width="1.5">
                    <rect x="3" y="3" width="18" height="18" rx="2" />
                    <circle cx="8.5" cy="8.5" r="1.5" />
                    <polyline points="21 15 16 10 5 21" />
                  </svg>
                </div>
                <div
                  class="absolute top-2.5 right-2.5 w-6 h-6 rounded-full bg-brand/60 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                    <polyline points="15 3 21 3 21 9" />
                    <line x1="10" y1="14" x2="21" y2="3" />
                  </svg>
                </div>
              </div>
              <div class="p-3">
                <div class="brand-font font-semibold text-brand text-[.82rem]">Periapical X-Ray — #46</div>
                <div class="font-body text-[.72rem] text-muted mt-0.5">Pre-root canal assessment</div>
                <div class="flex items-center justify-between mt-2">
                  <span class="font-body text-[.68rem] text-muted">Jul 8, 2025</span>
                  <span
                    class="font-body text-[.65rem] font-semibold text-[#7c3aed] bg-purple-50 px-2 py-0.5 rounded-full">Periapical</span>
                </div>
              </div>
            </div>

            <!-- X-ray card 2 -->
            <div
              class="rounded-xl overflow-hidden border border-[#e5e7eb] hover:border-brand transition-colors group cursor-pointer">
              <div class="xray-shimmer h-36 relative flex items-center justify-center">
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)"
                    stroke-width="1.5">
                    <rect x="3" y="3" width="18" height="18" rx="2" />
                    <circle cx="8.5" cy="8.5" r="1.5" />
                    <polyline points="21 15 16 10 5 21" />
                  </svg>
                </div>
                <div
                  class="absolute top-2.5 right-2.5 w-6 h-6 rounded-full bg-brand/60 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                    <polyline points="15 3 21 3 21 9" />
                    <line x1="10" y1="14" x2="21" y2="3" />
                  </svg>
                </div>
              </div>
              <div class="p-3">
