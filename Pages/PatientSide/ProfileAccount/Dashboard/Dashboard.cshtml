@page "/Profile/Dashboard"
@model DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}


<div class="flex-1 min-w-0 space-y-6">
  <!-- Welcome -->
  <div class="fade-up">
    <div
      class="flex items-center gap-2 font-body text-[0.67rem] font-semibold tracking-[0.15em] uppercase text-muted mb-2"
    >
      <span class="w-2 h-2 rounded-full bg-primary inline-block"></span>Patient
      Portal
    </div>
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-3">
      <div>
        <h1
          class="brand-font font-extrabold text-brand text-[1.8rem] leading-tight"
        >
          Good morning, Juan 👋
        </h1>
        <p class="font-body text-[0.88rem] text-muted mt-1">
          Here's an overview of your dental health and upcoming visits.
        </p>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <span class="w-2 h-2 rounded-full bg-green-400 inline-block"></span>
        <span class="font-body text-[0.78rem] text-muted"
          >Patient since Jan 2024</span
        >
      </div>
    </div>
  </div>

  <!-- Stat cards -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 fade-up">
    <div class="stat-card bg-white rounded-2xl p-5 border border-[#e5e7eb]">
      <div class="flex items-start justify-between mb-3">
        <div
          class="w-9 h-9 rounded-xl bg-blue-50 flex items-center justify-center"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#3b82f6"
            stroke-width="2"
          >
            <rect x="3" y="4" width="18" height="18" rx="2" />
            <line x1="16" y1="2" x2="16" y2="6" />
            <line x1="8" y1="2" x2="8" y2="6" />
            <line x1="3" y1="10" x2="21" y2="10" />
          </svg>
        </div>
        <span
          class="font-body text-[0.65rem] font-semibold text-blue-500 bg-blue-50 px-2 py-0.5 rounded-full"
          >+1 this year</span
        >
      </div>
      <div
        class="brand-font font-extrabold text-brand text-[1.8rem] leading-none"
      >
        6
      </div>
      <div class="font-body text-[0.73rem] text-muted mt-1.5">
        Total Appointments
      </div>
    </div>

    <div class="stat-card bg-white rounded-2xl p-5 border border-[#e5e7eb]">
      <div class="flex items-start justify-between mb-3">
        <div
          class="w-9 h-9 rounded-xl bg-green-50 flex items-center justify-center"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#16a34a"
            stroke-width="2"
          >
            <polyline points="20 6 9 17 4 12" />
          </svg>
        </div>
        <span
          class="font-body text-[0.65rem] font-semibold text-green-600 bg-green-50 px-2 py-0.5 rounded-full"
          >4 done</span
        >
      </div>
      <div
        class="brand-font font-extrabold text-brand text-[1.8rem] leading-none"
      >
        1
      </div>
      <div class="font-body text-[0.73rem] text-muted mt-1.5">
        Upcoming Visit
      </div>
    </div>

    <div class="stat-card bg-white rounded-2xl p-5 border border-[#e5e7eb]">
      <div class="flex items-start justify-between mb-3">
        <div
          class="w-9 h-9 rounded-xl bg-red-50 flex items-center justify-center"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#c0392b"
            stroke-width="2"
          >
            <polyline points="20 12 20 22 4 22 4 12" />
            <rect x="2" y="7" width="20" height="5" />
            <path d="M12 22V7" />
          </svg>
        </div>
        <span
          class="font-body text-[0.65rem] font-semibold text-primary bg-red-50 px-2 py-0.5 rounded-full"
          >Active</span
        >
      </div>
      <div
        class="brand-font font-extrabold text-primary text-[1.8rem] leading-none"
      >
        20%
      </div>
      <div class="font-body text-[0.73rem] text-muted mt-1.5">
        Member Discount
      </div>
    </div>

    <div class="stat-card bg-white rounded-2xl p-5 border border-[#e5e7eb]">
      <div class="flex items-start justify-between mb-3">
        <div
          class="w-9 h-9 rounded-xl bg-[#fef3c7] flex items-center justify-center"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b">
            <polygon
              points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
            />
          </svg>
        </div>
        <span
          class="font-body text-[0.65rem] font-semibold text-[#b45309] bg-[#fef3c7] px-2 py-0.5 rounded-full"
          >4 reviews</span
        >
      </div>
      <div
        class="brand-font font-extrabold text-brand text-[1.8rem] leading-none"
      >
        4.8
      </div>
      <div class="font-body text-[0.73rem] text-muted mt-1.5">Avg. Rating</div>
    </div>
  </div>

  <!-- Next appointment + Quick actions -->
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-5 fade-up">
    <!-- Next appointment -->
    <div
      class="lg:col-span-3 bg-brand rounded-2xl p-6 relative overflow-hidden"
    >
      <div
        class="absolute inset-0 opacity-[0.04]"
        style="
          background-image:
            linear-gradient(rgba(255, 255, 255, 1) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255, 255, 255, 1) 1px, transparent 1px);
          background-size: 32px 32px;
        "
      ></div>
      <div
        class="absolute -right-10 -bottom-10 w-40 h-40 rounded-full bg-primary/10 pointer-events-none"
      ></div>
      <div class="relative z-10">
        <div
          class="flex items-center gap-2 font-body text-[0.65rem] font-semibold tracking-[0.15em] uppercase text-white/40 mb-4"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-primary inline-block"></span
          >Next Appointment
        </div>
        <div class="flex items-start justify-between gap-4 mb-5">
          <div>
            <h3
              class="brand-font font-bold text-white text-[1.3rem] leading-tight mb-1"
            >
              Teeth Cleaning
            </h3>
            <div class="font-body text-[0.82rem] text-white/55">
              General Dentistry · Dr. Marcus Rivera
            </div>
          </div>
          <span
            class="font-body text-[0.65rem] font-semibold uppercase tracking-wider bg-blue-500/20 text-blue-300 px-3 py-1 rounded-full shrink-0"
            >Upcoming</span
          >
        </div>
        <div class="flex flex-wrap gap-3 mb-6">
          <div
            class="flex items-center gap-2 rounded-xl px-3 py-2"
            style="background: rgba(255, 255, 255, 0.08)"
          >
            <svg
              width="13"
              height="13"
              viewBox="0 0 24 24"
              fill="none"
              stroke="white"
              stroke-width="2"
            >
              <rect x="3" y="4" width="18" height="18" rx="2" />
              <line x1="16" y1="2" x2="16" y2="6" />
              <line x1="8" y1="2" x2="8" y2="6" />
              <line x1="3" y1="10" x2="21" y2="10" />
            </svg>
            <span class="font-body text-[0.8rem] text-white font-medium"
              >April 15, 2026</span
            >
          </div>
          <div
            class="flex items-center gap-2 rounded-xl px-3 py-2"
            style="background: rgba(255, 255, 255, 0.08)"
          >
            <svg
              width="13"
              height="13"
              viewBox="0 0 24 24"
              fill="none"
              stroke="white"
              stroke-width="2"
            >
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </svg>
            <span class="font-body text-[0.8rem] text-white font-medium"
              >10:00 AM</span
            >
          </div>
          <div
            class="flex items-center gap-2 rounded-xl px-3 py-2"
            style="background: rgba(255, 255, 255, 0.08)"
          >
            <svg
              width="13"
              height="13"
              viewBox="0 0 24 24"
              fill="none"
              stroke="white"
              stroke-width="2"
            >
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            <span class="font-body text-[0.8rem] text-white font-medium"
              >SDC — Quezon City</span
            >
          </div>
        </div>
        <div class="flex gap-3">
          <button
            class="flex-1 brand-font font-bold text-[0.75rem] tracking-wider uppercase bg-primary text-white py-2.5 rounded-xl hover:opacity-90 transition-opacity cursor-pointer border-none"
          >
            Get Directions
          </button>
          <a
            href="appointments.html"
            class="flex-1 brand-font font-bold text-[0.75rem] tracking-wider uppercase border border-white/20 text-white py-2.5 rounded-xl hover:bg-white/10 transition-colors no-underline flex items-center justify-center"
            >View All →</a
          >
        </div>
      </div>
    </div>

    <!-- Quick actions grid -->
    <div class="lg:col-span-2 grid grid-cols-2 gap-3 content-start">
      <a
        href="appointment/index.html"
        class="action-card bg-white rounded-2xl p-4 border border-[#e5e7eb] no-underline flex flex-col items-start gap-3"
      >
        <div
          class="w-9 h-9 rounded-xl bg-brand flex items-center justify-center"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="white"
            stroke-width="2"
          >
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
          </svg>
        </div>
        <div>
          <div class="brand-font font-bold text-brand text-[0.85rem]">Book</div>
          <div class="font-body text-[0.72rem] text-muted">Appointment</div>
        </div>
      </a>
      <a
        href="records.html"
        class="action-card bg-white rounded-2xl p-4 border border-[#e5e7eb] no-underline flex flex-col items-start gap-3"
      >
        <div
          class="w-9 h-9 rounded-xl bg-blue-50 flex items-center justify-center"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#3b82f6"
            stroke-width="2"
          >
            <path
              d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
            />
            <polyline points="14 2 14 8 20 8" />
          </svg>
        </div>
        <div>
          <div class="brand-font font-bold text-brand text-[0.85rem]">View</div>
          <div class="font-body text-[0.72rem] text-muted">Dental Records</div>
        </div>
      </a>
      <a
        href="prescriptions.html"
        class="action-card bg-white rounded-2xl p-4 border border-[#e5e7eb] no-underline flex flex-col items-start gap-3"
      >
        <div
          class="w-9 h-9 rounded-xl bg-green-50 flex items-center justify-center"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#16a34a"
            stroke-width="2"
          >
            <path
              d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"
            />
          </svg>
        </div>
        <div>
          <div class="brand-font font-bold text-brand text-[0.85rem]">My</div>
          <div class="font-body text-[0.72rem] text-muted">Prescriptions</div>
        </div>
      </a>
      <a
        href="contact.html"
        class="action-card bg-white rounded-2xl p-4 border border-[#e5e7eb] no-underline flex flex-col items-start gap-3"
      >
        <div
          class="w-9 h-9 rounded-xl bg-red-50 flex items-center justify-center"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#c0392b"
            stroke-width="2"
          >
            <path
              d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.18 6.18l.95-.93a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
            />
          </svg>
        </div>
        <div>
          <div class="brand-font font-bold text-brand text-[0.85rem]">
            Contact
          </div>
          <div class="font-body text-[0.72rem] text-muted">Clinic Support</div>
        </div>
      </a>
    </div>
  </div>

  <!-- Oral health + Activity -->
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-5 fade-up">
    <!-- Oral health -->
    <div class="lg:col-span-2 bg-white rounded-2xl p-6 border border-[#e5e7eb]">
      <div
        class="flex items-center gap-2 font-body text-[0.67rem] font-semibold tracking-[0.15em] uppercase text-muted mb-5"
      >
        <span class="w-2 h-2 rounded-full bg-primary inline-block"></span>Oral
        Health Summary
      </div>

      <!-- Score ring -->
      <div class="flex items-center gap-5 mb-6">
        <div class="relative shrink-0">
          <svg width="80" height="80" viewBox="0 0 80 80">
            <circle
              cx="40"
              cy="40"
              r="34"
              fill="none"
              stroke="#e5e7eb"
              stroke-width="7"
            />
            <circle
              id="scoreRing"
              cx="40"
              cy="40"
              r="34"
              fill="none"
              stroke="#c0392b"
              stroke-width="7"
              stroke-linecap="round"
              stroke-dasharray="220"
              stroke-dashoffset="220"
              style="
                transform: rotate(-90deg);
                transform-origin: center;
                transition: stroke-dashoffset 1.2s ease 0.3s;
              "
            />
          </svg>
          <div
            class="absolute inset-0 flex flex-col items-center justify-center"
          >
            <span
              class="brand-font font-extrabold text-brand text-[1.1rem] leading-none"
              >85</span
            >
            <span class="font-body text-[0.58rem] text-muted mt-0.5"
              >/ 100</span
            >
          </div>
        </div>
        <div>
          <div class="brand-font font-bold text-brand text-[1rem] mb-0.5">
            Good
          </div>
          <div class="font-body text-[0.78rem] text-muted leading-relaxed">
            Your oral health is on track. Keep up with regular cleanings.
          </div>
        </div>
      </div>

      <!-- Metrics -->
      <div class="space-y-3.5">
        <div>
          <div class="flex justify-between mb-1.5">
            <span class="font-body text-[0.78rem] text-brand">Gum Health</span>
            <span class="font-body text-[0.75rem] font-semibold text-green-600"
              >Healthy</span
            >
          </div>
          <div class="prog-bar">
            <div class="prog-fill bg-green-500" data-width="90%"></div>
          </div>
        </div>
        <div>
          <div class="flex justify-between mb-1.5">
            <span class="font-body text-[0.78rem] text-brand">Cavity Risk</span>
            <span class="font-body text-[0.75rem] font-semibold text-green-600"
              >Low</span
            >
          </div>
          <div class="prog-bar">
            <div class="prog-fill bg-green-400" data-width="20%"></div>
          </div>
        </div>
        <div>
          <div class="flex justify-between mb-1.5">
            <span class="font-body text-[0.78rem] text-brand"
              >Enamel Strength</span
            >
            <span class="font-body text-[0.75rem] font-semibold text-[#b45309]"
              >Fair</span
            >
          </div>
          <div class="prog-bar">
            <div class="prog-fill bg-[#f59e0b]" data-width="62%"></div>
          </div>
        </div>
        <div>
          <div class="flex justify-between mb-1.5">
            <span class="font-body text-[0.78rem] text-brand"
              >Plaque Control</span
            >
            <span class="font-body text-[0.75rem] font-semibold text-blue-600"
              >Good</span
            >
          </div>
          <div class="prog-bar">
            <div class="prog-fill bg-blue-500" data-width="78%"></div>
          </div>
        </div>
      </div>

      <div class="mt-5 pt-4 border-t border-[#e5e7eb]">
        <div
          class="font-body text-[0.68rem] font-semibold tracking-[0.1em] uppercase text-muted mb-2"
        >
          Last assessed by
        </div>
        <div class="flex items-center gap-2.5">
          <img
            src="https://randomuser.me/api/portraits/men/46.jpg"
            class="w-7 h-7 rounded-full object-cover border border-[#e5e7eb]"
            alt=""
          />
          <span class="font-body text-[0.8rem] text-brand"
            >Dr. Marcus Rivera
            <span class="text-muted font-normal">· Jan 10, 2026</span></span
          >
        </div>
      </div>
    </div>

    <!-- Activity timeline -->
    <div class="lg:col-span-3 bg-white rounded-2xl p-6 border border-[#e5e7eb]">
      <div class="flex items-center justify-between mb-5">
        <div
          class="flex items-center gap-2 font-body text-[0.67rem] font-semibold tracking-[0.15em] uppercase text-muted"
        >
          <span class="w-2 h-2 rounded-full bg-primary inline-block"></span
          >Recent Activity
        </div>
        <a
          href="appointments.html"
          class="font-body text-[0.75rem] text-primary hover:underline no-underline"
          >View all →</a
        >
      </div>

      <div class="space-y-0">
        <!-- Item 1 -->
        <div class="flex gap-4 pb-5 relative">
          <div class="relative shrink-0">
            <div
              class="w-6 h-6 rounded-full bg-blue-500 flex items-center justify-center z-10 relative"
            >
              <svg
                width="10"
                height="10"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="2.5"
              >
                <rect x="3" y="4" width="18" height="18" rx="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
              </svg>
            </div>
            <div
              class="absolute left-[11px] top-6 bottom-0 w-px bg-[#e5e7eb]"
            ></div>
          </div>
          <div class="flex-1 pt-0.5">
            <div class="flex items-start justify-between gap-2">
              <div>
                <div class="brand-font font-semibold text-brand text-[0.88rem]">
                  Teeth Cleaning — Booked
                </div>
                <div class="font-body text-[0.75rem] text-muted mt-0.5">
                  April 15, 2026 · Dr. Marcus Rivera
                </div>
              </div>
              <span
                class="font-body text-[0.65rem] text-blue-500 bg-blue-50 px-2 py-0.5 rounded-full shrink-0"
                >Upcoming</span
              >
            </div>
            <div class="font-body text-[0.68rem] text-muted mt-1.5">
              April 2, 2026
            </div>
          </div>
        </div>
        <!-- Item 2 -->
        <div class="flex gap-4 pb-5 relative">
          <div class="relative shrink-0">
            <div
              class="w-6 h-6 rounded-full bg-green-500 flex items-center justify-center z-10 relative"
            >
              <svg
                width="10"
                height="10"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="2.5"
              >
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </div>
            <div
              class="absolute left-[11px] top-6 bottom-0 w-px bg-[#e5e7eb]"
            ></div>
          </div>
          <div class="flex-1 pt-0.5">
            <div class="flex items-start justify-between gap-2">
              <div>
                <div class="brand-font font-semibold text-brand text-[0.88rem]">
                  Dental Checkup — Completed
                </div>
                <div class="font-body text-[0.75rem] text-muted mt-0.5">
                  No cavities. Enamel in good condition. · Dr. Rivera
                </div>
              </div>
              <span
                class="font-body text-[0.65rem] text-green-600 bg-green-50 px-2 py-0.5 rounded-full shrink-0"
                >Done</span
              >
            </div>
            <div class="font-body text-[0.68rem] text-muted mt-1.5">
              January 10, 2026
            </div>
          </div>
        </div>
        <!-- Item 3 -->
        <div class="flex gap-4 pb-5 relative">
          <div class="relative shrink-0">
            <div
              class="w-6 h-6 rounded-full bg-green-500 flex items-center justify-center z-10 relative"
            >
              <svg
                width="10"
                height="10"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="2.5"
              >
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </div>
            <div
              class="absolute left-[11px] top-6 bottom-0 w-px bg-[#e5e7eb]"
            ></div>
          </div>
          <div class="flex-1 pt-0.5">
            <div class="flex items-start justify-between gap-2">
              <div>
                <div class="brand-font font-semibold text-brand text-[0.88rem]">
                  Teeth Whitening — Completed
                </div>
                <div class="font-body text-[0.75rem] text-muted mt-0.5">
                  6 shades lighter. Take-home kit provided. · Dr. Santos
                </div>
              </div>
              <span
                class="font-body text-[0.65rem] text-green-600 bg-green-50 px-2 py-0.5 rounded-full shrink-0"
                >Done</span
              >
            </div>
            <div class="font-body text-[0.68rem] text-muted mt-1.5">
              October 22, 2025
            </div>
          </div>
        </div>
        <!-- Item 4 -->
        <div class="flex gap-4 pb-5 relative">
          <div class="relative shrink-0">
            <div
              class="w-6 h-6 rounded-full bg-green-500 flex items-center justify-center z-10 relative"
            >
              <svg
                width="10"
                height="10"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="2.5"
              >
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </div>
            <div
