@page "/Profile/Dashboard"
@model DashboardModel
@{
ViewData["Title"] = "Dashboard";
}

<script>
  // If the server didn't find a User, but we have one in Local Storage
  const localUser = JSON.parse(localStorage.getItem("sb_user"));
  const urlParams = new URLSearchParams(window.location.search);

  // If the ID isn't in the URL yet, reload with the ID so C# can see it
  if (localUser && localUser.id && !urlParams.has('uid')) {
    window.location.href = window.location.pathname + "?uid=" + localUser.id;
  }
</script>

<div class="flex-1 min-w-0 space-y-6">
  <!-- Welcome -->
  <div class="fade-up">
    <div
      class="flex items-center gap-2 font-body text-[0.67rem] font-semibold tracking-[0.15em] uppercase text-muted mb-2">
      <span class="w-2 h-2 rounded-full bg-primary inline-block"></span>Patient
      Portal
    </div>
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-3">
      <div>
        <h1 class="brand-font font-extrabold text-brand text-[1.8rem] leading-tight">
          Welcome back, @Model.PatientName 👋
        </h1>
        <p class="font-body text-[0.88rem] text-muted mt-1">
          Here's an overview of your dental health and upcoming visits.
        </p>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <span class="w-2 h-2 rounded-full bg-green-400 inline-block"></span>
        <span class="font-body text-[0.78rem] text-muted">Active Patient</span>
      </div>
    </div>
  </div>

  <!-- Stat cards -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 fade-up">
    <div class="stat-card bg-white rounded-2xl p-5 border border-[#e5e7eb]">
      <div class="flex items-start justify-between mb-3">
        <div class="w-9 h-9 rounded-xl bg-blue-50 flex items-center justify-center">
          <i class="fa-solid fa-calendar-days text-blue-500"></i>
        </div>
      </div>
      <div class="brand-font font-extrabold text-brand text-[1.8rem] leading-none">
        @Model.TotalCount
      </div>
      <div class="font-body text-[0.73rem] text-muted mt-1.5">
        Total Appointments
      </div>
    </div>

    <div class="stat-card bg-white rounded-2xl p-5 border border-[#e5e7eb]">
      <div class="flex items-start justify-between mb-3">
        <div class="w-9 h-9 rounded-xl bg-green-50 flex items-center justify-center">
          <i class="fa-solid fa-clock-rotate-left text-green-600"></i>
        </div>
      </div>
      <div class="brand-font font-extrabold text-brand text-[1.8rem] leading-none">
        @Model.UpcomingCount
      </div>
      <div class="font-body text-[0.73rem] text-muted mt-1.5">
        Upcoming Visits
      </div>
    </div>

    <div class="stat-card bg-white rounded-2xl p-5 border border-[#e5e7eb]">
      <div class="flex items-start justify-between mb-3">
        <div class="w-9 h-9 rounded-xl bg-red-50 flex items-center justify-center">
           <i class="fa-solid fa-check text-primary"></i>
        </div>
      </div>
      <div class="brand-font font-extrabold text-brand text-[1.8rem] leading-none">
        @Model.CompletedCount
      </div>
      <div class="font-body text-[0.73rem] text-muted mt-1.5">
        Completed
      </div>
    </div>

    <div class="stat-card bg-white rounded-2xl p-5 border border-[#e5e7eb]">
      <div class="flex items-start justify-between mb-3">
        <div class="w-9 h-9 rounded-xl bg-[#fef3c7] flex items-center justify-center">
          <i class="fa-solid fa-star text-star"></i>
        </div>
      </div>
      <div class="brand-font font-extrabold text-brand text-[1.8rem] leading-none">
        4.8
      </div>
      <div class="font-body text-[0.73rem] text-muted mt-1.5">Avg. Rating</div>
    </div>
  </div>

  <!-- Next appointment + Quick actions -->
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-5 fade-up">
    <!-- Next appointment -->
    <div class="lg:col-span-3 bg-brand rounded-2xl p-6 relative overflow-hidden">
      @if (Model.NextAppointment != null)
      {
      <div class="absolute inset-0 opacity-[0.04]" style="
          background-image:
            linear-gradient(rgba(255, 255, 255, 1) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255, 255, 255, 1) 1px, transparent 1px);
          background-size: 32px 32px;
        "></div>
      <div class="absolute -right-10 -bottom-10 w-40 h-40 rounded-full bg-primary/10 pointer-events-none"></div>
      <div class="relative z-10">
        <div
          class="flex items-center gap-2 font-body text-[0.65rem] font-semibold tracking-[0.15em] uppercase text-white/40 mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-primary inline-block"></span>Next Appointment
        </div>
        <div class="flex items-start justify-between gap-4 mb-5">
          <div>
            <h3 class="brand-font font-bold text-white text-[1.3rem] leading-tight mb-1">
              @Model.NextAppointment.ServiceName
            </h3>
            <div class="font-body text-[0.82rem] text-white/55">
              @(Model.NextAppointment.Doctor?.Profile != null ? $"{Model.NextAppointment.Doctor.Title} {Model.NextAppointment.Doctor.Profile.FirstName} {Model.NextAppointment.Doctor.Profile.LastName}" : "Unassigned")
            </div>
          </div>
          @{
            var ns = Model.NextAppointment.Status.ToLower();
            var nextStatusClass = ns switch {
              "confirmed" => "bg-emerald-500/20 text-emerald-300",
              "pending"   => "bg-orange-500/20 text-orange-300",
              "arrived"   => "bg-yellow-500/20 text-yellow-300",
              "completed" => "bg-blue-500/20 text-blue-300",
              "no-show"   => "bg-slate-500/20 text-slate-300",
              "cancelled" => "bg-red-500/20 text-red-300",
              _           => "bg-blue-500/20 text-blue-300"
            };
          }
          <span class="font-body text-[0.65rem] font-semibold uppercase tracking-wider @nextStatusClass px-3 py-1 rounded-full shrink-0">@Model.NextAppointment.Status</span>
        </div>
        <div class="flex flex-wrap gap-3 mb-6">
          <div class="flex items-center gap-2 rounded-xl px-3 py-2" style="background: rgba(255, 255, 255, 0.08)">
            <i class="fa-regular fa-calendar text-white text-[12px]"></i>
            <span class="font-body text-[0.8rem] text-white font-medium">@Model.NextAppointment.AppointmentDate.ToString("MMMM dd, yyyy")</span>
          </div>
          <div class="flex items-center gap-2 rounded-xl px-3 py-2" style="background: rgba(255, 255, 255, 0.08)">
            <i class="fa-regular fa-clock text-white text-[12px]"></i>
            <span class="font-body text-[0.8rem] text-white font-medium">@Model.NextAppointment.AppointmentTime</span>
          </div>
          <div class="flex items-center gap-2 rounded-xl px-3 py-2" style="background: rgba(255, 255, 255, 0.08)">
            <i class="fa-solid fa-location-dot text-white text-[12px]"></i>
            <span class="font-body text-[0.8rem] text-white font-medium">SDC — Quezon City</span>
          </div>
        </div>
        <div class="flex gap-3">
          <button id="getDirections"
            class="flex-1 brand-font font-bold text-[0.75rem] tracking-wider uppercase bg-primary text-white py-2.5 rounded-xl hover:opacity-90 transition-opacity cursor-pointer border-none">
            Get Directions
          </button>
          <a href="/Profile/MyAppointments"
            class="flex-1 brand-font font-bold text-[0.75rem] tracking-wider uppercase border border-white/20 text-white py-2.5 rounded-xl hover:bg-white/10 transition-colors no-underline flex items-center justify-center">View
            Details</a>
        </div>
      </div>
      }
      else
      {
        <div class="h-full flex flex-col items-center justify-center text-center py-10">
            <div class="w-14 h-14 rounded-full bg-white/5 flex items-center justify-center mb-4">
                <i class="fa-solid fa-calendar-plus text-white/20 text-xl"></i>
            </div>
            <h3 class="brand-font font-bold text-white text-[1.1rem] mb-2">No Upcoming Visits</h3>
            <p class="font-body text-[0.85rem] text-white/40 mb-6 max-w-[240px]">It's been a while! Schedule your next checkup to keep your smile bright.</p>
            <a href="/Appointments" class="brand-font font-bold text-[0.75rem] tracking-wider uppercase bg-primary text-white px-8 py-3 rounded-xl hover:opacity-90 transition-all no-underline">
                Book Now
            </a>
        </div>
      }
    </div>

    <!-- Quick actions grid -->
    <div class="lg:col-span-2 grid grid-cols-2 gap-3 content-start">
      <a href="/Appointments"
        class="action-card bg-white rounded-2xl p-4 border border-[#e5e7eb] no-underline flex flex-col items-start gap-3 transition-all hover:border-primary/30 hover:shadow-sm">
        <div class="w-9 h-9 rounded-xl bg-brand flex items-center justify-center">
           <i class="fa-solid fa-plus text-white text-sm"></i>
        </div>
        <div>
          <div class="brand-font font-bold text-brand text-[0.85rem]">Book</div>
          <div class="font-body text-[0.72rem] text-muted">Appointment</div>
        </div>
      </a>
      <a href="/Profile/Records"
        class="action-card bg-white rounded-2xl p-4 border border-[#e5e7eb] no-underline flex flex-col items-start gap-3 transition-all hover:border-primary/30 hover:shadow-sm">
        <div class="w-9 h-9 rounded-xl bg-blue-50 flex items-center justify-center">
           <i class="fa-solid fa-file-medical text-primary text-sm"></i>
        </div>
        <div>
          <div class="brand-font font-bold text-brand text-[0.85rem]">View</div>
          <div class="font-body text-[0.72rem] text-muted">Dental Records</div>
        </div>
      </a>
      <a href="/Profile/Prescriptions"
        class="action-card bg-white rounded-2xl p-4 border border-[#e5e7eb] no-underline flex flex-col items-start gap-3 transition-all hover:border-primary/30 hover:shadow-sm">
        <div class="w-9 h-9 rounded-xl bg-green-50 flex items-center justify-center">
           <i class="fa-solid fa-prescription text-green-600 text-sm"></i>
        </div>
        <div>
          <div class="brand-font font-bold text-brand text-[0.85rem]">My</div>
          <div class="font-body text-[0.72rem] text-muted">Prescriptions</div>
        </div>
      </a>
      <a href="/Profile/Contact"
        class="action-card bg-white rounded-2xl p-4 border border-[#e5e7eb] no-underline flex flex-col items-start gap-3 transition-all hover:border-primary/30 hover:shadow-sm">
        <div class="w-9 h-9 rounded-xl bg-red-50 flex items-center justify-center">
           <i class="fa-solid fa-headset text-primary text-sm"></i>
        </div>
        <div>
          <div class="brand-font font-bold text-brand text-[0.85rem]">
            Contact
          </div>
          <div class="font-body text-[0.72rem] text-muted">Clinic Support</div>
        </div>
      </a>
    </div>
  </div>

  <!-- Oral health + Activity -->
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-5 fade-up">
    <!-- Oral health -->
    <div class="lg:col-span-2 bg-white rounded-2xl p-6 border border-[#e5e7eb]">
      <div
        class="flex items-center gap-2 font-body text-[0.67rem] font-semibold tracking-[0.15em] uppercase text-muted mb-5">
        <span class="w-2 h-2 rounded-full bg-primary inline-block"></span>Oral
        Health Summary
      </div>

      <!-- Score ring -->
      <div class="flex items-center gap-5 mb-6">
        <div class="relative shrink-0">
          <svg width="80" height="80" viewBox="0 0 80 80">
            <circle cx="40" cy="40" r="34" fill="none" stroke="#e5e7eb" stroke-width="7" />
            <circle id="scoreRing" cx="40" cy="40" r="34" fill="none" stroke="#c0392b" stroke-width="7"
              stroke-linecap="round" stroke-dasharray="220" stroke-dashoffset="220" style="
                transform: rotate(-90deg);
                transform-origin: center;
                transition: stroke-dashoffset 1.2s ease 0.3s;
              " />
          </svg>
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <span class="brand-font font-extrabold text-brand text-[1.1rem] leading-none">85</span>
            <span class="font-body text-[0.58rem] text-muted mt-0.5">/ 100</span>
          </div>
        </div>
        <div>
          <div class="brand-font font-bold text-brand text-[1rem] mb-0.5">
            Good
          </div>
          <div class="font-body text-[0.78rem] text-muted leading-relaxed">
            Your oral health is on track. Keep up with regular cleanings.
          </div>
        </div>
      </div>

      <!-- Metrics -->
      <div class="space-y-3.5">
        <div>
          <div class="flex justify-between mb-1.5">
            <span class="font-body text-[0.78rem] text-brand">Gum Health</span>
            <span class="font-body text-[0.75rem] font-semibold text-green-600">Healthy</span>
          </div>
          <div class="prog-bar">
            <div class="prog-fill bg-green-500" data-width="90%"></div>
          </div>
        </div>
        <div>
          <div class="flex justify-between mb-1.5">
            <span class="font-body text-[0.78rem] text-brand">Cavity Risk</span>
            <span class="font-body text-[0.75rem] font-semibold text-green-600">Low</span>
          </div>
          <div class="prog-bar">
            <div class="prog-fill bg-green-400" data-width="20%"></div>
          </div>
        </div>
        <div>
          <div class="flex justify-between mb-1.5">
            <span class="font-body text-[0.78rem] text-brand">Enamel Strength</span>
            <span class="font-body text-[0.75rem] font-semibold text-[#b45309]">Fair</span>
          </div>
          <div class="prog-bar">
            <div class="prog-fill bg-[#f59e0b]" data-width="62%"></div>
          </div>
        </div>
        <div>
          <div class="flex justify-between mb-1.5">
            <span class="font-body text-[0.78rem] text-brand">Plaque Control</span>
            <span class="font-body text-[0.75rem] font-semibold text-blue-600">Good</span>
          </div>
          <div class="prog-bar">
            <div class="prog-fill bg-blue-500" data-width="78%"></div>
          </div>
        </div>
      </div>

      <div class="mt-5 pt-4 border-t border-[#e5e7eb]">
        <div class="font-body text-[0.68rem] font-semibold tracking-[0.1em] uppercase text-muted mb-2">
          Last assessed by
        </div>
        <div class="flex items-center gap-2.5">
          <img src="https://randomuser.me/api/portraits/men/46.jpg"
            class="w-7 h-7 rounded-full object-cover border border-[#e5e7eb]" alt="" />
          <span class="font-body text-[0.8rem] text-brand">Dr. Marcus Rivera
            <span class="text-muted font-normal">· Jan 10, 2026</span></span>
        </div>
      </div>
    </div>

    <!-- Activity timeline -->
    <div class="lg:col-span-3 bg-white rounded-2xl p-6 border border-[#e5e7eb]">
      <div class="flex items-center justify-between mb-5">
        <div
          class="flex items-center gap-2 font-body text-[0.67rem] font-semibold tracking-[0.15em] uppercase text-muted">
          <span class="w-2 h-2 rounded-full bg-primary inline-block"></span>Recent Activity
        </div>
        <a href="/Profile/MyAppointments" class="font-body text-[0.75rem] text-primary hover:underline no-underline">View all
          →</a>
      </div>

      <div class="space-y-0">
        @if (!Model.Appointments.Any())
        {
            <div class="py-10 text-center">
                <p class="text-muted font-body text-[0.85rem]">No recent activity found.</p>
            </div>
        }
        else
        {
            @foreach (var appt in Model.Appointments.Take(5))
            {
                var s = appt.Status.ToLower();
                var (iconClass, icon, badgeClass) = s switch {
                    "confirmed" => ("bg-emerald-500", "fa-calendar-check", "text-emerald-600 bg-emerald-50"),
                    "pending"   => ("bg-orange-500", "fa-clock", "text-orange-600 bg-orange-50"),
                    "arrived"   => ("bg-yellow-500", "fa-person-walking-arrow-right", "text-yellow-700 bg-yellow-50"),
                    "completed" => ("bg-blue-500", "fa-circle-check", "text-blue-600 bg-blue-50"),
                    "no-show"   => ("bg-slate-500", "fa-user-slash", "text-slate-600 bg-slate-50"),
                    "cancelled" => ("bg-red-500", "fa-xmark", "text-red-600 bg-red-50"),
                    _           => ("bg-slate-400", "fa-calendar", "text-slate-500 bg-slate-50")
                };

                <div class="flex gap-4 pb-5 relative last:pb-0">
                  <div class="relative shrink-0">
                    <div class="w-6 h-6 rounded-full @iconClass flex items-center justify-center z-10 relative">
                       <i class="fa-solid @icon text-white text-[10px]"></i>
                    </div>
                    <div class="absolute left-[11px] top-6 bottom-0 w-px bg-[#e5e7eb] group-last:hidden"></div>
                  </div>
                  <div class="flex-1 pt-0.5">
                    <div class="flex items-start justify-between gap-2">
                      <div>
                        <div class="brand-font font-semibold text-brand text-[0.88rem] @(s == "cancelled" ? "line-through text-muted" : "")">
                          @appt.ServiceName — @appt.Status
                        </div>
                        <div class="font-body text-[0.75rem] text-muted mt-0.5">
                          @appt.AppointmentDate.ToString("MMM dd, yyyy") · @(appt.Doctor?.Profile != null ? $"{appt.Doctor.Title} {appt.Doctor.Profile.FirstName} {appt.Doctor.Profile.LastName}" : "Unassigned")
                        </div>
                      </div>
                      <span
                        class="font-body text-[0.65rem] @badgeClass px-2 py-0.5 rounded-full shrink-0 uppercase font-bold tracking-tighter">@appt.Status</span>
                    </div>
                    <div class="font-body text-[0.68rem] text-muted mt-1.5">
                       Booked: @appt.CreatedAt.ToString("MMM dd, yyyy")
                    </div>
                  </div>
                </div>
            }
        }
      </div>
    </div>
  </div>

  <!-- Promo banner -->
  <div class="fade-up bg-white rounded-2xl border border-[#e5e7eb] overflow-hidden">
    <div class="flex flex-col sm:flex-row items-center gap-5 p-5">
      <div class="w-12 h-12 rounded-2xl bg-primary flex items-center justify-center shrink-0">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 12 20 22 4 22 4 12" />
          <rect x="2" y="7" width="20" height="5" />
          <path d="M12 22V7" />
          <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z" />
          <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z" />
        </svg>
      </div>
      <div class="flex-1 text-center sm:text-left">
        <div class="brand-font font-bold text-brand text-[1rem]">
          New Patient Promo — 20% OFF your next visit
        </div>
        <div class="font-body text-[0.82rem] text-muted mt-0.5">
          Use code <strong class="text-brand font-semibold">NEW20</strong> when
          booking. Valid until May 31, 2026.
        </div>
      </div>
      <a href="/Appointments"
        class="brand-font font-bold text-[0.75rem] tracking-wider uppercase bg-brand text-white px-6 py-3 rounded-xl hover:bg-primary transition-colors no-underline shrink-0">Book
        Now →</a>
    </div>
  </div>
</div>

<script type="module" src="~/js/PatientSide/dashboard.js" asp-append-version="true"></script>

<!-- /main -->