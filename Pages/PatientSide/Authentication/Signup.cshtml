@page "/sign-up"
@model SignupModel
@{
Layout = "_AuthLayout";
}

<div class="hidden lg:flex lg:w-[44%] bg-brand flex-col justify-between p-12 relative overflow-hidden shrink-0">
  <div class="absolute inset-0 bg-grid"></div>
  <div class="absolute -bottom-40 -left-40 w-96 h-96 rounded-full bg-primary/15 blur-3xl pointer-events-none"></div>
  <div class="absolute top-20 -right-24 w-64 h-64 rounded-full bg-primary/08 blur-2xl pointer-events-none"></div>

  <a href="../"
    class="brand-font flex items-center gap-2.5 font-extrabold text-[1rem] tracking-[0.07em] uppercase text-white no-underline relative z-10">
    <div class="w-9 h-9 rounded-full border-2 border-primary flex items-center justify-center shrink-0">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#c0392b" stroke-width="2.5">
        <circle cx="12" cy="12" r="9" />
        <circle cx="12" cy="12" r="3" />
      </svg>
    </div>
    Samson Dental <span class="text-primary ml-1">Center</span>
  </a>

  <div class="relative z-10">
    <div
      class="flex items-center gap-2 font-body text-[0.65rem] font-semibold tracking-[0.15em] uppercase text-white/35 mb-5">
      <span class="w-2 h-2 rounded-full bg-primary inline-block"></span>New
      Patient Registration
    </div>
    <h2 class="brand-font font-extrabold text-white leading-[1.08] mb-5" style="font-size: clamp(2rem, 3.2vw, 2.8rem)">
      Join 2,000+<br />happy patients.
    </h2>
    <p class="font-body text-[0.9rem] text-white/50 leading-relaxed max-w-xs mb-10">
      Create your free patient account and enjoy a smoother, more personalised
      dental experience at SDC.
    </p>

    <!-- Step progress visual -->
    <div class="space-y-4">
      <div class="flex items-center gap-3">
        <div id="lp_step1"
          class="w-8 h-8 rounded-full bg-primary flex items-center justify-center shrink-0 font-body text-[0.75rem] font-bold text-white step-indicator">
          1
        </div>
        <div>
          <div class="brand-font font-semibold text-white text-[0.85rem]">
            Personal Details
          </div>
          <div class="font-body text-[0.72rem] text-white/40">
            Your name and birthday
          </div>
        </div>
      </div>
      <div class="w-px h-4 bg-white/15 ml-4"></div>
      <div class="flex items-center gap-3">
        <div id="lp_step2"
          class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center shrink-0 font-body text-[0.75rem] font-bold text-white/40 step-indicator">
          2
        </div>
        <div>
          <div class="brand-font font-semibold text-white/50 text-[0.85rem]">
            Contact Info
          </div>
          <div class="font-body text-[0.72rem] text-white/30">
            Email and phone number
          </div>
        </div>
      </div>
      <div class="w-px h-4 bg-white/15 ml-4"></div>
      <div class="flex items-center gap-3">
        <div id="lp_step3"
          class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center shrink-0 font-body text-[0.75rem] font-bold text-white/40 step-indicator">
          3
        </div>
        <div>
          <div class="brand-font font-semibold text-white/50 text-[0.85rem]">
            Security
          </div>
          <div class="font-body text-[0.72rem] text-white/30">
            Create your password
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="relative z-10 flex items-center gap-4">
    <div class="flex -space-x-2">
      <img src="https://randomuser.me/api/portraits/women/44.jpg"
        class="w-8 h-8 rounded-full border-2 border-brand object-cover" alt="" />
      <img src="https://randomuser.me/api/portraits/men/32.jpg"
        class="w-8 h-8 rounded-full border-2 border-brand object-cover" alt="" />
      <img src="https://randomuser.me/api/portraits/women/68.jpg"
        class="w-8 h-8 rounded-full border-2 border-brand object-cover" alt="" />
    </div>
    <div>
      <div class="text-[#f59e0b] text-sm leading-none">★★★★★</div>
      <div class="font-body text-[0.7rem] text-white/50 mt-0.5">
        Trusted by 2,000+ patients
      </div>
    </div>
  </div>
</div>

<!-- ── Right panel ── -->
<div class="flex-1 flex items-center justify-center px-6 py-12 lg:py-0 overflow-y-auto ">
  <form id="signup-form" method="post" class="w-full max-w-[460px] fade-up animate">
    <!-- Mobile logo -->
    <div class="flex lg:hidden justify-center mb-8">
      <a href="../"
        class="brand-font flex items-center gap-2 font-extrabold text-[1rem] tracking-[0.07em] uppercase text-brand no-underline">
        <div class="w-9 h-9 rounded-full border-2 border-primary flex items-center justify-center shrink-0">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#c0392b" stroke-width="2.5">
            <circle cx="12" cy="12" r="9" />
            <circle cx="12" cy="12" r="3" />
          </svg>
        </div>
        Samson Dental <span class="text-primary ml-1">Center</span>
      </a>
    </div>

    <!-- Header -->
    <div class="mb-7">
      <h2 class="brand-font font-extrabold text-brand text-[1.9rem] leading-tight mb-1.5">
        Create your account
      </h2>
      <p class="font-body text-[0.9rem] text-muted">
        Fill in the details below to get started.
      </p>
    </div>

    <!-- Step progress bar (mobile/right panel) -->
    <div class="mb-8">
      <div class="flex items-center gap-2 mb-3">
        <div id="step_dot_1" class="w-2 h-2 rounded-full bg-primary transition-all duration-300"></div>
        <div id="step_dot_2" class="w-2 h-2 rounded-full bg-[#e5e7eb] transition-all duration-300"></div>
        <div id="step_dot_3" class="w-2 h-2 rounded-full bg-[#e5e7eb] transition-all duration-300"></div>
        <span id="stepLabel" class="font-body text-[0.72rem] text-muted ml-1">Step 1 of 3 — Personal Details</span>
      </div>
      <div class="h-1 bg-[#e5e7eb] rounded-full overflow-hidden">
        <div id="stepBar" class="h-full bg-primary rounded-full transition-all duration-500" style="width: 33%"></div>
      </div>
    </div>

    <!-- ══ STEP 1: Personal ══ -->
    <div id="step1" class="space-y-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block font-body text-[0.71rem] font-semibold tracking-[0.08em] uppercase text-muted mb-2">First
            Name <span class="text-primary">*</span></label>
          <div class="relative">
            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-muted pointer-events-none">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                <circle cx="12" cy="7" r="4" />
              </svg>
            </span>
            <input asp-for="Input.FirstName" id="su_fn" type="text" class="auth-input" placeholder="Juan" />
          </div>
          <div id="err_su_fn" class="field-error">First name is required.</div>
        </div>
        <div>
          <label class="block font-body text-[0.71rem] font-semibold tracking-[0.08em] uppercase text-muted mb-2">Last
            Name <span class="text-primary">*</span></label>
          <div class="relative">
            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-muted pointer-events-none">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                <circle cx="12" cy="7" r="4" />
              </svg>
            </span>
            <input asp-for="Input.LastName" id="su_ln" type="text" class="auth-input" placeholder="Dela Cruz" />
          </div>
          <div id="err_su_ln" class="field-error">Last name is required.</div>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block font-body text-[0.71rem] font-semibold tracking-[0.08em] uppercase text-muted mb-2">Date
            of Birth <span class="text-primary">*</span></label>
          <div class="relative">
            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-muted pointer-events-none">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
              </svg>
            </span>
            <input asp-for="Input.DateOfBirth" id="su_dob" type="date" class="auth-input" />
          </div>
          <div id="err_su_dob" class="field-error" asp-validation-for="Input.DateOfBirth">
            Date of birth is required.
          </div>
        </div>
        <div>
          <label class="block font-body text-[0.71rem] font-semibold tracking-[0.08em] uppercase text-muted mb-2">Sex
            <span class="text-primary">*</span></label>
          <div class="relative">
            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-muted pointer-events-none">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
              </svg>
            </span>
            <select asp-for="Input.Sex" id="su_sex" class="auth-input appearance-none pr-8">
              <option value="" disabled selected>Select</option>
              <option>Male</option>
              <option>Female</option>
              <option>Prefer not to say</option>
            </select>
            <span class="absolute right-3.5 top-1/2 -translate-y-1/2 text-muted pointer-events-none">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="6 9 12 15 18 9" />
              </svg>
            </span>
          </div>
          <div id="err_su_sex" class="field-error">Please select your sex.</div>
        </div>
      </div>

      <button type="button" id="gostep-2" data-next-step="2"
        class="brand-font font-bold text-[0.85rem] tracking-wider uppercase w-full bg-brand text-white py-3.5 rounded-xl hover:bg-primary transition-colors duration-200 cursor-pointer mt-2">
        Continue →
      </button>

      <div class="or-line font-body">or</div>

      <a href="../"
        class="brand-font font-bold text-[0.82rem] tracking-wider uppercase w-full border-2 border-[#e5e7eb] text-brand py-3.5 rounded-xl hover:border-brand hover:bg-brand hover:text-white transition-all duration-200 flex items-center justify-center gap-2 no-underline">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
          <circle cx="12" cy="7" r="4" />
        </svg>
        Continue as Guest
      </a>
    </div>

    <!-- ══ STEP 2: Contact ══ -->
    <div id="step2" class="space-y-4 hidden">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block font-body text-[0.71rem] font-semibold tracking-[0.08em] uppercase text-muted mb-2">Email
            Address <span class="text-primary">*</span></label>
          <div class="relative">
            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-muted pointer-events-none">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                <polyline points="22,6 12,13 2,6" />
              </svg>
            </span>
            <input asp-for="Input.Email" id="su_email" type="email" class="auth-input" placeholder="juan@email.com" />
          </div>
          <div id="err_su_email" class="field-error">
            Please enter a valid email address.
          </div>
        </div>

        <div>
          <label class="block font-body text-[0.71rem] font-semibold tracking-[0.08em] uppercase text-muted mb-2">Phone
            Number <span class="text-primary">*</span></label>
          <div class="relative">
            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-muted pointer-events-none">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.18 6.18l.95-.93a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
              </svg>
            </span>
            <input asp-for="Input.PhoneNumber" id="su_phone" type="tel" class="auth-input"
              placeholder="+63 9XX XXX XXXX" />
            <div id="err_su_phone" class="field-error">
              Phone number is required.
            </div>
          </div>
        </div>
      </div>
      <div>
        <label class="block font-body text-[0.71rem] font-semibold tracking-[0.08em] uppercase text-muted mb-2">Address
          <span class="text-muted font-normal normal-case">(optional)</span></label>
        <div class="relative">
          <span class="absolute left-3.5 top-3.5 text-muted pointer-events-none">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
          </span>
          <textarea asp-for="Input.Address" id="su_address" class="auth-input" rows="2"
            style="padding-top: 10px; resize: none" placeholder="City, Metro Manila"></textarea>
        </div>
      </div>

      <div class="flex gap-3">
        <button type="button" id="goback-1" type="button" data-prev-step="1"
          class="brand-font font-bold text-[0.82rem] tracking-wider uppercase flex-1 border-2 border-[#e5e7eb] text-muted py-3.5 rounded-xl hover:border-brand hover:text-brand transition-all cursor-pointer">
          ← Back
        </button>
        <button type="button" id="gostep-3" type="button" data-next-step="3"
          class="brand-font font-bold text-[0.85rem] tracking-wider uppercase flex-[2] bg-brand text-white py-3.5 rounded-xl hover:bg-primary transition-colors duration-200 cursor-pointer">
          Continue →
        </button>
      </div>
    </div>


    <!-- ══ STEP 3: Security ══ -->
    <div id="step3" class="space-y-4 hidden">
      <div>
        <label class="block font-body text-[0.71rem] font-semibold tracking-[0.08em] uppercase text-muted mb-2">Password
          <span class="text-primary">*</span></label>
        <div class="relative">
          <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-muted pointer-events-none">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
              <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
          </span>
          <input asp-for="Input.Password" id="su_pw" type="password" class="auth-input pr-11" tabindex="1"
            placeholder="Create a strong password" />
          <button type="button"
            class="absolute right-3.5 top-1/2 -translate-y-1/2 text-muted hover:text-primary transition-colors check-pw"
            data-input="su_pw">
            <svg class="eye-show" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
              <circle cx="12" cy="12" r="3" />
            </svg>
            <svg class="eye-hide hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94" />
              <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19" />
              <line x1="1" y1="1" x2="23" y2="23" />
            </svg>
          </button>
        </div>
        <!-- Strength bar -->
        <div class="mt-2 flex gap-1.5">
          <div id="sb1" class="strength-bar flex-1 bg-[#e5e7eb]"></div>
          <div id="sb2" class="strength-bar flex-1 bg-[#e5e7eb]"></div>
          <div id="sb3" class="strength-bar flex-1 bg-[#e5e7eb]"></div>
          <div id="sb4" class="strength-bar flex-1 bg-[#e5e7eb]"></div>
        </div>
        <div id="strengthLabel" class="font-body text-[0.7rem] text-muted mt-1"></div>
        <div id="err_su_pw" class="field-error">
          Password must be at least 8 characters.
        </div>
      </div>

      <div>
        <label class="block font-body text-[0.71rem] font-semibold tracking-[0.08em] uppercase text-muted mb-2">Confirm
          Password <span class="text-primary">*</span></label>
        <div class="relative">
          <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-muted pointer-events-none">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
              <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
          </span>
          <input asp-for="Input.ConfirmPassword" id="su_pw2" type="password" class="auth-input pr-11" tabindex="2"
            placeholder="Re-enter your password" />
          <button type="button"
            class="absolute right-3.5 top-1/2 -translate-y-1/2 text-muted hover:text-primary transition-colors check-pw"
            data-input="su_pw2">
            <svg class="eye-show" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
              <circle cx="12" cy="12" r="3" />
            </svg>
            <svg class="eye-hide hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94" />
              <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19" />
              <line x1="1" y1="1" x2="23" y2="23" />
            </svg>
          </button>
        </div>
        <div id="err_su_pw2" class="field-error">Passwords do not match.</div>
      </div>

      <!-- Patient type -->
      <div>
        <label class="block font-body text-[0.71rem] font-semibold tracking-[0.08em] uppercase text-muted mb-3">Patient
          Type</label>
        <div class="flex gap-4 flex-wrap">
          <label class="flex items-center gap-2.5 cursor-pointer font-body text-[0.87rem] text-brand">
            <input type="radio" asp-for="Input.PatientType" value="New Patient" checked
              class="accent-primary w-4 h-4" />
            New Patient
          </label>
          <label class="flex items-center gap-2.5 cursor-pointer font-body text-[0.87rem] text-brand">
            <input type="radio" asp-for="Input.PatientType" value="Returning Patient" class="accent-primary w-4 h-4" />
            Returning Patient
          </label>
        </div>
      </div>

      <!-- Consent -->
      <div>

        <div class="bg-offwhite rounded-xl flex items-start gap-3" id="consentBox">
          <input asp-for="Input.Consent" type="checkbox" id="su_consent"
            class="accent-primary w-4 h-4 mt-0.5 shrink-0 cursor-pointer " />
          <label for="su_consent" class="font-body text-[0.8rem] text-muted leading-relaxed cursor-pointer">
            I agree to the
            <a href="#" class="text-primary hover:underline">Terms of Service</a>
            and
            <a href="#" class="text-primary hover:underline">Privacy Policy</a>
            of Samson Dental Center.
          </label>
        </div>
        <div id="err_su_consent" class="field-error">
          You must agree to the terms to continue.
        </div>
      </div>

      <div class="flex gap-3 pt-1">
        <button type="button" id="goback-2" data-prev-step="2"
          class="brand-font font-bold text-[0.82rem] tracking-wider uppercase flex-1 border-2 border-[#e5e7eb] text-muted py-3.5 rounded-xl hover:border-brand hover:text-brand transition-all cursor-pointer">
          ← Back
        </button>
        <button type="button" id="create-acc-btn"
          class="brand-font font-bold text-[0.85rem] tracking-wider uppercase flex-[2] bg-brand text-white py-3.5 rounded-xl hover:bg-primary transition-colors duration-200 cursor-pointer">
          Create Account →
        </button>
      </div>
    </div>

    <!-- Sign in link -->
    <p class="font-body text-[0.85rem] text-muted text-center mt-7">
      Already have an account?
      <a href="/sign-in" class="text-primary font-medium hover:underline ml-1">Sign in →</a>
    </p>
  </form>
</div>